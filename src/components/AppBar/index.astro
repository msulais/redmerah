---
import { joinClassList } from '@/utils/attributes'

import { CAppBar, type AppBarProps } from '.'
import './index.scss'

type Props = AppBarProps
const {
	'class': className,
	AppBarTagName      = 'header',
	AppBarLeadingAttr  = {},
	AppBarTrailingAttr = {},
	AppBarContentAttr  = {},
	AppBarHeadingAttr  = {},
	AppBarFlexAttr     = {},
	...other
} = Astro.props
const {'class': contentClass , ...contentOther } = AppBarContentAttr
const {'class': headingClass , ...headingOther } = AppBarHeadingAttr
const {'class': leadingClass , ...leadingOther } = AppBarLeadingAttr
const {'class': trailingClass, ...trailingOther} = AppBarTrailingAttr
const {'class': flexClass    , ...flexOther} = AppBarFlexAttr

const Dynamic = AppBarTagName as 'header'
const cls = CAppBar.Classes
---
<Dynamic
	class={joinClassList(cls.Appbar, className)}
	{...other}>
	<div
		class={joinClassList(cls.Leading, leadingClass)}
		{...leadingOther}><slot name='leading'/></div>
	<div
		class={joinClassList(cls.Content, contentClass)}
		{...contentOther}>
		<h2
			class={joinClassList(cls.Headline, headingClass)}
			{...headingOther}><slot name='headline'/></h2>
		<slot />
	</div>
	<div
		class={joinClassList(cls.Flex, flexClass)}
		{...flexOther}/>
	<div
		class={joinClassList(cls.Trailing, trailingClass)}
		{...trailingOther}><slot name='trailing'/></div>
</Dynamic>