---
import { joinClassList } from '@/utils/attributes'

import {
	AppBarClasses,
	type AppBarProps
} from '.'
import './index.scss'

type Props = AppBarProps
const {
	'class': className,
	AppTagName      = 'header',
	AppLeadingAttr  = {},
	AppTrailingAttr = {},
	AppContentAttr  = {},
	AppHeadingAttr  = {},
	...other
} = Astro.props
const {'class': contentClass , ...contentOther } = AppContentAttr
const {'class': headingClass , ...headingOther } = AppHeadingAttr
const {'class': leadingClass , ...leadingOther } = AppLeadingAttr
const {'class': trailingClass, ...trailingOther} = AppTrailingAttr

const Dynamic = AppTagName as 'header'
---
<Dynamic
	class={joinClassList(AppBarClasses.appbar, className)}
	{...other}>
	{Astro.slots.has('leading') &&
		<div class={joinClassList(AppBarClasses.leading, leadingClass)} {...leadingOther}>
			<slot name='leading'/>
		</div>
	}
	<div class={joinClassList(AppBarClasses.content, contentClass)} {...contentOther}>
		{Astro.slots.has('headline') &&
			<h2
				class={joinClassList(AppBarClasses.headline, headingClass)}
				{...headingOther}>
				<slot name='headline'/>
			</h2>
		}
		<slot />
	</div>
	{Astro.slots.has('trailing') &&
		<div class={joinClassList(AppBarClasses.trailing, trailingClass)} {...trailingOther}>
			<slot name='trailing'/>
		</div>
	}
</Dynamic>