---
import { joinClassList } from '@/utils/attributes'

import {
	AppBarClasses,
	type AppBarProps
} from '.'
import './index.scss'

type Props = AppBarProps
const {
	'class': className,
	AppBarTagName      = 'header',
	AppBarLeadingAttr  = {},
	AppBarTrailingAttr = {},
	AppBarContentAttr  = {},
	AppBarHeadingAttr  = {},
	...other
} = Astro.props
const {'class': contentClass , ...contentOther } = AppBarContentAttr
const {'class': headingClass , ...headingOther } = AppBarHeadingAttr
const {'class': leadingClass , ...leadingOther } = AppBarLeadingAttr
const {'class': trailingClass, ...trailingOther} = AppBarTrailingAttr

const Dynamic = AppBarTagName as 'header'
---
<Dynamic
	class={joinClassList(AppBarClasses.appbar, className)}
	{...other}>
	{Astro.slots.has('leading') &&
		<div class={joinClassList(AppBarClasses.leading, leadingClass)} {...leadingOther}>
			<slot name='leading'/>
		</div>
	}
	<div class={joinClassList(AppBarClasses.content, contentClass)} {...contentOther}>
		{Astro.slots.has('headline') &&
			<h2
				class={joinClassList(AppBarClasses.headline, headingClass)}
				{...headingOther}>
				<slot name='headline'/>
			</h2>
		}
		<slot />
	</div>
	{Astro.slots.has('trailing') &&
		<div class={joinClassList(AppBarClasses.trailing, trailingClass)} {...trailingOther}>
			<slot name='trailing'/>
		</div>
	}
</Dynamic>