---
import { toggleAttribute } from '@/utils/attributes'
import './index.scss'

type Props = astroHTML.JSX.HTMLAttributes & {
    inline?: boolean
    filled?: boolean
    classList?: string[]
    code: number
}

let {inline, filled, code, classList = [], ...other} = Astro.props

if (filled) code -= 1
---

<i class:list={["icon", ...classList]} data-inline={toggleAttribute(inline)} {...other}>{
    String.fromCharCode(code)
}</i>