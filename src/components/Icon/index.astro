---
import { joinClassList } from '@/utils/attributes'
import { CIcon, type IconProps } from '.'
import './index.scss'

type Props = IconProps

const {
	'class': className,
	IconFilled,
	IconInline,
	IconCode,
	translate,
	...other
} = Astro.props
const cls = CIcon.Classes
---
<i
	class={joinClassList(cls.icon, className)}
	data-c-icon-inline={IconInline? '' : undefined}
	translate={translate ?? 'no'}
	{...other}>{String.fromCharCode(IconCode - (IconFilled? 1 : 0))}</i>