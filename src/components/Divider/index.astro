---
import { joinClassList } from '@/utils/attributes'
import {type DividerProps, CDivider} from '.'
import './index.scss'

type Props = DividerProps
const {
	'class': className,
	...other
} = Astro.props
const cls = CDivider.Classes
---
<div
	class={joinClassList(cls.Divider, className)}
	{...other}
/>