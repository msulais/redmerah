---
import { joinClassList } from '@/utils/attributes'
import { CComboBox, type ComboBoxProps } from '.'
import './index.scss'
type Props = ComboBoxProps
const {
	'class': className,
	ComboBoxVariant: variant = CComboBox.Variant.tonal,
	autocomplete = 'off',
	...other
} = Astro.props

const cls = CComboBox.Classes
---
<select
	class={joinClassList(cls.combobox, className)}
	data-c-combobox-variant={variant}
	autocomplete={autocomplete}
	{...other}><slot /></select>