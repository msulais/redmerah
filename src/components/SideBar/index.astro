---
import { joinClassList } from '@/utils/attributes'
import {type SideBarProps, CSideBar} from '.'
import './index.scss'

type Props = SideBarProps

const {
	'class': className,
	SideBarMinimized,
	SideBarTagName     = 'div',
	SideBarContentAttr = {},
	SideBarHeaderAttr  = {},
	SideBarFooterAttr  = {},
	...other
} = Astro.props
const {'class': contentClass, ...contentOther} = SideBarContentAttr
const {'class': headerClass , ...headerOther } = SideBarHeaderAttr
const {'class': footerClass , ...footerOther } = SideBarFooterAttr

const Dynamic = SideBarTagName as 'div'
const cls = CSideBar.Classes
---

<Dynamic
	class={joinClassList(cls.SideBar, className)}
	data-c-sidebar-minimized={SideBarMinimized? '' : undefined}
	{...other}>
	{Astro.slots.has('header') &&
		<div
			class={joinClassList(cls.Header, headerClass)}
			{...headerOther}><slot name="header"/></div>
	}
	<div
		class={joinClassList(cls.Content, contentClass)}
		{...contentOther}><slot /></div>
	{Astro.slots.has('footer') &&
		<div
			class={joinClassList(cls.Footer, footerClass)}
			{...footerOther}><slot name="footer"/></div>
	}
</Dynamic>