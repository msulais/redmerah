---
import { joinClassList } from '@/utils/attributes'
import { CSlider, type SliderProps } from '.'
import './index.scss'

type Props = SliderProps
const {
	'class': className,
	max = '100',
	value = '0',
	min = '0',
	autocomplete = 'off',
	...other
} = Astro.props

const cls = CSlider.Classes
---

<input
	class={joinClassList(cls.Slider, className)}
	type="range"
	value={value}
	min={min}
	max={max}
	autocomplete={autocomplete}
	{...other}
/>
<script>
	import { CSlider } from "."
	CSlider.register()
</script>