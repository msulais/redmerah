---
import { joinClassList } from '@/utils/attributes'
import { CTextAreaField, type TextAreaFieldProps } from '.'
import './index.scss'

type Props = TextAreaFieldProps
const {
	'class': className,
	...other
} = Astro.props

const cls = CTextAreaField.Classes
---
<textarea
	class={joinClassList(cls.textareafield, className)}
	{...other}>{other.value}</textarea>