---
import { joinClassList } from '@/utils/attributes'
import {type DialogProps, CDialog} from '.'
import './index.scss'

type Props = DialogProps
const {
	'class': className,
	DialogImportant,
	DialogContainerAttr,
	DialogHeaderAttr,
	DialogContentAttr,
	DialogFooterAttr,
	...other
} = Astro.props
const {'class': containerClass, ...containerOther} = DialogContainerAttr ?? {}
const {'class': headerClass   , ...headerOther   } = DialogHeaderAttr    ?? {}
const {'class': contentClass  , ...contentOther  } = DialogContentAttr   ?? {}
const {'class': footerClass   , ...footerOther   } = DialogFooterAttr    ?? {}

const cls = CDialog.Classes
---

<dialog
	class={joinClassList(cls.dialog, className)}
	data-c-dialog-important={DialogImportant? '' : undefined}
	{...other}>
	<div class={joinClassList(cls.container, containerClass)} {...containerOther}>
		<div
			class={joinClassList(cls.header, headerClass)}
			{...headerOther}><slot name="header"/></div>
		<div
			class={joinClassList(cls.content, contentClass)}
			{...contentOther}><slot /></div>
		<div
			class={joinClassList(cls.footer, footerClass)}
			{...footerOther}><slot name="footer"/></div>
	</div>
</dialog>
<script>
	import { CDialog } from '.'
	CDialog.register()
</script>