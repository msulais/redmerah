---
import { joinClassList } from '@/utils/attributes'
import { IconCodes } from '@/enums/icons'
import {type RadioMenuItemProps, CMenu} from '.'
import { CButton } from '@/components/Button'
import Icon from '@/components/Icon/index.astro'
import './index.scss'

type Props = RadioMenuItemProps
const {
	'class': className,
	RadioMenuItemChecked,
	RadioMenuItemDisabled,
	RadioMenuItemName,
	RadioMenuItemValue,
	RadioMenuItemLeadingAttr = {},
	RadioMenuItemInputAttr = {},
	RadioMenuItemIconAttr,
	RadioMenuItemContentAttr = {},
	...other
} = Astro.props
const {'class': leadingClassName, ...leadingOther} = RadioMenuItemLeadingAttr
const {'class': contentClassName, ...contentOther} = RadioMenuItemContentAttr
const {
	'class': iconClassName,
	IconCode: iconIcon = IconCodes.circleSmall,
	IconFilled: iconFilled = true,
	...iconOther
} = RadioMenuItemIconAttr ?? {}
const {
	'class': inputClassName,
	name: inputName = RadioMenuItemName,
	checked: inputChecked = RadioMenuItemChecked,
	disabled: inputDisabled = RadioMenuItemDisabled,
	type: inputType = "radio",
	role: inputRole = "menuitemradio",
	value: inputValue = RadioMenuItemValue,
	autocomplete: inputAutocomplete = 'off',
	...inputOther
} = RadioMenuItemInputAttr

const cls = CMenu.Classes
---
<label
	class={joinClassList(CButton.Classes.button, cls.item, cls.radioItem, className)}
	{...other}>
	<div
		class={joinClassList(cls.radioItemLeading, leadingClassName)}
		{...leadingOther}><slot name="leading"/></div>
	<input
		name={inputName}
		checked={inputChecked}
		disabled={inputDisabled}
		type={inputType}
		role={inputRole}
		value={inputValue}
		autocomplete={inputAutocomplete}
		class={joinClassList(cls.radioItemInput, inputClassName)}
		{...inputOther}
	/>
	<Icon
		class={joinClassList(cls.radioItemIcon, iconClassName)}
		IconCode={iconIcon}
		IconFilled={iconFilled}
		{...iconOther}
	/>
	<div
		class={joinClassList(cls.radioItemContent, contentClassName)}
		{...contentOther}><slot /></div>
</label>