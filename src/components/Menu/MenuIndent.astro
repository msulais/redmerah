---
import { joinClassList } from '@/utils/attributes'
import {CMenu, type MenuIndentProps} from '.'
import './index.scss'

type Props = MenuIndentProps
const {
	'class': className,
	...other
} = Astro.props

const cls = CMenu.Classes
---
<div
	class={joinClassList(cls.indent, className)}
	{...other}
/>