---
import { joinClassList } from '@/utils/attributes'
import {CMenu, type SubMenuItemProps} from '.'
import MenuItem from './MenuItem.astro'
import './index.scss'

type Props = SubMenuItemProps
const {
	'class': className,
	...other
} = Astro.props

const cls = CMenu.Classes
---

<MenuItem
	class={joinClassList(cls.submenuItem, className)}
	{...other}><slot /></MenuItem>
<script>
	import { CMenu } from '.'
	CMenu.CSubItem.register()
</script>