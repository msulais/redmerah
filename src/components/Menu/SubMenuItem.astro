---
import { joinClassList } from '@/utils/attributes'

import {
	MenuClasses,
	type SubMenuItemProps
} from '.'
import MenuItem from './MenuItem.astro'
import './index.scss'

type Props = SubMenuItemProps
const {
	'class': className,
	...other
} = Astro.props
---

<MenuItem
	class={joinClassList(MenuClasses.submenuItem, className)}
	{...other}>
	<slot />
</MenuItem>
<script>
	import { registerSubMenuItemRef } from '.'
	registerSubMenuItemRef()
</script>