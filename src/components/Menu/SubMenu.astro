---
import { joinClassList } from '@/utils/attributes'
import { type SubMenuProps, CMenu } from '.'
import Menu from './index.astro'
import './index.scss'
import { pxToRem } from '@/utils/css'
import { FlyoutPosition } from '@/enums/position'

type Props = SubMenuProps
const {
	'class': className,
	PopoverGap = pxToRem(-4),
	popover = 'manual',
	PopoverPosition: position = FlyoutPosition.RightCenterToBottom,
	...other
} = Astro.props

const cls = CMenu.Classes
---

<Menu
	class={joinClassList(cls.Submenu, className)}
	PopoverPosition={position}
	PopoverGap={PopoverGap}
	popover={popover}
	{...other}><slot /></Menu>