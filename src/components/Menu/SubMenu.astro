---
import { joinClassList } from '@/utils/attributes'

import { type SubMenuProps, MenuClasses } from '.'
import Menu from './index.astro'
import './index.scss'
import { PopoverPosition } from '../Popover'
import { pxToRem } from '@/utils/css'

type Props = SubMenuProps
const {
	'class': className,
	PopoverGap = pxToRem(-4),
	popover = 'manual',
	PopoverPosition: position = PopoverPosition.rightCenterToBottom,
	...other
} = Astro.props
---

<Menu
	class={joinClassList(MenuClasses.submenu, className)}
	PopoverPosition={position}
	PopoverGap={PopoverGap}
	popover={popover}
	{...other}>
	<slot />
</Menu>