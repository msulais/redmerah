---
import Popover from '@/components/Popover/index.astro'
import Button from '@/components/Button/index.astro'
import Tooltip from '@/components/Tooltip/index.astro'
import Divider from '@/components/Divider/index.astro'
import IconButton from '@/components/Button/IconButton.astro'
import { IconCodes } from '@/enums/icons'
import { CButton } from '../Button'
import './index.scss'
import { type DatePickerProps, CDatePicker } from '.'
import { joinClassList } from '@/utils/attributes'

type Props = DatePickerProps
const {
	'class': className,
	DatePickerStartDate = new Date(-864000000000000),
	DatePickerEndDate = new Date(864000000000000),
	DatePickerValue,
	DatePickerHeaderAttr,
	DatePickerTitleAttr,
	DatePickerPreviousAttr,
	DatePickerNextAttr,
	DatePickerDaysAttr,
	DatePickerDayAttr = [],
	DatePickerDividerAttr,
	DatePickerYearAttr,
	DatePickerYearButtonAttr = [],
	DatePickerMonthAttr,
	DatePickerMonthButtonAttr = [],
	DatePickerDateAttr,
	DatePickerDateEmptyAttr = [],
	DatePickerDateButtonAttr = [],
	DatePickerContentAttr,
	...other
} = Astro.props
const {'class': headerClass, ...headerOther} = DatePickerHeaderAttr ?? {}
const {'class': titleClass, ButtonVariant: titleVariant = CButton.Variant.filled, ...titleOther} = DatePickerTitleAttr ?? {}
const {
	'class': previousClass,
	ButtonVariant: previousVariant = CButton.Variant.tonal,
	IconButtonCode: previousIconCode = IconCodes.chevronLeft,
	...previousOther
} = DatePickerPreviousAttr ?? {}
const {
	'class': nextClass,
	ButtonVariant: nextVariant = CButton.Variant.tonal,
	IconButtonCode: nextIconCode = IconCodes.chevronRight,
	...nextOther
} = DatePickerNextAttr ?? {}
const {'class': daysClass, ...daysOther} = DatePickerDaysAttr ?? {}
const {'class': dividerClass, ...dividerOther} = DatePickerDividerAttr ?? {}
const {'class': yearClass, ...yearOther} = DatePickerYearAttr ?? {}
const {'class': monthClass, ...monthOther} = DatePickerMonthAttr ?? {}
const {'class': dateClass, ...dateOther} = DatePickerDateAttr ?? {}
const {'class': contentClass, ...contentOther} = DatePickerContentAttr ?? {}

const cls = CDatePicker.Classes
---

<Popover
	class={joinClassList(cls.datepicker, className)}
	data-c-datepicker-start={DatePickerStartDate.toISOString()}
	data-c-datepicker-end={DatePickerEndDate?.toISOString()}
	data-c-datepicker-value={DatePickerValue?.toISOString()}
	data-c-datepicker-viewtype={CDatePicker.ViewType.day}
	{...other}>
	<div
		class={joinClassList(cls.header, headerClass)}
		{...headerOther}>
		<Button
			ButtonVariant={titleVariant}
			class={joinClassList(cls.title, titleClass)}
			{...titleOther}>
			January 2025
		</Button>
		<IconButton
			ButtonVariant={previousVariant}
			class={joinClassList(cls.previous, previousClass)}
			IconButtonCode={previousIconCode}
			{...previousOther}
		/>
		<IconButton
			ButtonVariant={nextVariant}
			class={joinClassList(cls.next, nextClass)}
			IconButtonCode={nextIconCode}
			{...nextOther}
		/>
	</div>
	<Divider
		class={joinClassList(cls.divider, dividerClass)}
		{...dividerOther}
	/>
	<Tooltip
		class={joinClassList(cls.days, daysClass)}
		{...daysOther}>
		{['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'].map((v, i) => {
			const {
				'class': className,
				'data-tooltip': tooltip = v,
				...other
			} = DatePickerDayAttr[i] ?? {}
			return <span
				class={joinClassList(cls.day, className)}
				data-tooltip={tooltip}
				{...other}>
				{v.substring(0, 3)}
			</span>
		})}
	</Tooltip>
	<div
		class={joinClassList(cls.year, yearClass)}
		{...yearOther}>
		{Array(16).fill(2025).map((v, i) => {
			const {
				'class': className,
				...other
			} = DatePickerYearButtonAttr[i] ?? {}
			return <Button
				class={joinClassList(cls.yearButton, className)}
				{...other}>
				{v + i}
			</Button>
		})}
	</div>
	<div
		class={joinClassList(cls.month, monthClass)}
		{...monthOther}>
		{[
			'January', 'February', 'March', 'April',
			'May', 'June', 'July', 'August', 'September',
			'October', 'November', 'December'].map((v, i) =>
		{
			const {'class': className, ...other} = DatePickerMonthButtonAttr[i] ?? {}
			return <Button
				class={joinClassList(cls.monthButton, className)}
				{...other}>
				{v}
			</Button>
		})}
	</div>
	<div
		class={joinClassList(cls.date, dateClass)}
		{...dateOther}>
		{Array(6).fill(0).map((_, i) => {
			const {'class': className, ...other} = DatePickerDateEmptyAttr[i] ?? {}
			return (<div
				class={joinClassList(cls.dateEmpty, className)}
				{...other}
			/>)
		})}
		{Array(31).fill(0).map((_, i) => {
			const {
				'class': className,
				...other
			} = DatePickerDateButtonAttr[i] ?? {}
			return <Button
				class={joinClassList(cls.dateButton, className)}
				{...other}>
				{i + 1}
			</Button>
		})}
	</div>
	<div
		class={joinClassList(cls.content, contentClass)}
		{...contentOther}><slot /></div>
</Popover>
<script>
	import { CDatePicker } from '.'
	CDatePicker.register()
</script>