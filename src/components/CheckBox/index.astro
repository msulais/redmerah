---
import { joinClassList } from '@/utils/attributes'

import {
	type CheckBoxProps,
	CheckBoxClasses
} from '.'
import './index.scss'

type Props = CheckBoxProps
const {
	'class': className,
	CheckBoxChecked     = false,
	CheckBoxInputAttr   = {},
	CheckBoxIconAttr    = {},
	CheckBoxContentAttr = {},
	...other
} = Astro.props
const {'class': inputClass  , checked = CheckBoxChecked, autocomplete = 'off', type = 'checkbox', ...inputOther} = CheckBoxInputAttr
const {'class': iconClass   , ...iconOther   } = CheckBoxIconAttr
const {'class': contentClass, ...contentOther} = CheckBoxContentAttr
---

<label class={joinClassList(CheckBoxClasses.checkbox, className)} {...other}>
	<input
		class={joinClassList(CheckBoxClasses.input, inputClass)}
		autocomplete={autocomplete}
		checked={checked}
		type={type}
		{...inputOther}
	/>
	<svg
		class={joinClassList(CheckBoxClasses.icon, iconClass)}
		xmlns="http://www.w3.org/2000/svg"
		viewBox="0 -960 960 960"
		{...iconOther}>
		<path d="m389-369 299-299q10.91-11 25.45-11Q728-679 739-668t11 25.58q0 14.58-10.61 25.19L415-292q-10.91 11-25.45 11Q375-281 364-292L221-435q-11-11-11-25.5t11-25.5q11-11 25.67-11 14.66 0 25.33 11l117 117Z"/>
	</svg>
	<div
		class={joinClassList(CheckBoxClasses.content, contentClass)}
		{...contentOther}>
		<slot />
	</div>
</label>