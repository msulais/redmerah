---
import { attrClassList } from '@/utils/attributes'
import { ComboBoxClasses, ComboBoxVariant, type ComboBoxProps } from '.'
import './index.scss'
type Props = ComboBoxProps
const {
	'class': className,
	ComboBoxVariant: variant = ComboBoxVariant.tonal,
	autocomplete = 'off',
	...other
} = Astro.props
---
<select
	class={attrClassList(ComboBoxClasses.combobox, className)}
	data-c-combobox-variant={variant}
	autocomplete={autocomplete}
	{...other}>
	<slot />
</select>