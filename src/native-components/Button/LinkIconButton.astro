---
import LinkButton from './LinkButton.astro'
import Icon from '@/native-components/Icon/index.astro'
import { attrClassList } from '@/utils/attributes'
import { ButtonClasses, type LinkIconButtonProps } from '.'

import './index.scss'

type Props = LinkIconButtonProps

const {
	'class': className,
	LinkIconButtonCode,
	LinkIconButtonFilled,
	LinkIconButtonIconAttr = {},
	...other
} = Astro.props
const {
	IconFilled,
	IconCode,
	...iconOther
} = LinkIconButtonIconAttr
---
<LinkButton
	class={attrClassList(ButtonClasses.icon, className)}
	{...other}>
	<Icon
		IconCode={IconCode ?? LinkIconButtonCode}
		IconFilled={IconFilled ?? LinkIconButtonFilled}
		{...iconOther}
	/>
</LinkButton>