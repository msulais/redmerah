---
import { attrClassList } from '@/utils/attributes'
import { type IconProps, IconClasses } from '.'

import './index.scss'

type Props = IconProps

const {
	'class': className,
	IconFilled,
	IconInline,
	IconCode,
	translate,
	...other
} = Astro.props
---
<i
	class={attrClassList(IconClasses.icon, className)}
	data-c-icon-inline={IconInline? '' : undefined}
	translate={translate ?? 'no'}
	{...other}>
	{String.fromCharCode(IconCode - (IconFilled? 1 : 0))}
</i>