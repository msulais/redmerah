---
import { attrClassList } from '@/utils/attributes'

import { ButtonClasses } from '@/native-components/Button'
import Icon from '@/native-components/Icon/index.astro'
import {
	type SelectProps,
	SelectClasses,
	SelectVariant as SSelectVariant
} from '.'
import './index.scss'
import { IconCodes } from '@/enums/icons'

type Props = SelectProps
const {
	SelectContentAttr     = {},
	SelectPopoverAttr     = {},
	SelectPlaceholderAttr = {},
	SelectIconAttr        = {},
	SelectVariant         = SSelectVariant.tonal,
	SelectUseIcon         = true,
	'class': className,
	role,
	...other
} = Astro.props

const {'class': iconClass       , ...iconOther   } = SelectIconAttr
const {'class': contentClass    , ...contentOther} = SelectContentAttr
const {'class': popoverClass    , ...popoverOther} = SelectPopoverAttr
const {'class': placeholderClass, tabindex, ...placeholderOther} = SelectPlaceholderAttr
---

<div
	class={attrClassList(SelectClasses.select, className)}
	data-c-select-variant={SelectVariant}
	data-c-select-use-icon={SelectUseIcon? '' : undefined}
	role={role ?? 'listbox'}
	{...other}>
	<div
		class={attrClassList(SelectClasses.popover, popoverClass)}
		{...popoverOther}>
		<div
			class={attrClassList(SelectClasses.content, contentClass)}
			{...contentOther}>
			<slot/>
			<div
				class={attrClassList(
					ButtonClasses.button,
					SelectClasses.placeholder,
					placeholderClass
				)}
				tabindex={tabindex ?? 0}
				{...placeholderOther}>
				<slot name="placeholder">
					Choose item
				</slot>
			</div>
		</div>
	</div>
	<Icon
		class={attrClassList(
			SelectClasses.icon,
			iconClass
		)}
		IconCode={IconCodes.chevronDown}
		{...iconOther}
	/>
</div>
<script>
	import { registerSelectRef } from '.'
	registerSelectRef()
</script>