---
import { attrClassList } from '@/utils/attributes'

import {
	MenuClasses,
	type MenuProps
} from '.'
import Popover from '@/native-components/Popover/index.astro'
import './index.scss'

type Props = MenuProps
const {
	'class': className,
	PopoverGap = 8,
	PopoverPadding = 5, // +1px border
	role,
	...other
} = Astro.props
---

<Popover
	role={role ?? 'menu'}
	class={attrClassList(MenuClasses.menu, className)}
	PopoverGap={PopoverGap}
	PopoverPadding={PopoverPadding}
	{...other}>
	<slot />
</Popover>
<script>
	import { registerMenuRef } from '.'
	registerMenuRef()
</script>