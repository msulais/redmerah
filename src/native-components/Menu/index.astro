---
import { MenuClasses, type MenuProps } from '.'
import Popover from '@/native-components/Popover/index.astro'
import { attrClassList } from '@/utils/attributes'

import './index.scss'

type Props = MenuProps

const {
	'class': className,
	'c:gap': gap = 8,
	'c:padding': padding = 5, // +1px border
	role,
	...other
} = Astro.props
---

<Popover
	role={role ?? 'menu'}
	class={attrClassList(MenuClasses.menu, className)}
	c:gap={gap}
	c:padding={padding}
	{...other}>
	<slot />
</Popover>