---
import { attrClassList } from '@/utils/attributes'

import {
	type TextFieldButtonProps,
	TextFieldClasses
} from '.'
import Button from '@/native-components/Button/index.astro'
import './index.scss'

type Props = TextFieldButtonProps
const {
	'class': className,
	...other
} = Astro.props
---

<Button
	class={attrClassList(TextFieldClasses.button, className)}
	{...other}>
	<slot/>
</Button>