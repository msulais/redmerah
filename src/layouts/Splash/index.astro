---
import { ElementIds } from '@/enums/ids'
import { toggleAttribute } from '@/utils/attributes'

type Props = {
	src: string
	alt: string
}
const {
	alt = 'Splash icon',
	src = '#',
} = Astro.props
---
<div
	id={ElementIds.splash}
	style={{
		zIndex: 999,
		width: '100%',
		height: '100dvh',
		backgroundColor: 'rgb(var(--g-color-background))',
		position: 'fixed',
		left: 0,
		top: 0,
		display: 'flex',
		alignItems: 'center',
		justifyContent: 'center'
	}}>
	<img
		width="160"
		src={src}
		alt={alt}
		style={{
			position: 'absolute',
			filter: 'blur(64px)',
			opacity: '.3'
		}}
	/>
	<img width="160" src={src} alt={alt} />
</div>