---
import type { HEXColor } from '@/types/color'
import { generateColorPalette, hexToRgb } from '@/utils/color'
import { GlobalElementIds } from '@/enums/ids'
import { PlatformAnimationMode, PlatformThemeMode } from '@/enums/platforms'
import Dialog from '@/components/Dialog/index.astro'
import Icon from '@/components/Icon/index.astro'
import Button from '@/components/Button/index.astro'
import LinkButton from '@/components/Button/LinkButton.astro'
import '@/styles/variables.scss'
import '@/styles/index.scss'
import { IconCodes } from '@/enums/icons'
import { AppCSSColors } from '@/enums/app-data'
import { ButtonVariant } from '@/components/Button'

type Props = {
	title?: string
	description?: string
	lang?: string
	theme?: PlatformThemeMode
	animation?: PlatformAnimationMode
	accentColor?: HEXColor
}

const {
	title = 'Redmerah • Increase your productivity with our apps',
	description = 'Get things done faster with zero interruptions! Redmerah offers powerful, privacy-focused tools to boost your productivity. Free, secure & data stays local.',
	lang = 'en-US',
	theme = PlatformThemeMode.auto,
	animation = PlatformAnimationMode.auto,
	accentColor = '#FF0000',
} = Astro.props

const colors = generateColorPalette(accentColor)
const colorToCSS = (hex: HEXColor) => {
	const rgb = hexToRgb(hex)
	return `${Math.round(rgb.r * 0xff)}, ${Math.round(rgb.g * 0xff)}, ${Math.round(rgb.b * 0xff)}`
}
---

<html lang={ lang } data-animation={ animation } data-theme={ theme }>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content={ accentColor } />
		<meta name="description" content={ description }>
		<title>{ title }</title>
		<style id={GlobalElementIds.colorAccent} set:html={`:root{--g-color-accent-light: ${colorToCSS(colors.color)};--g-color-accent-dark: ${colorToCSS(colors.colorDark)};--g-color-on-accent-light: ${colorToCSS(colors.onColor)};--g-color-on-accent-dark: ${colorToCSS(colors.onColorDark)};}`}/>
		<slot name="favicon">
			<link rel="shortcut icon" type="image/ico" href="/favicon/favicon.ico" />
			<link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
			<link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
			<link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
			<link rel="manifest" href="/favicon/site.webmanifest">
		</slot>
		<slot name="open-graph-protocol" />
	</head>
	<body>
		<slot />
		<Dialog
			id={GlobalElementIds.popoverWarningNotice}
			style="width:512px"
			DialogHeaderAttr={{style: 'opacity:var(--g-opacity-inv2)'}}>
			<Fragment slot="header">
				<Icon IconCode={IconCodes.warning} style="font-size:32px"/>
				Browser Compatibility Notice
			</Fragment>
			<p>This web app heavily utilizes the <a style={`border-bottom:1px solid rgb(${AppCSSColors.accent})`} href="https://developer.mozilla.org/en-US/docs/Web/API/Popover_API">Popover API</a>, which may not be fully supported by your browser. Some features might not function as expected. Please consider using a modern browser for the best experience.</p>
			<form slot="footer" style="display:contents" method="dialog">
				<Button ButtonVariant={ButtonVariant.tonal}>Close</Button>
				<LinkButton LinkButtonNewTab autofocus LinkButtonVariant={ButtonVariant.filled} href="https://developer.mozilla.org/en-US/docs/Web/API/Popover_API#browser_compatibility">Check browser</LinkButton>
			</form>
		</Dialog>
		<script src="./_popover-api-check.ts" />
	</body>
</html>