---
import Icon from '@/native-components/Icon/index.astro'
import Tooltip from '@/native-components/Tooltip/index.astro'
import Drawer from '@/native-components/Drawer/index.astro'
import Divider from '@/native-components/Divider/index.astro'
import Button from '@/native-components/Button/index.astro'
import LinkDrawerButton from '@/native-components/Drawer/LinkDrawerButton.astro'
import LinkButton from '@/native-components/Button/LinkButton.astro'
import IconButton from '@/native-components/Button/IconButton.astro'
import { ButtonVariant } from '@/native-components/Button'
import UIMenus from './_ui/_UIMenus.astro'
import CSS from './_index.module.scss'

import { RoutesLinks, ExternalLinks } from '@/enums/links'
import { ICON_APPS, ICON_ARROW_RIGHT_UP, ICON_SETTINGS, ICON_GIFT, ICON_INFO, ICON_LINE_HORIZONTAL_3, ICON_HOME, ICON_SHIELD_CHECKMARK, ICON_RECEIPT, ICON_CALL } from '@/constants/icons'
import { ElementIds, ID } from './_scripts/_enums'

type Props = {
	route?: RoutesLinks
}

const { route } = Astro.props
---

<header class={CSS.header} id={ID + ElementIds.appbar}>
	<Tooltip>
		<IconButton
			class={CSS.mobile_only}
			data-tooltip="Navigation"
			aria-label="Open navigation"
			popovertarget={ID + ElementIds.drawer}
			IconButtonCode={ICON_LINE_HORIZONTAL_3}
		/>
	</Tooltip>
	<LinkButton
		href={RoutesLinks.home}
		style="padding-left:6px;font-size:var(--g-font-size-m)">
		<svg width=24 height="24" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
			<rect y="10" width="8" height="22" rx="2" fill="rgb(var(--g-color-accent))"/>
			<path d="M14.1504 19.4785C12.7754 18.4093 12.0879 17.8747 12.0142 17.4068C11.9505 17.0018 12.1036 16.5932 12.4224 16.3179C12.7906 16 13.6786 16 15.4544 16H29.9394C30.6607 16 31.0213 16 31.2968 16.1336C31.5391 16.251 31.7362 16.4385 31.8596 16.669C32 16.9311 32 17.2743 32 17.9605V29.2243C32 30.5454 32 31.2059 31.7161 31.5421C31.4693 31.8344 31.0954 32.0031 30.7013 32C30.2481 31.9963 29.7105 31.5783 28.6354 30.7423L14.1504 19.4785Z" fill="rgba(var(--g-color-accent),.64)"/>
			<rect x="22" width="8" height="22" rx="2" transform="rotate(90 22 0)" fill="rgba(var(--g-color-accent),.64)"/>
			<path d="M31.0477 3.02574C31.6985 2.0423 32.0239 1.55059 31.9986 1.14307C31.9766 0.788019 31.8005 0.460331 31.5166 0.246004C31.1908 0 30.6011 0 29.4219 0H11.9496C11.2672 0 10.926 0 10.6653 0.132816C10.436 0.249644 10.2496 0.43606 10.1328 0.665348C10 0.926014 10 1.26724 10 1.9497V28.3519C10 30.2994 10 31.2731 10.3413 31.6271C10.636 31.9329 11.0688 32.0632 11.4833 31.9709C11.9633 31.864 12.5007 31.052 13.5754 29.4279L31.0477 3.02574Z" fill="rgb(var(--g-color-accent))"/>
		</svg>
		Redmerah
	</LinkButton>
	<nav>
		<LinkButton
			class={CSS.desktop_only}
			LinkButtonVariant={route == RoutesLinks.apps? ButtonVariant.filled : undefined}
			href={RoutesLinks.apps}>
			<Icon
				IconCode={ICON_APPS}
				IconFilled={route == RoutesLinks.apps}
			/>
			Apps
		</LinkButton>
		<LinkButton
			class={CSS.desktop_only}
			LinkButtonVariant={route == RoutesLinks.about? ButtonVariant.filled : undefined}
			href={RoutesLinks.about}>
			<Icon
				IconCode={ICON_INFO}
				IconFilled={route == RoutesLinks.about}
			/>
			About
		</LinkButton>
		<LinkButton
			class={CSS.desktop_only}
			href={ExternalLinks.donate}
			LinkButtonVariant={ButtonVariant.tonal}
			LinkButtonNewTab>
			<Icon IconCode={ICON_GIFT}/>
			Donate
			<Icon IconCode={ICON_ARROW_RIGHT_UP} IconInline/>
		</LinkButton>
	</nav>
	<Tooltip>
		<IconButton
			data-tooltip="Settings"
			aria-label="Open settings"
			IconButtonCode={ICON_SETTINGS}
			id={ID + ElementIds.appbarSettingsButton}
			aria-haspopup="menu"
			aria-expanded="false"
			aria-controls={ID + ElementIds.appbarSettingsMenu}
		/>
	</Tooltip>
</header>
<Drawer id={ID + ElementIds.drawer}>
	<Tooltip slot="header">
		<Button
			popovertarget={ID + ElementIds.drawer}
			aria-label="Hide navigation"
			style="width:min-content"
			data-tooltip="Close"
			popovertargetaction="hide">
			<Icon IconCode={ICON_LINE_HORIZONTAL_3}/>
		</Button>
	</Tooltip>
	<LinkDrawerButton
		href={RoutesLinks.home}
		LinkDrawerButtonSelected={route === RoutesLinks.home}
		LinkButtonVariant={route === RoutesLinks.home? ButtonVariant.tonal : undefined}>
		<Icon IconCode={ICON_HOME}/>
		Home
	</LinkDrawerButton>
	<LinkDrawerButton
		href={RoutesLinks.apps}
		LinkDrawerButtonSelected={route === RoutesLinks.apps}
		LinkButtonVariant={route === RoutesLinks.apps? ButtonVariant.tonal : undefined}>
		<Icon IconCode={ICON_APPS}/>
		Apps
	</LinkDrawerButton>
	<LinkDrawerButton
		href={RoutesLinks.about}
		LinkDrawerButtonSelected={route === RoutesLinks.about}
		LinkButtonVariant={route === RoutesLinks.about? ButtonVariant.tonal : undefined}>
		<Icon IconCode={ICON_INFO}/>
		About
	</LinkDrawerButton>
	<LinkDrawerButton
		href={RoutesLinks.privacy}
		LinkDrawerButtonSelected={route === RoutesLinks.privacy}
		LinkButtonVariant={route === RoutesLinks.privacy? ButtonVariant.tonal : undefined}>
		<Icon IconCode={ICON_SHIELD_CHECKMARK}/>
		Privacy policy
	</LinkDrawerButton>
	<LinkDrawerButton
		href={RoutesLinks.terms}
		LinkDrawerButtonSelected={route === RoutesLinks.terms}
		LinkButtonVariant={route === RoutesLinks.terms? ButtonVariant.tonal : undefined}>
		<Icon IconCode={ICON_RECEIPT}/>
		Terms & conditions
	</LinkDrawerButton>
	<Fragment slot="footer">
		<Divider />
		<LinkDrawerButton
			href={'mailto:' + ExternalLinks.contactEmail}>
			<Icon IconCode={ICON_CALL}/>
			Contact
		</LinkDrawerButton>
		<LinkDrawerButton
			href={ExternalLinks.donate}
			LinkButtonNewTab>
			<Icon IconCode={ICON_GIFT}/>
			Donate
		</LinkDrawerButton>
	</Fragment>
</Drawer>
<UIMenus/>
<script src="./_scripts/_index.ts"/>