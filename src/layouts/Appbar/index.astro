---
import Icon from '@/components/Icon/index.astro';
import LinkButton from '@/components/Button/LinkButton.astro';
import { ButtonVariant } from '@/components/Button';
import { SettingsElement, NavigationMenu } from './_components'
import CSS from './_index.module.scss'

import { RoutesLinks, ExternalLinks } from '@/enums/links';
import logo from '@/assets/logo.svg'

type Props = {
	route?: RoutesLinks
}

const { route } = Astro.props
---

<header class={CSS.header} id="_appbar">
	<LinkButton variant={ButtonVariant.outlined} href={RoutesLinks.home}><img src={logo.src} alt="Redmerah logo" /> Redmerah</LinkButton>
	<nav>
		<LinkButton classList={[CSS.desktop_only]} selected={route == RoutesLinks.apps} href={RoutesLinks.apps}><Icon code={0xE063} filled/>Apps</LinkButton>
		<LinkButton classList={[CSS.desktop_only]} selected={route == RoutesLinks.about} href={RoutesLinks.about}><Icon code={0xE930}/>About</LinkButton>
		<LinkButton classList={[CSS.desktop_only]} href={ExternalLinks.donate} openInNewTab><Icon code={0xE84B}/>Donate</LinkButton>
	</nav>
	<div>
		<SettingsElement client:only="solid-js"/>
		<NavigationMenu client:only="solid-js" route={route}/>
	</div>
</header>

<script>
	import { _scrollY, _toggleAttribute, _scroll } from "@/constants/string"
	import { getWindow } from "@/constants/window"
	import { getElementById } from "@/utils/element"
	import { addEventListener } from "@/utils/event"

	const appbar = getElementById('_appbar')
	let isTop = getWindow()[_scrollY] == 0

	appbar?.[_toggleAttribute]('data-top', isTop)
	addEventListener(getWindow(), _scroll, () => {
		const $isTop = getWindow()[_scrollY] == 0

		if (isTop == $isTop) return;
		isTop = $isTop

		appbar?.[_toggleAttribute]('data-top', isTop)
	})
</script>