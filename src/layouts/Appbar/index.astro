---
import * as Ids from './_scripts/shared/ids.enum.js'
import * as InputNames from './_scripts/shared/input-names.enum.js'
import * as Constant from './_scripts/shared/constant.enum.js'
import * as BrTheme from '@/web-components/components/br-theme.server.js'
import * as Icons from '@/enums/icons.enum.js'
import * as Routes from '@/enums/routes.enum.js'
import * as ExternalLinks from '@/enums/external-links.enum.js'
import * as Styles from './_styles/styles.enum.js'
import type { EnumOf } from '@/types/collections'

type Props = {
	route?: EnumOf<typeof Routes>
}

const { route } = Astro.props

const ID_DRAWER = '59E07DF2'
const THEMES: [text: string, value: string, icon: string][] = [
	['System', BrTheme.ThemeMode.Auto , Icons.LaptopSettings],
	['Light' , BrTheme.ThemeMode.Light, Icons.WeatherSunny  ],
	['Dark'  , BrTheme.ThemeMode.Dark , Icons.WeatherMoon   ],
]
const ANIMATION: [text: string, value: string, icon: string][] = [
	['System', BrTheme.Animation.Auto, Icons.VideoClipOptimize],
	['On'    , BrTheme.Animation.On  , Icons.VideoClip        ],
	['Off'   , BrTheme.Animation.Off , Icons.VideoClipOff     ],
]
---
<header class={Styles.AppBar}>
	<div>
		<p>
			<br-if br:media="(width <= 33rem)">
				<button
					style="margin-right:2px"
					br:tooltip="Toggle navigation"
					br:variant="icon"
					br:command-for={ID_DRAWER}>
					<br-icon set:html={Icons.LineHorizontal3}/>
				</button>
			</br-if>
			<a
				br:as="button"
				href={Routes.Home}
				br:prevent-default>
				<svg style="width: 1.5rem;height: 1.5rem" viewBox="0 0 512 512" fill="none" xmlns="http://www.w3.org/2000/svg">
					<g clip-path="url(#clip0_864_188)">
						<path d="M256 320V240C256 222.327 241.673 208 224 208C206.327 208 192 222.327 192 240V464C192 478.91 192 486.365 189.564 492.246C186.316 500.087 180.087 506.316 172.246 509.564C166.365 512 158.91 512 144 512V512C129.09 512 121.635 512 115.754 509.564C107.913 506.316 101.684 500.087 98.4359 492.246C96 486.365 96 478.91 96 464V240C96 169.308 153.308 112 224 112C294.692 112 352 169.308 352 240V320C352 343.016 352.037 357.876 352.812 369.25C353.559 380.194 354.829 384.378 355.656 386.375C360.528 398.131 369.869 407.472 381.625 412.344C383.622 413.171 387.806 414.441 398.75 415.188C399.166 415.216 399.586 415.243 400.011 415.27C416.056 416.266 424.079 416.764 429.607 419.361C437.289 422.97 442.625 428.648 445.75 436.538C448 442.216 448 449.478 448 464V464C448 479.086 448 486.63 445.427 492.653C442.092 500.457 435.2 507.05 427.256 510.035C421.125 512.339 414.085 512.026 400.006 511.402C397.324 511.283 394.728 511.14 392.219 510.969C376.39 509.889 360.548 507.509 344.906 501.031C309.622 486.416 281.584 458.378 266.969 423.094C260.491 407.452 258.111 391.61 257.031 375.781C255.981 360.383 256 341.703 256 320Z" fill="url(#paint0_linear_864_188)"/>
						<rect x="32" y="32" width="448" height="288" rx="64" fill="#7A0000" stroke="#FF1414" stroke-width="64"/>
					</g>
					<defs>
						<linearGradient id="paint0_linear_864_188" x1="288" y1="288" x2="288" y2="512" gradientUnits="userSpaceOnUse">
							<stop stop-color="#A30000"/>
							<stop offset="1" stop-color="#FF1414"/>
						</linearGradient>
						<clipPath id="clip0_864_188">
							<rect width="512" height="512" fill="white"/>
						</clipPath>
					</defs>
				</svg>
				Redmerah
			</a>
		</p>
		<nav>
			<br-if br:media="(width > 33rem)">
				<a
					href={Routes.Apps}
					br:as="button"
					br:prevent-default
					br:variant={route === Routes.Apps? "filled" : undefined}>
					<br-icon set:html={route === Routes.Apps? Icons.AppsFilled : Icons.Apps}/>
					Apps
				</a>
				<a
					href={Routes.About}
					br:as="button"
					br:prevent-default
					br:variant={route === Routes.About? "filled" : undefined}>
					<br-icon set:html={route === Routes.About? Icons.InfoFilled : Icons.Info}/>
					About
				</a>
				<a
					br:as="button"
					br:prevent-default
					href={ExternalLinks.Donate}
					target="_blank"
					rel="noopener noreferrer">
					<br-icon set:html={Icons.Gift}/>
					Donate
				</a>
			</br-if>
			<button
				aria-label="Settings"
				br:variant="icon"
				br:tooltip="Settings"
				br:command-for={Ids.PopoverAppBarSettings}>
				<br-icon set:html={Icons.Settings}/>
			</button>
		</nav>
	</div>
</header>

<br-popover id={Ids.PopoverAppBarSettings}>
	<br-focusgroup br:direction="vertical">
		<menu>
			<li>
				<button br:prevent-default br:command-for={Ids.PopoverAppBarSettingsAnimation}>
					<br-icon set:html={Icons.PlayCircleHint}/>
					Animation
					<div style="flex:1"/>
					<br-icon set:html={Icons.ChevronRight}/>
				</button>
				<br-popover br:submenu id={Ids.PopoverAppBarSettingsAnimation}>
					<menu>
						{ANIMATION.map(v => <li><label br:as="button">
							<input
								checked={v[1] === Constant.DEFAULT_ANIMATION}
								value={v[1]}
								type="radio"
								name={InputNames.Animation}
							/>
							<br-icon set:html={v[2]}/>
							{v[0]}
						</label></li>)}
					</menu>
				</br-popover>
			</li>
			<li>
				<button br:prevent-default br:command-for={Ids.PopoverAppBarSettingsTheme}>
					<br-icon set:html={Icons.WeatherSunny}/>
					Theme
					<div style="flex:1"/>
					<br-icon set:html={Icons.ChevronRight}/>
				</button>
				<br-popover br:submenu id={Ids.PopoverAppBarSettingsTheme}>
					<menu>
						{THEMES.map(v => <li><label br:as="button">
							<input
								checked={v[1] === Constant.DEFAULT_THEME}
								value={v[1]}
								type="radio"
								name={InputNames.Theme}
							/>
							<br-icon set:html={v[2]}/>
							{v[0]}
						</label></li>)}
					</menu>
				</br-popover>
			</li>
		</menu>
	</br-focusgroup>
</br-popover>

<br-navigation br:variant="drawer" id={ID_DRAWER}>
	<br-focusgroup br:direction="vertical">
		<button
			br:tooltip="Toggle navigation"
			br:command-for={ID_DRAWER}>
			<br-icon set:html={Icons.LineHorizontal3}/>
		</button>
		<a
			href={Routes.Home}
			br:as="navigationitem"
			br:prevent-default
			br:path={Routes.Home}>
			<br-icon set:html={route === Routes.Home? Icons.HomeFilled : Icons.Home}/>
			Home
		</a>
		<a
			href={Routes.Apps}
			br:as="navigationitem"
			br:prevent-default
			br:path={Routes.Apps}>
			<br-icon set:html={route === Routes.Apps? Icons.AppsFilled : Icons.Apps}/>
			Apps
		</a>
		<a
			href={Routes.About}
			br:as="navigationitem"
			br:prevent-default
			br:path={Routes.About}>
			<br-icon set:html={route === Routes.About? Icons.InfoFilled : Icons.Info}/>
			About
		</a>
		<a
			br:as="navigationitem"
			br:prevent-default
			href={ExternalLinks.Donate}
			target="_blank"
			rel="noopener noreferrer">
			<br-icon set:html={Icons.Gift}/>
			Donate
		</a>
		<a
			br:as="navigationitem"
			br:prevent-default
			href={ExternalLinks.Github}
			target="_blank"
			rel="noopener noreferrer">
			<br-icon set:html={Icons.Code}/>
			Github
		</a>
		<a
			br:as="navigationitem"
			br:prevent-default
			href={'mailto:' + ExternalLinks.ContactEmail}>
			<br-icon set:html={Icons.Chat}/>
			Contact
		</a>
	</br-focusgroup>
</br-navigation>

<script src="@/web-components/components/br-focusgroup.ts"/>
<script src="@/web-components/components/br-popover.ts"/>
<script src="@/web-components/components/br-navigation.ts"/>
<script src="@/web-components/components/br-if.ts"/>
<script src="@/web-components/components/br-icon.ts"/>
<script src="@/web-components/components/menu.ts"/>
<script src="@/web-components/components/navigationitem.ts"/>
<script src="@/web-components/components/button.ts"/>
<script src="./_scripts/index.ts"/>