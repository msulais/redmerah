---
import { ElementIds, ID, RadioGroupNames } from '../_scripts/_enums'
import ColorPicker from '@/native-components/ColorPicker/index.astro'
import { MenuPosition } from '@/native-components/Menu'
import Menu from '@/native-components/Menu/index.astro'
import SubMenu from '@/native-components/Menu/SubMenu.astro'
import SubMenuItem from '@/native-components/Menu/SubMenuItem.astro'
import RadioMenuItem from '@/native-components/Menu/RadioMenuItem.astro'
import MenuIndent from '@/native-components/Menu/MenuIndent.astro'
import MenuItem from '@/native-components/Menu/MenuItem.astro'
import Icon from '@/native-components/Icon/index.astro'
import { PlatformAnimationMode, PlatformThemeMode } from '@/enums/platforms'
import { AppCSSColors } from '@/enums/app-data'
import { IconCodes } from '@/enums/icons'
---

<Menu id={ID + ElementIds.appbarSettingsMenu} PopoverAnchorBy={ID + ElementIds.appbarSettingsButton}>
	<MenuItem
		id={ID + ElementIds.appbarSettingsAccentButton}
		popovertarget={ID + ElementIds.appbarColorPicker}>
		<Icon style={`color: rgb(${AppCSSColors.accent})`} IconCode={IconCodes.circle} IconFilled/>
		Color accent
		<div style="flex:1"/>
		<MenuIndent/>
	</MenuItem>
	<SubMenuItem
		popovertarget={ID + ElementIds.appbarSettingsAnimationMenu}>
		<Icon IconCode={IconCodes.playCircleHint}/>
		Animation
		<div style="flex:1"/>
		<Icon IconCode={IconCodes.chevronRight}/>
	</SubMenuItem>
	<SubMenu slot="submenus" id={ID + ElementIds.appbarSettingsAnimationMenu}>
		<RadioMenuItem
			RadioMenuItemInputAttr={{
				name: RadioGroupNames.settingsAnimation,
				checked: true,
				value: PlatformAnimationMode.auto
			}}>
			<Icon IconCode={IconCodes.videoClipOptimize}/>
			Automatic
		</RadioMenuItem>
		<RadioMenuItem
			RadioMenuItemInputAttr={{
				name: RadioGroupNames.settingsAnimation,
				value: PlatformAnimationMode.on
			}}>
			<Icon IconCode={IconCodes.videoClip}/>
			On
		</RadioMenuItem>
		<RadioMenuItem
			RadioMenuItemInputAttr={{
				name: RadioGroupNames.settingsAnimation,
				value: PlatformAnimationMode.off
			}}>
			<Icon IconCode={IconCodes.videoClipOff}/>
			Off
		</RadioMenuItem>
	</SubMenu>

	<SubMenuItem
		popovertarget={ID + ElementIds.appbarSettingsThemeMenu}>
		<Icon IconCode={IconCodes.weatherSunny}/>
		Theme
		<div style="flex:1"/>
		<Icon IconCode={IconCodes.chevronRight}/>
	</SubMenuItem>
	<SubMenu slot="submenus" id={ID + ElementIds.appbarSettingsThemeMenu}>
		<RadioMenuItem
			RadioMenuItemInputAttr={{
				name: RadioGroupNames.settingsTheme,
				checked: true,
				value: PlatformThemeMode.auto
			}}>
			<Icon IconCode={IconCodes.laptopSettings}/>
			Automatic
		</RadioMenuItem>
		<RadioMenuItem
			RadioMenuItemInputAttr={{
				name: RadioGroupNames.settingsTheme,
				value: PlatformThemeMode.light
			}}>
			<Icon IconCode={IconCodes.weatherSunny}/>
			Light
		</RadioMenuItem>
		<RadioMenuItem
			RadioMenuItemInputAttr={{
				name: RadioGroupNames.settingsTheme,
				value: PlatformThemeMode.dark
			}}>
			<Icon IconCode={IconCodes.weatherMoon}/>
			Dark
		</RadioMenuItem>
	</SubMenu>
</Menu>
<ColorPicker
	PopoverDraggable
	ColorPickerValue='#0093FF'
	ColorPickerDisabledOpacity
	ColorPickerHueOnly
	PopoverPosition={MenuPosition.centerCenterRightTop}
	PopoverAnchorBy={ID + ElementIds.appbarSettingsButton}
	id={ID + ElementIds.appbarColorPicker}
	aria-labelledby={ID + ElementIds.appbarSettingsAccentButton}
/>