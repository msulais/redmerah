---
import UICompass from './_UICompass.astro'
import { CSSClasses } from '../_styles/_css'
import Dialog from '@/components/Dialog/index.astro'
import Button from '@/components/Button/index.astro'
import { ButtonVariant } from '@/components/Button/'
import { ElementIds } from '../_scripts/_shared/_ids'
import { pxToRem } from '@/utils/css'
---

<main class={CSSClasses.body}>
	<UICompass/>
</main>

<Dialog id={ElementIds.dlg_notSupport} style={`width:${pxToRem(500)}rem`}>
	<Fragment slot="header">Compass Not Available</Fragment>
	<p>This compass app requires a device with a built-in magnetometer (compass sensor) to function. It appears your device, or browser, does not support this feature. Please try again on a mobile device.</p>
	<form method="dialog" slot="footer" style="display:contents">
		<div></div>
		<Button ButtonVariant={ButtonVariant.filled}>Close</Button>
	</form>
</Dialog>