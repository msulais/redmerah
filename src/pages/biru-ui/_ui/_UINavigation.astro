---
import SideBar from '@/native-components/SideBar/index.astro'
import SideBarButton from '@/native-components/SideBar/SideBarButton.astro'
import { ButtonVariant } from '@/native-components/Button'
import { ELEMENT_ID_PREFIX, ElementIds } from '../_scripts/_enums'

const items: {
	name: string
	selected: boolean
	controls: string
}[] = [
	{
		name: 'Buttons',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelButtons,
		selected: false,
	},
	{
		name: 'CheckBox',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelCheckbox,
		selected: false
	},
	{
		name: 'TextField',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelTextfield,
		selected: false
	},
	{
		name: 'ColorPicker',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelColorpicker,
		selected: false
	},
	{
		name: 'Icon',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelIcon,
		selected: false
	},
	{
		name: 'List',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelList,
		selected: false
	},
	{
		name: 'Popover',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelPopover,
		selected: false
	},
	{
		name: 'Modal',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelModal,
		selected: false
	},
	{
		name: 'Select',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelSelect,
		selected: true
	},
].sort((a, b) => a.name.localeCompare(b.name))
---

<SideBar
	role="tablist"
	id={ELEMENT_ID_PREFIX + ElementIds.navigation}
	aria-label="Navigation">
	{items.map(v => <SideBarButton
		role="tab"
		aria-selected={v.selected}
		aria-controls={v.controls}
		SideBarButtonSelected={v.selected}
		ButtonVariant={v.selected ? ButtonVariant.tonal : undefined}>
		{v.name}
	</SideBarButton>)}
</SideBar>