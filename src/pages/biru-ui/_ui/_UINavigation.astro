---
import SideBar from '@/native-components/SideBar/index.astro'
import Drawer from '@/native-components/Drawer/index.astro'
import Button from '@/native-components/Button/index.astro'
import Icon from '@/native-components/Icon/index.astro'
import DrawerButton from '@/native-components/Drawer/DrawerButton.astro'
import SideBarButton from '@/native-components/SideBar/SideBarButton.astro'
import { ButtonVariant } from '@/native-components/Button'
import { ELEMENT_ID_PREFIX, ElementIds } from '../_scripts/_enums'
import { ICON_LINE_HORIZONTAL_3 } from '@/constants/icons'
import CSS from '../_index.module.scss'

const items: {
	name: string
	selected: boolean
	controls: string
}[] = [
	{
		name: 'Buttons',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelButtons,
		selected: false,
	},
	{
		name: 'CheckBox',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelCheckbox,
		selected: false
	},
	{
		name: 'TextField',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelTextfield,
		selected: false
	},
	{
		name: 'ColorPicker',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelColorpicker,
		selected: false
	},
	{
		name: 'Icon',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelIcon,
		selected: false
	},
	{
		name: 'List',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelList,
		selected: false
	},
	{
		name: 'Popover',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelPopover,
		selected: false
	},
	{
		name: 'Modal',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelModal,
		selected: false
	},
	{
		name: 'Select',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelSelect,
		selected: false
	},
	{
		name: 'Tooltip',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelTooltip,
		selected: false
	},
	{
		name: 'Menu',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelMenu,
		selected: false
	},
	{
		name: 'EmojiPicker',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelEmojipicker,
		selected: false
	},
	{
		name: 'Drawer',
		controls: ELEMENT_ID_PREFIX + ElementIds.panelDrawer,
		selected: true
	},
].sort((a, b) => a.name.localeCompare(b.name))
---

<SideBar
	class={CSS.sidebar}
	role="tablist"
	id={ELEMENT_ID_PREFIX + ElementIds.navigationSideBar}
	aria-label="Navigation">
	{items.map(v => <SideBarButton
		role="tab"
		aria-selected={v.selected}
		aria-controls={v.controls}
		SideBarButtonSelected={v.selected}
		ButtonVariant={v.selected ? ButtonVariant.tonal : undefined}>
		{v.name}
	</SideBarButton>)}
</SideBar>
<Drawer
	id={ELEMENT_ID_PREFIX + ElementIds.navigationDrawer}
	aria-label="Navigation">
	<Button
		slot="header"
		style="width:min-content"
		popovertarget={ELEMENT_ID_PREFIX + ElementIds.navigationDrawer}
		popovertargetaction="hide">
		<Icon IconCode={ICON_LINE_HORIZONTAL_3}/>
	</Button>
	{items.map(v => <DrawerButton
		aria-selected={v.selected}
		aria-controls={v.controls}
		DrawerButtonSelected={v.selected}
		ButtonVariant={v.selected ? ButtonVariant.tonal : undefined}>
		{v.name}
	</DrawerButton>)}
</Drawer>