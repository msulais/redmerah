---
import SideNavigation from '@/native-components/SideNavigation/index.astro'
import SideNavigationButton from '@/native-components/SideNavigation/SideNavigationButton.astro'
import { ButtonVariant } from '@/native-components/Button'
---

<SideNavigation>
	<SideNavigationButton c:selected c:variant={ButtonVariant.tonal}>Buttons</SideNavigationButton>
	{[
		'CheckBox', 'ColorPicker', 'DatePicker', 'DateTimePicker',
		'Dialog', 'Divider', 'Drawer', 'Dropdown', 'EmojiPicker',
		'Expander', 'Icon', 'List', 'Menu', 'Modal', 'Popover',
		'Switch', 'TextField', 'Toast', 'Tooltip'
	].map(v => <SideNavigationButton>{v}</SideNavigationButton>)}
</SideNavigation>