---
import CheckBox from '@/native-components/CheckBox/index.astro'
import TextField from '@/native-components/TextField/index.astro'
import Modal from '@/native-components/Modal/index.astro'
import Button from '@/native-components/Button/index.astro'
import Select from '@/native-components/Select/index.astro'
import SelectOption from '@/native-components/Select/SelectOption.astro'
import { ElementIds, ELEMENT_ID_PREFIX } from '../../_scripts/_enums'
import CSS from '../../_index.module.scss'
import { ButtonVariant } from '@/native-components/Button'
import { FlyoutPosition } from '@/enums/position'
---
<div
	class={CSS.bodyPage}
	role="tabpanel"
	id={ELEMENT_ID_PREFIX + ElementIds.panelModal}
	hidden>
	<h2>Modal</h2>
	<p>A modal is an overlay window that appears on top of the main content, blocking user interaction with the underlying elements until it is dismissed. Modals are often used for critical tasks or to present important information.</p>
	<div class={CSS.bodyPlayground}>
		<Button
			ButtonVariant={ButtonVariant.tonal}
			id={ELEMENT_ID_PREFIX + ElementIds.panelModalPreviewButtonOpen}
			aria-controls={ELEMENT_ID_PREFIX + ElementIds.panelModalPreviewModal}
			aria-haspopup="true">
			Open popover
		</Button>
		<Modal
			aria-label="Modal"
			id={ELEMENT_ID_PREFIX + ElementIds.panelModalPreviewModal}
			ModalAnchorBy={ELEMENT_ID_PREFIX + ElementIds.panelModalPreviewButtonOpen}
			ModalContentAttr={{
				style: "padding: 16px;width: 280px"
			}}
			ModalPadding={16}
			ModalGap={8}>
			<TextField
				TextFieldInputAttr={{
					placeholder: 'Feedback',
					style: 'width: 100%'
				}}
			/>
			<p style="padding:8px 0 16px 0">Consequat commodo sint incididunt nulla duis commodo elit enim aliquip ex occaecat eiusmod.</p>
			<Button
				id={ELEMENT_ID_PREFIX + ElementIds.panelModalPreviewButtonClose}
				aria-controls={ELEMENT_ID_PREFIX + ElementIds.panelModalPreviewModal}
				ButtonVariant={ButtonVariant.filled}>
				Close popover
			</Button>
		</Modal>
	</div>
	<div class={CSS.bodyOptions} id={ELEMENT_ID_PREFIX + ElementIds.panelModalOptions}>
		<div class={CSS.bodyOptionsGroup}>
			<label id={ELEMENT_ID_PREFIX + ElementIds.panelModalOptionsPositionLabel}>Position:</label>
			<Select
				aria-labelledby={ELEMENT_ID_PREFIX + ElementIds.panelModalOptionsPositionLabel}
				id={ELEMENT_ID_PREFIX + ElementIds.panelModalOptionsPosition}
				style="margin-right:12px">
				{[
					[FlyoutPosition.centerBottom, 'Center bottom'],
					[FlyoutPosition.centerBottomToLeft, 'Center bottom to left'],
					[FlyoutPosition.centerBottomToRight, 'Center bottom to right'],
					[FlyoutPosition.centerCenter, 'Center center'],
					[FlyoutPosition.centerCenterBottom, 'Center center bottom'],
					[FlyoutPosition.centerCenterLeft, 'Center center left'],
					[FlyoutPosition.centerCenterLeftBottom, 'Center center left bottom'],
					[FlyoutPosition.centerCenterLeftTop, 'Center center left top'],
					[FlyoutPosition.centerCenterRight, 'Center center right'],
					[FlyoutPosition.centerCenterRightBottom, 'Center center right bottom'],
					[FlyoutPosition.centerCenterRightTop, 'Center center right top'],
					[FlyoutPosition.centerCenterTop, 'Center center top'],
					[FlyoutPosition.centerTop, 'Center top'],
					[FlyoutPosition.centerTopToLeft, 'Center top to left'],
					[FlyoutPosition.centerTopToRight, 'Center top to right'],
					[FlyoutPosition.leftBottom, 'Left bottom'],
					[FlyoutPosition.leftCenter, 'Left center'],
					[FlyoutPosition.leftCenterToBottom, 'Left center to bottom'],
					[FlyoutPosition.leftCenterToTop, 'Left center to top'],
					[FlyoutPosition.leftTop, 'Left top'],
					[FlyoutPosition.rightBottom, 'Right bottom'],
					[FlyoutPosition.rightCenter, 'Right center'],
					[FlyoutPosition.rightCenterToBottom, 'Right center to bottom'],
					[FlyoutPosition.rightCenterToTop, 'Right center to top'],
					[FlyoutPosition.rightTop, 'Right top'],
				].map(v =>
					<SelectOption value={v[0]} SelectOptionSelected={v[0] === FlyoutPosition.centerBottom}>{v[1]}</SelectOption>
				)}
			</Select>
		</div>
		<div class={CSS.bodyOptionsGroup} style="margin-right:12px">
			<label
				for={ELEMENT_ID_PREFIX + ElementIds.panelModalOptionsPadding}>
				Padding:
			</label>
			<TextField
				TextFieldInputAttr={{
					value: '16',
					type: 'number',
					min: 0,
					style: 'width:100px',
					id: ELEMENT_ID_PREFIX + ElementIds.panelModalOptionsPadding
				}}
			/>
		</div>
		<div class={CSS.bodyOptionsGroup} style="margin-right:12px">
			<label
				for={ELEMENT_ID_PREFIX + ElementIds.panelModalOptionsGap}>
				Gap:
			</label>
			<TextField
				TextFieldInputAttr={{
					value: '8',
					type: 'number',
					min: 0,
					style: 'width:100px;',
					id: ELEMENT_ID_PREFIX + ElementIds.panelModalOptionsGap
				}}
			/>
		</div>
		<CheckBox
			CheckBoxInputAttr={{
				id: ELEMENT_ID_PREFIX + ElementIds.panelModalOptionsAnchor,
				checked: true
			}}>
			Anchor
		</CheckBox>
		<CheckBox
			CheckBoxInputAttr={{
				id: ELEMENT_ID_PREFIX + ElementIds.panelModalOptionsAutofocus,
				checked: true
			}}>
			Autofocus
		</CheckBox>
		<CheckBox
			CheckBoxInputAttr={{
				id: ELEMENT_ID_PREFIX + ElementIds.panelModalOptionsImportant,
			}}>
			Important
		</CheckBox>
		<CheckBox
			CheckBoxInputAttr={{
				id: ELEMENT_ID_PREFIX + ElementIds.panelModalOptionsDraggable,
			}}>
			Draggable
		</CheckBox>
	</div>
</div>