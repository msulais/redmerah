---
import icon from '@/assets/images/apps/biru-ui.svg'

import Html from '@/layouts/Html/index.astro'
import Splash from '@/layouts/Splash/index.astro'
import App from './_App'

export const prerender = true
---

<Html
	title='BiruUI | Redmerah'
	accent_color='#0093FF'
	description='We test our UI here'>
	<Fragment slot="favicon">
		<link rel="shortcut icon" type="image/ico" href="/favicon/biru-ui/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/favicon/biru-ui/apple-touch-icon.png">
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon/biru-ui/favicon-32x32.png">
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon/biru-ui/favicon-16x16.png">
		<link rel="manifest" href="/favicon/biru-ui/site.webmanifest">
	</Fragment>
	<script is:inline src='/scripts/root-settings.min.js'/>
	<Splash src={icon.src} alt="Biru UI icon splash"/>
	<App client:only="solid-js"/>
</Html>
