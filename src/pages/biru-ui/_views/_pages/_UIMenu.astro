---
import CheckBox from '@/components/CheckBox/index.astro'
import TextField from '@/components/TextField/index.astro'
import Menu from '@/components/Menu/index.astro'
import SubMenu from '@/components/Menu/SubMenu.astro'
import Icon from '@/components/Icon/index.astro'
import MenuItem from '@/components/Menu/MenuItem.astro'
import MenuHeader from '@/components/Menu/MenuHeader.astro'
import SubMenuItem from '@/components/Menu/SubMenuItem.astro'
import RadioMenuItem from '@/components/Menu/RadioMenuItem.astro'
import CheckMenuItem from '@/components/Menu/CheckMenuItem.astro'
import MenuIndent from '@/components/Menu/MenuIndent.astro'
import Divider from '@/components/Divider/index.astro'
import Button from '@/components/Button/index.astro'
import ComboBox from '@/components/ComboBox/index.astro'
import ComboBoxOption from '@/components/ComboBox/ComboBoxOption.astro'
import { ElementIds, RadioGroupNames } from '../../_scripts/_enums'
import CSS from '../../_index.module.scss'
import { ButtonVariant } from '@/components/Button'
import { FlyoutPosition } from '@/enums/position'
import { MenuPosition } from '@/components/Menu'
import { IconCodes } from '@/enums/icons'
---
<div
	class={CSS.bodyPage}
	role="tabpanel"
	id={ElementIds.panelMenu}
	hidden>
	<h2>Menu</h2>
	<p>A menu is a collection of options or commands that are presented to the user. It can be a simple list of items, a hierarchical structure, or a combination of both. Menus are commonly used for navigation, actions, or settings.</p>
	<div class={CSS.bodyPlayground}>
		<Button
			ButtonVariant={ButtonVariant.tonal}
			id={ElementIds.panelMenuPreviewButton}
			aria-controls={ElementIds.panelMenuPreviewMenu}
			aria-haspopup="menu"
			popovertarget={ElementIds.panelMenuPreviewMenu}>
			Open menu
		</Button>
		<Menu
			PopoverPosition={MenuPosition.centerBottomToRight}
			PopoverAnchorBy={ElementIds.panelMenuPreviewButton}
			id={ElementIds.panelMenuPreviewMenu}>
			<MenuHeader>Actions</MenuHeader>
			<MenuItem>
				<Icon IconCode={IconCodes.copy}/>
				Copy
				<div style="flex:1"/>
				<MenuIndent/>
			</MenuItem>
			<MenuItem>
				<Icon IconCode={IconCodes.clipboardPaste}/>
				Paste
				<div style="flex:1"/>
				<MenuIndent/>
			</MenuItem>
			<MenuItem>
				<Icon IconCode={IconCodes.cut}/>
				Cut
				<div style="flex:1"/>
				<MenuIndent/>
			</MenuItem>
			<Divider/>
			<CheckMenuItem CheckMenuItemChecked>Auto correct<MenuIndent/></CheckMenuItem>
			<CheckMenuItem>Show error<MenuIndent/></CheckMenuItem>
			<Divider/>
			<MenuHeader>Font family</MenuHeader>
			<RadioMenuItem
				RadioMenuItemInputAttr={{name: RadioGroupNames.panelMenuPreview, checked: true}}>
				Sans serif
				<div style="flex:1"/>
				<MenuIndent/>
			</RadioMenuItem>
			<RadioMenuItem
				RadioMenuItemInputAttr={{name: RadioGroupNames.panelMenuPreview}}>
				Monospace
				<div style="flex:1"/>
				<MenuIndent/>
			</RadioMenuItem>
			<RadioMenuItem
				RadioMenuItemInputAttr={{name: RadioGroupNames.panelMenuPreview}}>
				Serif
				<div style="flex:1"/>
				<MenuIndent/>
			</RadioMenuItem>
			<Divider/>
			<MenuHeader>Sub menus</MenuHeader>
			<SubMenuItem popovertarget={ElementIds.panelMenuPreviewMenu2}>
				<MenuIndent/>
				Level 1
				<div style="flex:1"/>
				<Icon IconCode={IconCodes.chevronRight}/>
			</SubMenuItem>
			<SubMenu id={ElementIds.panelMenuPreviewMenu2}>
				<MenuItem>
					<Icon IconCode={IconCodes.copy}/>
					Copy
					<div style="flex:1"/>
					<MenuIndent/>
				</MenuItem>
				<MenuItem>
					<Icon IconCode={IconCodes.clipboardPaste}/>
					Paste
					<div style="flex:1"/>
					<MenuIndent/>
				</MenuItem>
				<MenuItem>
					<Icon IconCode={IconCodes.cut}/>
					Cut
					<div style="flex:1"/>
					<MenuIndent/>
				</MenuItem>
			</SubMenu>

			<SubMenuItem popovertarget={ElementIds.panelMenuPreviewMenu3}>
				<MenuIndent/>
				Level 2
				<div style="flex:1"/>
				<Icon IconCode={IconCodes.chevronRight}/>
			</SubMenuItem>
			<SubMenu id={ElementIds.panelMenuPreviewMenu3}>
				<MenuItem>
					<Icon IconCode={IconCodes.copy}/>
					Copy
					<div style="flex:1"/>
					<MenuIndent/>
				</MenuItem>
				<MenuItem>
					<Icon IconCode={IconCodes.clipboardPaste}/>
					Paste
					<div style="flex:1"/>
					<MenuIndent/>
				</MenuItem>
				<MenuItem>
					<Icon IconCode={IconCodes.cut}/>
					Cut
					<div style="flex:1"/>
					<MenuIndent/>
				</MenuItem>
				<Divider />
				<SubMenuItem popovertarget={ElementIds.panelMenuPreviewMenu5}>
					<MenuIndent/>
					Next level
					<div style="flex:1"/>
					<Icon IconCode={IconCodes.chevronRight}/>
				</SubMenuItem>
				<SubMenu id={ElementIds.panelMenuPreviewMenu5}>
					<MenuItem>
						<Icon IconCode={IconCodes.copy}/>
						Copy
						<div style="flex:1"/>
						<MenuIndent/>
					</MenuItem>
					<MenuItem>
						<Icon IconCode={IconCodes.clipboardPaste}/>
						Paste
						<div style="flex:1"/>
						<MenuIndent/>
					</MenuItem>
					<MenuItem>
						<Icon IconCode={IconCodes.cut}/>
						Cut
						<div style="flex:1"/>
						<MenuIndent/>
					</MenuItem>
				</SubMenu>
			</SubMenu>

			<SubMenuItem popovertarget={ElementIds.panelMenuPreviewMenu4}>
				<MenuIndent/>
				Level 3
				<div style="flex:1"/>
				<Icon IconCode={IconCodes.chevronRight}/>
			</SubMenuItem>
			<SubMenu id={ElementIds.panelMenuPreviewMenu4}>
				<MenuItem>
					<Icon IconCode={IconCodes.copy}/>
					Copy
					<div style="flex:1"/>
					<MenuIndent/>
				</MenuItem>
				<MenuItem>
					<Icon IconCode={IconCodes.clipboardPaste}/>
					Paste
					<div style="flex:1"/>
					<MenuIndent/>
				</MenuItem>
				<MenuItem>
					<Icon IconCode={IconCodes.cut}/>
					Cut
					<div style="flex:1"/>
					<MenuIndent/>
				</MenuItem>
				<Divider />
				<SubMenuItem popovertarget={ElementIds.panelMenuPreviewMenu6}>
					<MenuIndent/>
					Next level
					<div style="flex:1"/>
					<Icon IconCode={IconCodes.chevronRight}/>
				</SubMenuItem>
				<SubMenu id={ElementIds.panelMenuPreviewMenu6}>
					<MenuItem>
						<Icon IconCode={IconCodes.copy}/>
						Copy
						<div style="flex:1"/>
						<MenuIndent/>
					</MenuItem>
					<MenuItem>
						<Icon IconCode={IconCodes.clipboardPaste}/>
						Paste
						<div style="flex:1"/>
						<MenuIndent/>
					</MenuItem>
					<MenuItem>
						<Icon IconCode={IconCodes.cut}/>
						Cut
						<div style="flex:1"/>
						<MenuIndent/>
					</MenuItem>
					<Divider />
					<SubMenuItem popovertarget={ElementIds.panelMenuPreviewMenu7}>
						<MenuIndent/>
						Next level
						<div style="flex:1"/>
						<Icon IconCode={IconCodes.chevronRight}/>
					</SubMenuItem>
					<SubMenu id={ElementIds.panelMenuPreviewMenu7}>
						<MenuItem>
							<Icon IconCode={IconCodes.copy}/>
							Copy
							<div style="flex:1"/>
							<MenuIndent/>
						</MenuItem>
						<MenuItem>
							<Icon IconCode={IconCodes.clipboardPaste}/>
							Paste
							<div style="flex:1"/>
							<MenuIndent/>
						</MenuItem>
						<MenuItem>
							<Icon IconCode={IconCodes.cut}/>
							Cut
							<div style="flex:1"/>
							<MenuIndent/>
						</MenuItem>
					</SubMenu>
				</SubMenu>
			</SubMenu>
		</Menu>
	</div>
	<div class={CSS.bodyOptions} id={ElementIds.panelMenuOptions}>
		<div class={CSS.bodyOptionsGroup} style="margin-right:12px">
			<label for={ElementIds.panelMenuOptionsPosition}>Position:</label>
			<ComboBox
				id={ElementIds.panelMenuOptionsPosition}>
				{[
					[FlyoutPosition.centerBottom, 'Center bottom'],
					[FlyoutPosition.centerBottomToLeft, 'Center bottom to left'],
					[FlyoutPosition.centerBottomToRight, 'Center bottom to right'],
					[FlyoutPosition.centerCenter, 'Center center'],
					[FlyoutPosition.centerCenterBottom, 'Center center bottom'],
					[FlyoutPosition.centerCenterLeft, 'Center center left'],
					[FlyoutPosition.centerCenterLeftBottom, 'Center center left bottom'],
					[FlyoutPosition.centerCenterLeftTop, 'Center center left top'],
					[FlyoutPosition.centerCenterRight, 'Center center right'],
					[FlyoutPosition.centerCenterRightBottom, 'Center center right bottom'],
					[FlyoutPosition.centerCenterRightTop, 'Center center right top'],
					[FlyoutPosition.centerCenterTop, 'Center center top'],
					[FlyoutPosition.centerTop, 'Center top'],
					[FlyoutPosition.centerTopToLeft, 'Center top to left'],
					[FlyoutPosition.centerTopToRight, 'Center top to right'],
					[FlyoutPosition.leftBottom, 'Left bottom'],
					[FlyoutPosition.leftCenter, 'Left center'],
					[FlyoutPosition.leftCenterToBottom, 'Left center to bottom'],
					[FlyoutPosition.leftCenterToTop, 'Left center to top'],
					[FlyoutPosition.leftTop, 'Left top'],
					[FlyoutPosition.rightBottom, 'Right bottom'],
					[FlyoutPosition.rightCenter, 'Right center'],
					[FlyoutPosition.rightCenterToBottom, 'Right center to bottom'],
					[FlyoutPosition.rightCenterToTop, 'Right center to top'],
					[FlyoutPosition.rightTop, 'Right top'],
				].map(v =>
					<ComboBoxOption value={v[0]} selected={v[0] === FlyoutPosition.centerBottomToRight}>{v[1]}</ComboBoxOption>
				)}
			</ComboBox>
		</div>
		<div class={CSS.bodyOptionsGroup} style="margin-right:12px">
			<label
				for={ElementIds.panelMenuOptionsGap}>
				Gap:
			</label>
			<TextField
				TextFieldInputAttr={{
					value: '8',
					type: 'number',
					min: 0,
					style: 'width:100px',
					id: ElementIds.panelMenuOptionsGap
				}}
			/>
		</div>
		<CheckBox
			CheckBoxInputAttr={{
				id: ElementIds.panelMenuOptionsAnchor,
				checked: true
			}}>
			Anchor
		</CheckBox>
	</div>
</div>