---
import Appbar from '@/components/AppBar/index.astro'
import logo from '@/assets/images/apps/biru-ui.svg'
import IconButton from '@/components/Button/IconButton.astro'
import Tooltip from '@/components/Tooltip/index.astro'
import { ElementIds } from '../_scripts/_enums'
import CSS from '../_index.module.scss'
import { IconCodes } from '@/enums/icons'
---

<Appbar id={ElementIds.appbar}>
	<Fragment slot='leading'>
		<IconButton
			class={CSS.appbarDrawer}
			IconButtonCode={IconCodes.lineHorizontal3}
			popovertarget={ElementIds.navigationDrawer}
		/>
		<img class={CSS.appbarLogo} src={logo.src} width="32" alt="BiruUI logo"/>
	</Fragment>
	<Fragment slot='headline'>BiruUI</Fragment>
	<Fragment slot='trailing'>
		<Tooltip>
			<IconButton
				id={ElementIds.appbarInfoButton}
				data-tooltip="Info"
				style="padding:0 10px"
				IconButtonCode={IconCodes.info}
				aria-label="Info"
				popovertarget={ElementIds.appbarInfoMenu}
			/>
			<IconButton
				id={ElementIds.appbarSettingsButton}
				data-tooltip="Settings"
				style="padding:0 10px"
				IconButtonCode={IconCodes.settings}
				aria-label="Settings"
				popovertarget={ElementIds.appbarSettingsMenu}
			/>
		</Tooltip>
	</Fragment>
</Appbar>