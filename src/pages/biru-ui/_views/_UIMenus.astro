---
import { ElementIds, RadioGroupNames } from '../_scripts/_enums'
import { ExternalLinks, RoutesLinks } from '@/enums/links'
import ColorPicker from '@/components/ColorPicker/index.astro'
import Menu from '@/components/Menu/index.astro'
import SubMenu from '@/components/Menu/SubMenu.astro'
import SubMenuItem from '@/components/Menu/SubMenuItem.astro'
import RadioMenuItem from '@/components/Menu/RadioMenuItem.astro'
import LinkMenuItem from '@/components/Menu/LinkMenuItem.astro'
import MenuIndent from '@/components/Menu/MenuIndent.astro'
import MenuItem from '@/components/Menu/MenuItem.astro'
import Divider from '@/components/Divider/index.astro'
import Icon from '@/components/Icon/index.astro'
import logoRedmerah from '@/assets/images/logos/redmerah-logo.svg'
import { PlatformAnimationMode, PlatformThemeMode } from '@/enums/platforms'
import { AppCSSColors } from '@/enums/app-data'
import { PopoverPosition } from '@/components/Popover'
import { IconCodes } from '@/enums/icons'
---

<Menu id={ElementIds.appbarSettingsMenu} PopoverAnchorBy={ElementIds.appbarSettingsButton}>
	<MenuItem
		id={ElementIds.appbarSettingsAccentButton}
		aria-controls={ElementIds.appbarColorPicker}>
		<Icon style={`color: rgb(${AppCSSColors.accent})`} IconCode={IconCodes.circle} IconFilled/>
		Color accent
		<div style="flex:1"/>
		<MenuIndent/>
	</MenuItem>
	<SubMenuItem
		popovertarget={ElementIds.appbarSettingsAnimationMenu}>
		<Icon IconCode={IconCodes.playCircleHint}/>
		Animation
		<div style="flex:1"/>
		<Icon IconCode={IconCodes.chevronRight}/>
	</SubMenuItem>
	<SubMenu id={ElementIds.appbarSettingsAnimationMenu}>
		<RadioMenuItem
			RadioMenuItemInputAttr={{
				name: RadioGroupNames.settingsAnimation,
				checked: true,
				value: PlatformAnimationMode.auto
			}}>
			<Icon IconCode={IconCodes.videoClipOptimize}/>
			Automatic
		</RadioMenuItem>
		<RadioMenuItem
			RadioMenuItemInputAttr={{
				name: RadioGroupNames.settingsAnimation,
				value: PlatformAnimationMode.on
			}}>
			<Icon IconCode={IconCodes.videoClip}/>
			On
		</RadioMenuItem>
		<RadioMenuItem
			RadioMenuItemInputAttr={{
				name: RadioGroupNames.settingsAnimation,
				value: PlatformAnimationMode.off
			}}>
			<Icon IconCode={IconCodes.videoClipOff}/>
			Off
		</RadioMenuItem>
	</SubMenu>

	<SubMenuItem
		popovertarget={ElementIds.appbarSettingsThemeMenu}>
		<Icon IconCode={IconCodes.weatherSunny}/>
		Theme
		<div style="flex:1"/>
		<Icon IconCode={IconCodes.chevronRight}/>
	</SubMenuItem>
	<SubMenu id={ElementIds.appbarSettingsThemeMenu}>
		<RadioMenuItem
			RadioMenuItemInputAttr={{
				name: RadioGroupNames.settingsTheme,
				checked: true,
				value: PlatformThemeMode.auto
			}}>
			<Icon IconCode={IconCodes.laptopSettings}/>
			Automatic
		</RadioMenuItem>
		<RadioMenuItem
			RadioMenuItemInputAttr={{
				name: RadioGroupNames.settingsTheme,
				value: PlatformThemeMode.light
			}}>
			<Icon IconCode={IconCodes.weatherSunny}/>
			Light
		</RadioMenuItem>
		<RadioMenuItem
			RadioMenuItemInputAttr={{
				name: RadioGroupNames.settingsTheme,
				value: PlatformThemeMode.dark
			}}>
			<Icon IconCode={IconCodes.weatherMoon}/>
			Dark
		</RadioMenuItem>
	</SubMenu>
</Menu>
<ColorPicker
	PopoverDraggable
	ColorPickerValue='#0093FF'
	ColorPickerDisabledOpacity
	ColorPickerHueOnly
	PopoverPosition={PopoverPosition.centerCenterRightTop}
	PopoverAnchorBy={ElementIds.appbarSettingsButton}
	id={ElementIds.appbarColorPicker}
	aria-labelledby={ElementIds.appbarSettingsAccentButton}
/>
<Menu id={ElementIds.appbarInfoMenu} PopoverAnchorBy={ElementIds.appbarInfoButton}>
	<LinkMenuItem href="/">
		<img src={logoRedmerah.src} width="20"/>
		Redmerah
	</LinkMenuItem>
	<LinkMenuItem href={RoutesLinks.apps}>
		<Icon IconCode={IconCodes.apps}/>
		More apps
	</LinkMenuItem>
	<LinkMenuItem href={RoutesLinks.about}>
		<Icon IconCode={IconCodes.info}/>
		About us
	</LinkMenuItem>
	<Divider />
	<LinkMenuItem href={RoutesLinks.privacy}>
		<Icon IconCode={IconCodes.shieldCheckmark}/>
		Privacy policy
	</LinkMenuItem>
	<LinkMenuItem href={RoutesLinks.terms}>
		<Icon IconCode={IconCodes.receipt}/>
		Terms & conditions
	</LinkMenuItem>
	<Divider />
	<MenuItem id={ElementIds.appbarInfoShareButton}>
		<Icon IconCode={IconCodes.shareAndroid}/>
		Share
	</MenuItem>
	<LinkMenuItem href={'mailto:' + ExternalLinks.contactEmail + '?subject=' + encodeURI('BiruUI')}>
		<Icon IconCode={IconCodes.chat}/>
		Send feedback
	</LinkMenuItem>
	<LinkMenuItem href={ExternalLinks.donate} LinkButtonNewTab>
		<Icon IconCode={IconCodes.gift}/>
		Donate
	</LinkMenuItem>
</Menu>