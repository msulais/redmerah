---
import icon from '@/assets/apps/tasks-splash.svg'

import Html from '@/layouts/Html/index.astro';
import Splash from '@/layouts/Splash/index.astro';
import App from './_App'

export const prerender = true;
---

<Html
	title='Tasks'
	accentColor='#9735E4'
	description='Simple and easy-to-use app that helps you stay organized and on track. With Tasks, you can create tasks, add them to lists, and mark them as completed.'>
	<Fragment slot="favicon">
		<link rel="shortcut icon" type="image/ico" href="/favicon/tasks/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/favicon/tasks/apple-touch-icon.png">
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon/tasks/favicon-32x32.png">
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon/tasks/favicon-16x16.png">
		<link rel="manifest" href="/favicon/tasks/site.webmanifest">
	</Fragment>
	<App client:only="solid-js"/>
	<Splash src={icon.src} alt="Tasks splash icon" />
</Html>

<script is:inline src='/scripts/theme.js'/>