---
import { ButtonVariant } from '@/native-components/Button'
import { ElementIds } from '../../_scripts/_shared/_ids'
import { CSSClasses } from '../../_styles/_css'
import Button from '@/native-components/Button/index.astro'
import IconButton from '@/native-components/Button/IconButton.astro'
import Icon from '@/native-components/Icon/index.astro'
import Tooltip from '@/native-components/Tooltip/index.astro'
import Dialog from '@/native-components/Dialog/index.astro'
import TextField from '@/native-components/TextField/index.astro'
import { IconCodes } from '@/enums/icons'
import ringtone from '@/assets/audio/simple-ringtone-84595.mp3'
---

<div
	id={ElementIds.pg_timer}
	class={[CSSClasses.bodyPage, CSSClasses.bodyPageTimer].join(' ')}
	role="tabpanel"
	hidden>
	<h2 id={ElementIds.pgTm_time}>00:10:00</h2>
	<audio id={ElementIds.pgTm_audio} loop src={ringtone}></audio>
	<Tooltip style="display:flex;justify-content:center;gap:8px">
		<Button
			style="width:92px"
			ButtonVariant={ButtonVariant.filled}
			id={ElementIds.pgTm_playPause}>
			<Icon IconCode={IconCodes.play} IconFilled/>
			<span>Start</span>
		</Button>
		<IconButton
			id={ElementIds.pgTm_editReset}
			IconButtonCode={IconCodes.edit}
			ButtonVariant={ButtonVariant.tonal}
			aria-label="Edit timer"
			data-tooltip="Edit timer"
		/>
	</Tooltip>
	<Dialog
		id={ElementIds.pgTm_editDialog}
		style="width:360px">
		<Fragment slot="header">Edit Timer</Fragment>
		<div style={{display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: '8px', marginBottom: '8px'}}>
			<label for={ElementIds.pgTm_hours}>Hours:</label>
			<label for={ElementIds.pgTm_minutes}>Minutes:</label>
			<label for={ElementIds.pgTm_seconds}>Seconds:</label>
		</div>
		<div style={{display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: '8px'}}>
			<TextField TextFieldInputAttr={{
				type: 'number', value: 0, min: 0, max: 99, placeholder: 'Hours',
				id: ElementIds.pgTm_hours
			}}/>
			<TextField TextFieldInputAttr={{
				type: 'number', value: 10, min: 0, max: 99, placeholder: 'Minutes',
				id: ElementIds.pgTm_minutes
			}}/>
			<TextField TextFieldInputAttr={{
				type: 'number', value: 0, min: 0, max: 99, placeholder: 'Seconds',
				id: ElementIds.pgTm_seconds
			}}/>
		</div>
		<form slot="footer" method="dialog" style="display:contents">
			<Button ButtonVariant={ButtonVariant.tonal}>Cancel</Button>
			<Button id={ElementIds.pgTm_save} ButtonVariant={ButtonVariant.filled}>Save</Button>
		</form>
	</Dialog>
	<Dialog style="width:360px" id={ElementIds.pgTm_doneDialog}>
		<Fragment slot="header">Timer Done</Fragment>
		<p id={ElementIds.pgTm_doneTime}></p>
		<p id={ElementIds.pgTm_doneDate}></p>
		<form style="display:contents" method="dialog" slot="footer">
			<Button ButtonVariant={ButtonVariant.filled}>
				<Icon IconCode={IconCodes.dismiss}/>
				Dismiss
			</Button>
		</form>
	</Dialog>
</div>