---
import * as Icons from '@/constants/icons.enum.js'
import Html2 from '@/layouts/Html2/index.astro'
import { APP } from './_scripts/shared/constant'
---

<Html2
	title={APP.name + ' • Redmerah'}
	description={APP.description}>
	<Fragment slot="favicon">
		<link rel="shortcut icon" type="image/ico" href={`/favicon${APP.link}/favicon.ico`} />
		<link rel="apple-touch-icon" sizes="180x180" href={`/favicon${APP.link}/apple-touch-icon.png`}>
		<link rel="icon" type="image/png" sizes="32x32" href={`/favicon${APP.link}/favicon-32x32.png`}>
		<link rel="icon" type="image/png" sizes="16x16" href={`/favicon${APP.link}/favicon-16x16.png`}>
		<link rel="manifest" href={`/favicon${APP.link}/site.webmanifest`}>
	</Fragment>
	<br-theme
		br:color-accent="#00FFFF"
		br:theme-mode="auto"
		br:font-family-icon="FluentSystemIcons-Resizable"
		br:font-family-sans-serif="'Figtree', ui-sans-serif, system-ui, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji', 'Segoe UI Symbol', 'Noto Color Emoji'"
		br:font-family-monospace="'Google Sans Code', ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace"
	>
	<br-tooltip>
	<br-scaffold>
		<br-appbar slot="appbar">
			<button br:tooltip="Person" slot="leading" br:icon br:variant="filled">
				<br-icon set:html={Icons.Person}/>
			</button>
			<span slot="headline">Calculator</span>
			<button slot="trailing" br:icon><br-icon set:html={Icons.Alert}/></button>
			<button slot="trailing" br:commandfor="text-action" br:icon><br-icon set:html={Icons.MoreVertical}/></button>
		</br-appbar>
		<br-navigation slot="left-sidebar">
			<a br:as="button navigationitem" br:hash="#sf" br:query="abc=8" br:path="/324">
				<br-icon set:html={Icons.Home}/>
				Home
			</a>
			<div style="flex:1"></div>
			<a br:as="button navigationitem" br:hash="#sf" br:query="abc=8" br:path="/324">
				<br-icon set:html={Icons.Settings}/>
				Settings
			</a>
		</br-navigation>
		<br-popover id="text-action" style="padding:.25rem">
			<menu>
				<li><button br:preventdefault><br-icon set:html={Icons.Copy}/>Copy</button></li>
				<li><button><br-icon set:html={Icons.ClipboardPaste}/>Paste</button></li>
				<li><button><br-icon set:html={Icons.Cut}/>Cut</button></li>
				<li><button><br-icon set:html={Icons.SlideSize}/>Select all</button></li>
				<li>
					<button
						br:preventdefault
						br:commandfor="submenu"
						style="padding-left:2.25rem">
						Submenu
						<div style="flex:1"></div>
						<br-icon set:html={Icons.ChevronRight}/>
					</button>
					<br-popover id="submenu" br:submenu style="width:192px">
						<menu>
							<li>
								<button>Option 1</button>
								<button>Option 2</button>
								<button>Option 3</button>
							</li>
						</menu>
					</br-popover>
				</li>
				<li><hr></li>
				<li>
					<label br:as="button">
						<input type="checkbox">
						Text wrap
					</label>
				</li>
				<li>
					<label br:as="button">
						<input type="radio" name="a">
						On
					</label>
				</li>
				<li>
					<label br:as="button">
						<input type="radio" name="a">
						Off
					</label>
				</li>
			</menu>
		</br-popover>
		<div style="display:flex;flex-wrap:wrap;gap:2px;margin:8px;border-radius:4px;border:1px solid rgba(var(--br-theme-color-on-surface),.16);background-color:rgb(var(--br-theme-color-surface));padding:16px">
			<select>
				<option>Option 1</option>
				<option selected>Option 2</option>
				<option>Option 3</option>
			</select>
			<button>Transparent</button>
			<button br:variant="colored">Colored idea</button>
			<button
				br:commandfor="dlg1"
				br:command="open-dialog"
				br:variant="tonal">Tonal palette</button>
			<br-dialog id="dlg1">
				<span slot="title">This is headline</span>
				This is dialog and this will be super long long text
				<p>Laboris fugiat qui Lorem ut exercitation cillum do.</p>
				<button
					br:variant="filled"
					br:commandfor="popover1"
					slot="footer"
					br:command="toggle-popover">
					Popover
				</button>
				<button
					br:commandfor="dlg1"
					br:command="close-dialog"
					br:variant="tonal outlined colored"
					slot="footer" br:tooltip="Click me">Click me</button>
				<br-popover id="popover1" br:position="right-center-to-bottom">
					<p>This is the prove of this popover is working fine</p>
					<button
						br:variant="tonal"
						br:command="close-popover"
						br:commandfor="popover1"
						style="margin-top:.5rem">
						Outlined the sun
					</button>
					<button
						br:commandfor="dlg1"
						br:command="close-dialog"
						br:variant="tonal outlined colored"
						br:tooltip="Click me">Close dialog</button>
				</br-popover>
			</br-dialog>
			<button
				br:variant="filled"
				br:commandfor="popover1"
				br:command="toggle-popover">
				Good work
			</button>
			<br-dialog></br-dialog>
			<br-view br:media="(max-width:720px)">
				<button br:variant="outlined">Outlined the sun</button>
			</br-view>
			<a br:as="button" br:variant="link">get sun</a>
		</div>
		<input br:as="textfield" placeholder="Email" type="time">
		<textarea style="width:190px" br:as="textfield"></textarea>
		<label>
			<input br:as="switch" type="checkbox"/>
			switch
		</label>
		<input type="range" br:as="slider">
		<label br:as="radiobutton">
			<input type="radio" name="theme">
			Theme light
		</label>
		<label br:as="radiobutton">
			<input type="radio" name="theme">
			Theme dark
		</label>
		<label br:as="checkbox">
			<input type="checkbox">
			Check in
		</label>
	</br-scaffold>
	</br-tooltip>
	</br-theme>
	<script src="@/web-components/components/br-theme.ts"/>
	<script src="@/web-components/components/br-scaffold.ts"/>
	<script src="@/web-components/components/br-view.ts"/>
	<script src="@/web-components/components/br-appbar.ts"/>
	<script src="@/web-components/components/br-icon.ts"/>
	<script src="@/web-components/components/br-popover.ts"/>
	<script src="@/web-components/components/br-dialog.ts"/>
	<script src="@/web-components/components/br-tooltip.ts"/>
	<script src="@/web-components/components/br-navigation.ts"/>
	<script src="@/web-components/components/button.ts"/>
	<script src="@/web-components/components/select.ts"/>
	<script src="@/web-components/components/menu.ts"/>
	<script src="@/web-components/components/textfield.ts"/>
	<script src="@/web-components/components/switch.ts"/>
	<script src="@/web-components/components/slider.ts"/>
	<script src="@/web-components/components/radiobutton.ts"/>
	<script src="@/web-components/components/checkbox.ts"/>
	<script src="./_scripts/index.ts"/>
</Html2>