---
import * as Icons from '@/enums/icons.enum.js'
import * as Ids from '../_scripts/shared/ids.enum.js'
import * as Pages from '../_scripts/shared/pages.enum.js'
---
<br-navigation slot="left-sidebar" id={Ids.Navigation}>
	<button
		aria-label="Toggle navigation"
		br:tooltip="Toggle navigation"
		br:commandfor={Ids.Navigation}>
		<br-icon set:html={Icons.LineHorizontal3}/>
	</button>
	<a
		br:as="navigationitem"
		href={`?page=${Pages.Basic}`}
		br:query={`page=${Pages.Basic}|none`}
		br:label="Basic">
		<br-icon set:html={Icons.Calculator}/>
	</a>
	<a
		br:as="navigationitem"
		href={`?page=${Pages.Scientific}`}
		br:query={`page=${Pages.Scientific}`}
		br:label="Scientific">
		<br-icon set:html={Icons.Beaker}/>
	</a>
	<a
		br:as="navigationitem"
		href={`?page=${Pages.Converter}`}
		br:query={`page=${Pages.Converter}`}
		br:label="Converter">
		<br-icon set:html={Icons.ArrowSort}/>
	</a>
	<a
		br:as="navigationitem"
		href={`?page=${Pages.Programmer}`}
		br:query={`page=${Pages.Programmer}`}
		br:label="Programmer">
		<br-icon set:html={Icons.Code}/>
	</a>
	<a
		br:as="navigationitem"
		href={`?page=${Pages.Date}`}
		br:query={`page=${Pages.Date}`}
		br:label="Date">
		<br-icon set:html={Icons.Calendar}/>
	</a>
</br-navigation>