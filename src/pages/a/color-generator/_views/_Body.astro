---
import * as Styles from '../_styles/styles.enum.js'
import * as Icons from '@/enums/icons.enum.js'
import * as Ids from '../_scripts/shared/ids.enum.js'
import * as Constant from '../_scripts/shared/constant.enum.js'
---
<div class={Styles.Actions}>
	<label
		style="display:flex;align-items:center">
		Color (<code><span id={Ids.ColorInputLabel}>{Constant.DEFAULT_COLOR}</span></code>):
		<input style="margin-left:1ch;" value={Constant.DEFAULT_COLOR} id={Ids.ColorInput} type="color"/>
	</label>
	<button
		br:variant="tonal"
		id={Ids.CopyButton}>
		<br-icon set:html={Icons.Copy}/>
		Copy
	</button>
</div>
<div class={Styles.Preview}>
	<div id={Ids.AccentLight}>
		<span id={Ids.AccentLightText}></span>
		<span id={Ids.OnAccentLightText}></span>
	</div>
	<div id={Ids.AccentDark}>
		<span id={Ids.AccentDarkText}></span>
		<span id={Ids.OnAccentDarkText}></span>
	</div>
</div>