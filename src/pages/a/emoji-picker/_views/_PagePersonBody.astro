---
import * as Ids from '../_scripts/shared/ids.enum.js'
import * as Pages from '../_scripts/shared/pages.enum.js'
import * as Icons from '@/enums/icons.enum.js'
import * as Styles from '../_styles/styles.enum.js'
import * as InputNames from '../_scripts/shared/input-names.enum.js'
import * as SkinTones from '../_scripts/shared/skin-tones.enum.js'
import * as Constant from '../_scripts/shared/constant.enum.js'
import { EMOJIS_PERSON_AND_BODY } from '@/constants/emoji'

const SKIN_TONES: {
	name: string
	skinTone: typeof SkinTones[keyof typeof SkinTones]
	color: string
}[] = [
	{
		name: 'Skin Tone: None',
		color: '#FFC64E',
		skinTone: SkinTones.None
	},
	{
		name: 'Skin Tone: Light',
		color: '#F7C1B0',
		skinTone: SkinTones.Light
	},
	{
		name: 'Skin Tone: Medium Light',
		color: '#E4AB94',
		skinTone: SkinTones.MediumLight
	},
	{
		name: 'Skin Tone: Medium',
		color: '#B18378',
		skinTone: SkinTones.Medium
	},
	{
		name: 'Skin Tone: Medium Dark',
		color: '#8A5D5C',
		skinTone: SkinTones.MediumDark
	},
	{
		name: 'Skin Tone: Dark',
		color: '#4B3234',
		skinTone: SkinTones.Dark
	},
]
---

<br-if
	br:query={`page=${Pages.PersonBody}`}
	br:animation-for={Ids.PagePersonBody}
	br:animation-start-duration="1000"
	br:animation-start-keyframes={JSON.stringify({
		opacity: [0, 1],
	})}>
	<div class={Styles.SkinTones} id={Ids.PagePersonBodySkinTones}>
		Skin tone:
		{SKIN_TONES.map(v =>
			<label
				br:as="button"
				br:variant={"icon" + (Constant.DEFAULT_SKIN_TONE === v.skinTone? " outlined" : "")}
				aria-label={v.name}
				br:tooltip={v.name}>
				<input
					name={InputNames.SkinTone}
					type="radio"
					checked={Constant.DEFAULT_SKIN_TONE === v.skinTone}
					autocomplete="off"
					value={v.skinTone}
				/>
				<br-icon style={{color: v.color}} set:html={Icons.CircleFilled}/>
			</label>
		)}
	</div>
	<br-focusgroup br:direction="grid">
		<ul class={Styles.Page} id={Ids.PagePersonBody}>
			{EMOJIS_PERSON_AND_BODY.map(v => <li>
				<button data-emoji={v[0]} br:tooltip={v[1]}>{v[0]}</button>
			</li>)}
		</ul>
	</br-focusgroup>
</br-if>