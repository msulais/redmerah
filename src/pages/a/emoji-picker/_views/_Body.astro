---
import * as Ids from '../_scripts/shared/ids.enum.js'
import * as Icons from '@/enums/icons.enum.js'
import * as Styles from '../_styles/styles.enum.js'
import PageSmileyEmotion from './_PageSmileyEmotion.astro'
import PagePersonBody from './_PagePersonBody.astro'
import PageActivities from './_PageActivities.astro'
import PageAnimalNature from './_PageAnimalNature.astro'
import PageFlags from './_PageFlags.astro'
import PageFoodDrink from './_PageFoodDrink.astro'
import PageObjects from './_PageObjects.astro'
import PageTravelPlaces from './_PageTravelPlaces.astro'
import PageSymbols from './_PageSymbols.astro'
---
<br-moveif
	br:fallback={Ids.SearchInputLocation}
	br:media="(width < 35rem)"
	br:for={Ids.SearchInput}
/>

<div
	id={Ids.SearchResult}
	class={Styles.SearchResult}>
	{/*
		Expected structure:
		<details open>
			<summary>{group_name}<br-icon>&#xE478;</br-icon></summary>
			<ul>
				<li><button
					data-emoji={emoji}
					br:tooltip={emoji_name}>
					{emoji}
				</button></li>
				...
			</ul>
		</details>
		...
	*/}
</div>

<div id={Ids.Body} class={Styles.Body}>
	<PageSmileyEmotion/>
	<PagePersonBody/>
	<PageActivities/>
	<PageAnimalNature/>
	<PageFlags/>
	<PageFoodDrink/>
	<PageObjects/>
	<PageTravelPlaces/>
	<PageSymbols/>
</div>
<div class={Styles.Clipboard}>
	<input
		id={Ids.CopyInput}
		type="text"
		br:as="textfield"
		placeholder="📋 Click emoji to copy"
	/>
	<button
		id={Ids.ClearCopyInput}
		br:variant="tonal icon"
		aria-label="Clear"
		br:tooltip="Clear">
		<br-icon set:html={Icons.Dismiss}/>
	</button>

	<br-attributeif
		br:for={Ids.CopyButton}
		br:name="br:variant"
		br:value="filled icon"
		br:fallback="filled"
		br:media="(width <= 35rem)"
	/>
	<br-attributeif
		br:for={Ids.CopyButton}
		br:name="br:tooltip"
		br:value="Copy"
		br:media="(width <= 35rem)"
	/>
	<button
		id={Ids.CopyButton}
		br:variant="filled"
		aria-label="Copy">
		<br-icon set:html={Icons.Copy}/>
		<br-if br:media="(width > 35rem)">
			Copy
		</br-if>
	</button>
</div>