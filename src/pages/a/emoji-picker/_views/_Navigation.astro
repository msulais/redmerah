---
import * as Icons from '@/enums/icons.enum.js'
import * as Ids from '../_scripts/shared/ids.enum.js'
import * as Pages from '../_scripts/shared/pages.enum.js'
---
<br-navigation slot="left-sidebar" id={Ids.Navigation}>
	<br-focusgroup br:direction="vertical">
		<button
			aria-label="Toggle navigation"
			br:tooltip="Toggle navigation"
			br:command-for={Ids.Navigation}>
			<br-icon set:html={Icons.LineHorizontal3}/>
		</button>
		<a
			br:as="navigationitem"
			href={`?page=${Pages.SmileyEmotion}`}
			br:query={`page=${Pages.SmileyEmotion}|none`}
			br:label="Smiley & Emotion">
			<br-icon style="line-height:normal;" set:html="😃"/>
		</a>
		<a
			br:as="navigationitem"
			href={`?page=${Pages.PersonBody}`}
			br:query={`page=${Pages.PersonBody}`}
			br:label="Person & Body">
			<br-icon style="line-height:normal;" set:html="🧑"/>
		</a>
		<a
			br:as="navigationitem"
			href={`?page=${Pages.AnimalNature}`}
			br:query={`page=${Pages.AnimalNature}`}
			br:label="Animal & Nature">
			<br-icon style="line-height:normal;" set:html="🦖"/>
		</a>
		<a
			br:as="navigationitem"
			href={`?page=${Pages.FoodDrink}`}
			br:query={`page=${Pages.FoodDrink}`}
			br:label="Food & Drink">
			<br-icon style="line-height:normal;" set:html="🍎"/>
		</a>
		<a
			br:as="navigationitem"
			href={`?page=${Pages.TravelPlaces}`}
			br:query={`page=${Pages.TravelPlaces}`}
			br:label="Travel & Places">
			<br-icon style="line-height:normal;" set:html="🌍"/>
		</a>
		<a
			br:as="navigationitem"
			href={`?page=${Pages.Activities}`}
			br:query={`page=${Pages.Activities}`}
			br:label="Activities">
			<br-icon style="line-height:normal;" set:html="🏓"/>
		</a>
		<a
			br:as="navigationitem"
			href={`?page=${Pages.Objects}`}
			br:query={`page=${Pages.Objects}`}
			br:label="Objects">
			<br-icon style="line-height:normal;" set:html="📒"/>
		</a>
		<a
			br:as="navigationitem"
			href={`?page=${Pages.Symbols}`}
			br:query={`page=${Pages.Symbols}`}
			br:label="Symbols">
			<br-icon style="line-height:normal;" set:html="🚹"/>
		</a>
		<a
			br:as="navigationitem"
			href={`?page=${Pages.Flags}`}
			br:query={`page=${Pages.Flags}`}
			br:label="Flags">
			<br-icon style="line-height:normal;" set:html="🚩"/>
		</a>
	</br-focusgroup>
</br-navigation>