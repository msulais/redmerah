---
import Html from '@/layouts/Html/index.astro'
import App from '@/components/App2/index.astro'
import Menus from './_views/_UIMenus.astro'
import Body from './_views/_UIBody.astro'
import Navigation from './_views/_UINavigation.astro'
import AppBar from './_views/_UIAppBar.astro'
import UISplash from './_views/_UISplash.astro'
export const prerender = true
---

<Html
	title='BiruUI • Redmerah'
	accentColor='#0093FF'
	description='We test our UI here'>
	<Fragment slot="favicon">
		<link rel="shortcut icon" type="image/ico" href="/favicon/a/biru-ui/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/favicon/a/biru-ui/apple-touch-icon.png">
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon/a/biru-ui/favicon-32x32.png">
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon/a/biru-ui/favicon-16x16.png">
		<link rel="manifest" href="/favicon/a/biru-ui/site.webmanifest">
	</Fragment>
	<UISplash/>
	<App AppTagName='div'>
		<AppBar slot='appbar'/>
		<Navigation slot="left-sidebar"/>
		<Body/>
	</App>
	<Menus/>
	<script src="./_scripts/_index.ts" />
</Html>
