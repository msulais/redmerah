---
import Icon from '@/components/Icon/index.astro'
import Toast from '@/components/Toast/index.astro'
import { CSSClasses } from '../_styles/_css'
import { IconCodes } from '@/enums/icons'
import { ElementIds } from '../_scripts/_shared/_ids'
import { DEFAULT_DECODED_TEXT, DEFAULT_ENCODED_TEXT, DEFAULT_TEXT_WRAP } from '../_scripts/_shared/_constant'
---

<main class={CSSClasses.body}>
	<div id={ElementIds.bd_inputContainer}>
		<label for={ElementIds.bd_decode}>Decode:</label>
		<textarea
			id={ElementIds.bd_decode}
			placeholder="Type your decoded url here ..."
			data-text-wrap={DEFAULT_TEXT_WRAP? '' : undefined}>{
			DEFAULT_DECODED_TEXT
		}</textarea>
	</div>
	<div id={ElementIds.bd_slider} class={CSSClasses.bodySlider}/>
	<div>
		<label for={ElementIds.bd_encode}>Encode:</label>
		<textarea
			id={ElementIds.bd_encode}
			placeholder="Type your encoded url here ..."
			data-text-wrap={DEFAULT_TEXT_WRAP? '' : undefined}>{
			DEFAULT_ENCODED_TEXT
		}</textarea>
	</div>
</main>
<Toast id={ElementIds.toa_copied} ToastCloseDelay={1500}>
	<Icon IconCode={IconCodes.Copy} slot="leading"/>
	Copied
</Toast>