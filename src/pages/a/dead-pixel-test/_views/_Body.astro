---
import * as Icons from '@/enums/icons.enum.js'
import * as Ids from '../_scripts/shared/ids.enum.js'
---
<button br:variant="filled" id={Ids.Start}>
	<br-icon set:html={Icons.PlayFilled}/>
	Start test
</button>
<ul>
	<li data-tooltip="Black: #000000" style="background-color:#000"/>
	<li data-tooltip="White: #FFFFFF" style="background-color:#FFF"/>
	<li data-tooltip="Red: #FF0000" style="background-color:#FF0000"/>
	<li data-tooltip="Yellow: #FFFF00" style="background-color:#FFFF00"/>
	<li data-tooltip="Green: #00FF00" style="background-color:#00FF00"/>
	<li data-tooltip="Cyan: #00FFFF" style="background-color:#00FFFF"/>
	<li data-tooltip="Blue: #0000FF" style="background-color:#0000FF"/>
	<li data-tooltip="Purple: #FF00FF" style="background-color:#FF00FF"/>
</ul>
<div id={Ids.View} data-css="view"/>