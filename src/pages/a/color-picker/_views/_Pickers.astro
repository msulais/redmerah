---
import * as Icons from '@/enums/icons.enum.js'
import * as ColorPickerMode from '../_scripts/shared/modes.enum.js'
import * as Constant from '../_scripts/shared/constant.enum.js'
import * as Styles from '../_styles/styles.enum.js'
import * as Ids from '../_scripts/shared/ids.enum.js'
import { colorContrastPercentage, hexToRgb, hslToRgb, hsvToHex, hsvToRgb, hwbToRgb } from '@/utils/color'
---

<div
	data-picker-mode={ColorPickerMode.Image}
	hidden={Constant.DEFAULT_PICKER_MODE !== ColorPickerMode.Image}>
	<button
		id={Ids.PickerImageButton}
		br:variant="filled"
		style={{
			'margin-top': '.5rem'
		}}>
		<br-icon set:html={Icons.Image}/>
		Pick image
	</button>
	<div
		id={Ids.PickerimageWrapper}
		class={Styles.PickerImageRect}
		data-no-image
		tabindex="0"
		style={{
			'--color': '#fff',
			'--border-color': '#fff',
			'--position-x': '0%',
			'--position-y': '0%',
		}}>
		<canvas
			id={Ids.PickerImageCanvas}
			style="width:100%;height:100%"
		/>
	</div>
	<div style={{
		'min-height': '1rem'
	}}/>
</div>

<div
	data-picker-mode={ColorPickerMode.Rectangle}
	hidden={Constant.DEFAULT_PICKER_MODE !== ColorPickerMode.Rectangle}>
	<div id={Ids.PickerRectangleRect} tabindex="0" class={Styles.PickerRect} style={{
		'--color': Constant.DEFAULT_COLOR,
		'--hue': Constant.DEFAULT_COLOR_IN_HSV.h * 360,
		'--position-x': (Constant.DEFAULT_COLOR_IN_HSV.s * 100) + '%',
		'--position-y': 100 - (Constant.DEFAULT_COLOR_IN_HSV.v * 100) + '%',
		'--border-color': colorContrastPercentage(Constant.DEFAULT_COLOR_IN_RGB, {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
		background: [
			'linear-gradient(to top,#000,transparent)',
			'linear-gradient(to right,#fff,transparent)',
			'hsl(var(--hue),100%,50%)'
		].join(',')
	}}/>
	<input
		class={Styles.PickerSlider}
		id={Ids.PickerRectangleHue}
		style={{
			'--color': `hsl(${Math.round(Constant.DEFAULT_COLOR_IN_HSL.h * 360)},100%,50%)`,
			'--border-color': colorContrastPercentage(hslToRgb({h: Constant.DEFAULT_COLOR_IN_HSL.h, s: 1, l: .5}), {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(90deg in hsl longer hue,#FF0000 0%,#FF0000 100%)',
			marginTop: '.75rem'
		}}
		type="range"
		min="0"
		max={360}
		value={Math.round(Constant.DEFAULT_COLOR_IN_HSV.h * 360) + ''}
	/>
</div>

<div
	data-picker-mode={ColorPickerMode.RectangleHsl}
	hidden={Constant.DEFAULT_PICKER_MODE !== ColorPickerMode.RectangleHsl}>
	<div id={Ids.PickerRectangleHslRect} tabindex="0" class={Styles.PickerRect} style={{
		'--color': Constant.DEFAULT_COLOR,
		'--hue': Constant.DEFAULT_COLOR_IN_HSL.h * 360,
		'--position-x': (Constant.DEFAULT_COLOR_IN_HSL.s * 100) + '%',
		'--position-y': (Constant.DEFAULT_COLOR_IN_HSL.l * 100) + '%',
		'--border-color': colorContrastPercentage(Constant.DEFAULT_COLOR_IN_RGB, {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
		background: [
			'linear-gradient(to bottom,#ffffff,#ffffff00 50%,#00000000 50%,#000000)',
			'linear-gradient(to right,#808080,hsl(var(--hue),100%,50%))'
		].join(',')
	}}/>
	<input
		class={Styles.PickerSlider}
		id={Ids.PickerRectangleHslHue}
		style={{
			'--color': `hsl(${Math.round(Constant.DEFAULT_COLOR_IN_HSL.h * 360)},100%,50%)`,
			'--border-color': colorContrastPercentage(hslToRgb({h: Constant.DEFAULT_COLOR_IN_HSL.h, s: 1, l: .5}), {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(90deg in hsl longer hue,#FF0000 0%,#FF0000 100%)',
			marginTop: '.75rem'
		}}
		type="range"
		min="0"
		max={360}
		value={Math.round(Constant.DEFAULT_COLOR_IN_HSL.h * 360) + ''}
	/>
</div>

<div
	data-picker-mode={ColorPickerMode.Spectrum}
	hidden={Constant.DEFAULT_PICKER_MODE !== ColorPickerMode.Spectrum}>
	<div id={Ids.PickerSpectrumRect} tabindex="0" class={Styles.PickerRect} style={{
		'--color': hsvToHex({...Constant.DEFAULT_COLOR_IN_HSV, v: 1}),
		'--position-x': (Constant.DEFAULT_COLOR_IN_HSV.h * 100) + '%',
		'--position-y': 100 - (Constant.DEFAULT_COLOR_IN_HSV.s * 100) + '%',
		'--border-color': colorContrastPercentage(hsvToRgb({...Constant.DEFAULT_COLOR_IN_HSV, v: 1}), {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
		background: [
			'linear-gradient(0deg in hsl longer hue,#fff 0%,transparent 100%)',
			'linear-gradient(90deg in hsl longer hue,#FF0000 0%,#FF0000 100%)'
		].join(',')
	}}/>
	<input
		id={Ids.PickerSpectrumHue}
		class={Styles.PickerSlider}
		style={{
			'--max-value-color': hsvToHex({...Constant.DEFAULT_COLOR_IN_HSV, v: 1}),
			'--color': Constant.DEFAULT_COLOR,
			'--border-color': colorContrastPercentage(Constant.DEFAULT_COLOR_IN_RGB, {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(to right,var(--max-value-color) 0%,#000 100%)',
			marginTop: '.75rem'
		}}
		type="range"
		min="0"
		max="100"
		value={Math.round((1 - Constant.DEFAULT_COLOR_IN_HSV.v) * 100) + ''}
	/>
</div>

<div
	data-picker-mode={ColorPickerMode.SliderRgb}
	hidden={Constant.DEFAULT_PICKER_MODE !== ColorPickerMode.SliderRgb}>
	<label for={Ids.PickerRgbRed} style={{'margin-top': '1rem'}}>Red: {Math.round(Constant.DEFAULT_COLOR_IN_RGB.r * 0xff)} ({Math.round(Constant.DEFAULT_COLOR_IN_RGB.r * 100)}%)</label>
	<input
		id={Ids.PickerRgbRed}
		class={Styles.PickerSlider}
		style={{
			'--color': `rgb(${Math.round(Constant.DEFAULT_COLOR_IN_RGB.r * 0xff)},0,0)`,
			'--border-color': colorContrastPercentage({...Constant.DEFAULT_COLOR_IN_RGB, g: 0, b: 0}, {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(to right,#000 0%,#FF0000 100%)',
			marginTop: '.25rem'
		}}
		type="range"
		min="0"
		max="255"
		value={Math.round(Constant.DEFAULT_COLOR_IN_RGB.r * 0xff) + ''}
	/>

	<label for={Ids.PickerRgbGreen} style={{'margin-top': '.75rem'}}>Green: {Math.round(Constant.DEFAULT_COLOR_IN_RGB.g * 0xff)} ({Math.round(Constant.DEFAULT_COLOR_IN_RGB.g * 100)}%)</label>
	<input
		id={Ids.PickerRgbGreen}
		class={Styles.PickerSlider}
		style={{
			'--color': `rgb(0,${Math.round(Constant.DEFAULT_COLOR_IN_RGB.g * 0xff)},0)`,
			'--border-color': colorContrastPercentage({...Constant.DEFAULT_COLOR_IN_RGB, r: 0, b: 0}, {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(to right,#000 0%,#00FF00 100%)',
			marginTop: '.25rem'
		}}
		type="range"
		min="0"
		max="255"
		value={Math.round(Constant.DEFAULT_COLOR_IN_RGB.g * 0xff) + ''}
	/>

	<label for={Ids.PickerRgbBlue} style={{'margin-top': '.75rem'}}>Blue: {Math.round(Constant.DEFAULT_COLOR_IN_RGB.b * 0xff)} ({Math.round(Constant.DEFAULT_COLOR_IN_RGB.b * 100)}%)</label>
	<input
		class={Styles.PickerSlider}
		id={Ids.PickerRgbBlue}
		style={{
			'--color': `rgb(0,0,${Math.round(Constant.DEFAULT_COLOR_IN_RGB.b * 0xff)})`,
			'--border-color': colorContrastPercentage({...Constant.DEFAULT_COLOR_IN_RGB, g: 0, r: 0}, {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(to right,#000 0%,#0000FF 100%)',
			marginTop: '.25rem'
		}}
		type="range"
		min="0"
		max="255"
		value={Math.round(Constant.DEFAULT_COLOR_IN_RGB.b * 0xff) + ''}
	/>
</div>

<div
	data-picker-mode={ColorPickerMode.SliderHsl}
	hidden={Constant.DEFAULT_PICKER_MODE !== ColorPickerMode.SliderHsl}>
	<label for={Ids.PickerHslHue} style={{'margin-top': '1rem'}}>Hue: {Math.round(Constant.DEFAULT_COLOR_IN_HSL.h * 360)}° ({Math.round(Constant.DEFAULT_COLOR_IN_HSL.h * 100)}%)</label>
	<input
		id={Ids.PickerHslHue}
		class={Styles.PickerSlider}
		style={{
			'--color': `hsl(${Math.round(Constant.DEFAULT_COLOR_IN_HSL.h * 360)},100%,50%)`,
			'--border-color': colorContrastPercentage(hslToRgb({...Constant.DEFAULT_COLOR_IN_HSL, s: 1, l: 0.5}), {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(90deg in hsl longer hue,#FF0000 0%,#FF0000 100%)',
			marginTop: '.25rem'
		}}
		type="range"
		min="0"
		max={360}
		value={Math.round(Constant.DEFAULT_COLOR_IN_HSL.h * 360) + ''}
	/>

	<label for={Ids.PickerHslSaturation} style={{'margin-top': '.75rem'}}>Saturation: {Math.round(Constant.DEFAULT_COLOR_IN_HSL.s * 100)}%</label>
	<input
		id={Ids.PickerHslSaturation}
		class={Styles.PickerSlider}
		style={{
			'--hue': Math.round(Constant.DEFAULT_COLOR_IN_HSL.h * 360) + '',
			'--color': `hsl(${Math.round(Constant.DEFAULT_COLOR_IN_HSL.h * 360)},${Math.round(Constant.DEFAULT_COLOR_IN_HSL.s * 100)}%,50%)`,
			'--border-color': colorContrastPercentage(hslToRgb({...Constant.DEFAULT_COLOR_IN_HSL, l: 0.5}), {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(to right,hsl(var(--hue),0%,50%) 0%,hsl(var(--hue),100%,50%) 100%)',
			marginTop: '.25rem'
		}}
		type="range"
		min="0"
		max="100"
		value={Math.round(Constant.DEFAULT_COLOR_IN_HSL.s * 100) + ''}
	/>

	<label for={Ids.PickerHslLightness} style={{'margin-top': '.75rem'}}>Lightness: {Math.round(Constant.DEFAULT_COLOR_IN_HSL.l * 100)}%</label>
	<input
		class={Styles.PickerSlider}
		id={Ids.PickerHslLightness}
		style={{
			'--color': `hsl(0,0%,${Math.round(Constant.DEFAULT_COLOR_IN_HSL.l * 100)}%)`,
			'--border-color': colorContrastPercentage(hslToRgb({...Constant.DEFAULT_COLOR_IN_HSL, h: 0, s: 0}), {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(to right,#000 0%,#fff 100%)',
			marginTop: '.25rem'
		}}
		type="range"
		min="0"
		max="100"
		value={Math.round(Constant.DEFAULT_COLOR_IN_HSL.l * 100) + ''}
	/>
</div>

<div
	data-picker-mode={ColorPickerMode.SliderCmyk}
	hidden={Constant.DEFAULT_PICKER_MODE !== ColorPickerMode.SliderCmyk}>
	<label for={Ids.PickerCmykCyan} style={{'margin-top': '1rem'}}>Cyan: {Math.round(Constant.DEFAULT_COLOR_IN_CMYK.c * 100)}%</label>
	<input
		id={Ids.PickerCmykCyan}
		class={Styles.PickerSlider}
		style={{
			'--color': `hsl(180,100%,${Constant.DEFAULT_COLOR_IN_CMYK.c * 50}%)`,
			'--border-color': colorContrastPercentage(hslToRgb({h: 180 / 360, s: 1, l: Constant.DEFAULT_COLOR_IN_CMYK.c * 0.5}), {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(90deg,#000 0%,#00FFFF 100%)',
			marginTop: '.25rem'
		}}
		type="range"
		min="0"
		max="100"
		value={Math.round(Constant.DEFAULT_COLOR_IN_CMYK.c * 100) + ''}
	/>

	<label for={Ids.PickerCmykMagenta} style={{'margin-top': '.75rem'}}>Magenta: {Math.round(Constant.DEFAULT_COLOR_IN_CMYK.m * 100)}%</label>
	<input
		id={Ids.PickerCmykMagenta}
		class={Styles.PickerSlider}
		style={{
			'--color': `hsl(300,100%,${Constant.DEFAULT_COLOR_IN_CMYK.m * 50}%)`,
			'--border-color': colorContrastPercentage(hslToRgb({h: 300 / 360, s: 1, l: Constant.DEFAULT_COLOR_IN_CMYK.m * 0.5}), {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(90deg,#000 0%,#FF00FF 100%)',
			marginTop: '.25rem'
		}}
		type="range"
		min="0"
		max="100"
		value={Math.round(Constant.DEFAULT_COLOR_IN_CMYK.m * 100) + ''}
	/>

	<label for={Ids.PickerCmykYellow} style={{'margin-top': '.75rem'}}>Yellow: {Math.round(Constant.DEFAULT_COLOR_IN_CMYK.y * 100)}%</label>
	<input
		id={Ids.PickerCmykYellow}
		class={Styles.PickerSlider}
		style={{
			'--color': `hsl(60,100%,${Constant.DEFAULT_COLOR_IN_CMYK.y * 50}%)`,
			'--border-color': colorContrastPercentage(hslToRgb({h: 60 / 360, s: 1, l: Constant.DEFAULT_COLOR_IN_CMYK.y * 0.5}), {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(90deg,#000 0%,#FFFF00 100%)',
			marginTop: '.25rem'
		}}
		type="range"
		min="0"
		max="100"
		value={Math.round(Constant.DEFAULT_COLOR_IN_CMYK.y * 100) + ''}
	/>

	<label for={Ids.PickerCmykKey} style={{'margin-top': '.75rem'}}>Key/Black: {Math.round(Constant.DEFAULT_COLOR_IN_CMYK.k * 100)}%</label>
	<input
		id={Ids.PickerCmykKey}
		class={Styles.PickerSlider}
		style={{
			'--color': `hsl(0,0%,${(1-Constant.DEFAULT_COLOR_IN_CMYK.k) * 100}%)`,
			'--border-color': colorContrastPercentage(hslToRgb({h: 0, s: 0, l: (1-Constant.DEFAULT_COLOR_IN_CMYK.k)}), {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(to right,#fff 0%,#000 100%)',
			marginTop: '.25rem'
		}}
		type="range"
		min="0"
		max="100"
		value={Math.round(Constant.DEFAULT_COLOR_IN_CMYK.k * 100) + ''}
	/>
</div>

<div
	data-picker-mode={ColorPickerMode.SliderHex}
	hidden={Constant.DEFAULT_PICKER_MODE !== ColorPickerMode.SliderHex}>
	<label for={Ids.PickerHex} style={{'margin-top': '1rem'}}>Hex: {Constant.DEFAULT_COLOR} ({Constant.DEFAULT_COLOR_IN_VALUE})</label>
	<input
		id={Ids.PickerHex}
		class={Styles.PickerSlider}
		style={{
			'--color': Constant.DEFAULT_COLOR,
			'--border-color': colorContrastPercentage(hexToRgb(Constant.DEFAULT_COLOR), {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(90deg,#000 0%,#fff 100%)',
			marginTop: '.25rem'
		}}
		type="range"
		min="0"
		max={0xffffff}
		value={Constant.DEFAULT_COLOR_IN_VALUE + ''}
	/>
</div>

<div
	data-picker-mode={ColorPickerMode.SliderHsv}
	hidden={Constant.DEFAULT_PICKER_MODE !== ColorPickerMode.SliderHsv}>
	<label for={Ids.PickerHsvHue} style={{'margin-top': '1rem'}}>Hue: {Math.round(Constant.DEFAULT_COLOR_IN_HSV.h * 360)}° ({Math.round(Constant.DEFAULT_COLOR_IN_HSV.h * 100)}%)</label>
	<input
		id={Ids.PickerHsvHue}
		class={Styles.PickerSlider}
		style={{
			'--color': hsvToHex({...Constant.DEFAULT_COLOR_IN_HSV, s: 1, v: 1}),
			'--border-color': colorContrastPercentage(hsvToRgb({...Constant.DEFAULT_COLOR_IN_HSV, s: 1, v: 1}), {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(90deg in hsl longer hue,#FF0000 0%,#FF0000 100%)',
			marginTop: '.25rem'
		}}
		type="range"
		min="0"
		max={360}
		value={Math.round(Constant.DEFAULT_COLOR_IN_HSV.h * 360) + ''}
	/>

	<label for={Ids.PickerHsvSaturation} style={{'margin-top': '.75rem'}}>Saturation: {Math.round(Constant.DEFAULT_COLOR_IN_HSV.s * 100)}%</label>
	<input
		id={Ids.PickerHsvSaturation}
		class={Styles.PickerSlider}
		style={{
			'--hue': Math.round(Constant.DEFAULT_COLOR_IN_HSV.h * 360),
			'--color': hsvToHex({...Constant.DEFAULT_COLOR_IN_HSV, v: 1}),
			'--border-color': colorContrastPercentage(hsvToRgb({...Constant.DEFAULT_COLOR_IN_HSV, v: 1}), {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(to right,hsl(var(--hue),0%,50%) 0%,hsl(var(--hue),100%,50%) 100%)',
			marginTop: '.25rem'
		}}
		type="range"
		min="0"
		max="100"
		value={Math.round(Constant.DEFAULT_COLOR_IN_HSV.s * 100) + ''}
	/>

	<label for={Ids.PickerHsvValue} style={{'margin-top': '.75rem'}}>Value: {Math.round(Constant.DEFAULT_COLOR_IN_HSV.v * 100)}%</label>
	<input
		id={Ids.PickerHsvValue}
		class={Styles.PickerSlider}
		style={{
			'--max-value-color': hsvToHex({...Constant.DEFAULT_COLOR_IN_HSV, v: 1}),
			'--color': Constant.DEFAULT_COLOR,
			'--border-color': colorContrastPercentage(hexToRgb(Constant.DEFAULT_COLOR), {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(to right,#000 0%,var(--max-value-color) 100%)',
			marginTop: '.25rem'
		}}
		type="range"
		min="0"
		max="100"
		value={Math.round(Constant.DEFAULT_COLOR_IN_HSV.v * 100) + ''}
	/>
</div>

<div
	data-picker-mode={ColorPickerMode.SliderHwb}
	hidden={Constant.DEFAULT_PICKER_MODE !== ColorPickerMode.SliderHwb}>
	<label for={Ids.PickerHwbHue} style={{'margin-top': '1rem'}}>Hue: {Math.round(Constant.DEFAULT_COLOR_IN_HWB.h * 360)}° ({Math.round(Constant.DEFAULT_COLOR_IN_HWB.h * 100)}%)</label>
	<input
		id={Ids.PickerHwbHue}
		class={Styles.PickerSlider}
		style={{
			'--color': `hwb(${Math.round(Constant.DEFAULT_COLOR_IN_HWB.h * 360)} 0% 0%)`,
			'--border-color': colorContrastPercentage(hwbToRgb({...Constant.DEFAULT_COLOR_IN_HWB, w: 0, b: 0}), {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(90deg in hsl longer hue,#FF0000 0%,#FF0000 100%)',
			marginTop: '.25rem'
		}}
		type="range"
		min="0"
		max={360}
		value={Math.round(Constant.DEFAULT_COLOR_IN_HWB.h * 360) + ''}
	/>

	<label for={Ids.PickerHwbWhiteness} style={{'margin-top': '.75rem'}}>Whiteness: {Math.round(Constant.DEFAULT_COLOR_IN_HWB.w * 100)}%</label>
	<input
		id={Ids.PickerHwbWhiteness}
		class={Styles.PickerSlider}
		style={{
			'--hue': Math.round(Constant.DEFAULT_COLOR_IN_HWB.h * 360),
			'--color': `hwb(${Math.round(Constant.DEFAULT_COLOR_IN_HWB.h * 360)} ${Math.round(Constant.DEFAULT_COLOR_IN_HWB.w * 100)}% 0%)`,
			'--border-color': colorContrastPercentage(hwbToRgb({...Constant.DEFAULT_COLOR_IN_HWB, b: 0}), {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(to right,hwb(var(--hue) 0% 0%) 0%,#fff 100%)',
			marginTop: '.25rem'
		}}
		type="range"
		min="0"
		max="100"
		value={Math.round(Constant.DEFAULT_COLOR_IN_HWB.w * 100) + ''}
	/>

	<label for={Ids.PickerHwbBlackness} style={{'margin-top': '.75rem'}}>Blackness: {Math.round(Constant.DEFAULT_COLOR_IN_HWB.b * 100)}%</label>
	<input
		id={Ids.PickerHwbBlackness}
		class={Styles.PickerSlider}
		style={{
			'--hue': Math.round(Constant.DEFAULT_COLOR_IN_HWB.h * 360),
			'--color': `hwb(${Math.round(Constant.DEFAULT_COLOR_IN_HWB.h * 360)} 0% ${Math.round(Constant.DEFAULT_COLOR_IN_HWB.b * 100)}%)`,
			'--border-color': colorContrastPercentage(hwbToRgb({...Constant.DEFAULT_COLOR_IN_HWB, w: 0}), {r: 0, g: 0, b: 0}) > 50? '#000' : '#fff',
			'--gradient': 'linear-gradient(to right,hwb(var(--hue) 0% 0%) 0%,#000 100%)',
			marginTop: '.25rem'
		}}
		type="range"
		min="0"
		max="100"
		value={Math.round(Constant.DEFAULT_COLOR_IN_HWB.b * 100) + ''}
	/>
</div>