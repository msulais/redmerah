---
import * as InputNames from '../_scripts/shared/input-names.enum.js'
import * as TabValues from '../_scripts/shared/tab-values.enum.js'
import * as Icons from '@/enums/icons.enum.js'
import * as Ids from '../_scripts/shared/ids.enum.js'
import * as Styles from '../_styles/styles.enum.js'
import * as Constant from '../_scripts/shared/constant.enum.js'
---
<div id={Ids.InputContainer}>
	<div id={Ids.InputTabs}>
		<label br:as="tab">
			<input
				type="radio"
				name={InputNames.TabsInput}
				value={TabValues.InputMarkdown}
				checked={Constant.DEFAULT_TAB_INPUT_VALUE === TabValues.InputMarkdown}
			/>
			Markdown
		</label>
		<label br:as="tab">
			<input
				type="radio"
				name={InputNames.TabsInput}
				value={TabValues.InputCSS}
				checked={Constant.DEFAULT_TAB_INPUT_VALUE === TabValues.InputCSS}
			/>
			CSS
		</label>
	</div>
	<textarea
		br:as="textfield"
		id={Ids.InputMarkdown}
		placeholder="Type your markdown here ..."
		style={{
			display: Constant.DEFAULT_TAB_INPUT_VALUE === TabValues.InputMarkdown? null : 'none'
		}}
		data-text-wrap={Constant.DEFAULT_TEXT_WRAP? '' : undefined}>{
		Constant.DEFAULT_MARKDOWN_TEXT
	}</textarea>
	<textarea
		br:as="textfield"
		id={Ids.InputCSS}
		placeholder="Type your CSS here ..."
		style={{
			display: Constant.DEFAULT_TAB_INPUT_VALUE === TabValues.InputCSS? null : 'none'
		}}
		data-text-wrap={Constant.DEFAULT_TEXT_WRAP? '' : undefined}>{
		Constant.DEFAULT_CSS_TEXT
	}</textarea>
</div>
<div id={Ids.Slider} class={Styles.Slider}>
	<br-icon set:html={Icons.ReOrderVertical}/>
</div>
<div>
	<div id={Ids.OutputTabs}>
		<label br:as="tab">
			<input
				type="radio"
				name={InputNames.TabsOutput}
				value={TabValues.OutputPreview}
				checked={Constant.DEFAULT_TAB_OUTPUT_VALUE === TabValues.OutputPreview}
			/>
			Preview
		</label>
		<label br:as="tab">
			<input
				type="radio"
				name={InputNames.TabsOutput}
				value={TabValues.OutputHTML}
				checked={Constant.DEFAULT_TAB_OUTPUT_VALUE === TabValues.OutputHTML}
			/>
			HTML
		</label>
	</div>
	<iframe
		title="Markdown preview"
		id={Ids.OutputPreview}
		style={{
			display: Constant.DEFAULT_TAB_OUTPUT_VALUE === TabValues.OutputPreview? null : 'none'
		}}
		srcdoc={Constant.DEFAULT_PREVIEW_TEXT}
	/>
	<textarea
		br:as="textfield"
		id={Ids.OutputHTML}
		style={{
			display: Constant.DEFAULT_TAB_OUTPUT_VALUE === TabValues.OutputHTML? null : 'none'
		}}
		data-text-wrap={Constant.DEFAULT_TEXT_WRAP? '' : undefined}>{
		Constant.DEFAULT_HTML_TEXT
	}</textarea>
</div>