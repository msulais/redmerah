---
import * as Ids from '../_scripts/shared/ids.enum.js'
import * as Commands from '../_scripts/shared/commands.enum.js'
import * as Constant from '../_scripts/shared/constant.enum.js'
import * as Pages from '../_scripts/shared/pages.enum.js'
import * as Styles from '../_styles/styles.enum.js'
import * as Icons from '@/enums/icons.enum.js'

function textHHMMSS(ms: number): string {
	let hour = 0
	let minute = 0
	let second = 0
	if (ms >= 3_600_000) {
		hour = Math.floor(ms / 3_600_000)
		ms = Math.floor(ms % 3_600_000)
	}
	if (ms >= 60_000) {
		minute = Math.floor(ms / 60_000)
		ms = Math.floor(ms % 60_000)
	}
	if (ms >= 1000) {
		second = Math.floor(ms / 1000)
		ms = Math.floor(ms % 1000)
	}

	ms = Math.floor(ms / 10)
	return (
		hour.toString()
		+ ':'
		+ [minute, second].map(v => v.toString().padStart(2, '0')).join(':')
	)
}

function textMS(ms: number): string {
	if (ms >= 3_600_000) {
		ms = Math.floor(ms % 3_600_000)
	}
	if (ms >= 60_000) {
		ms = Math.floor(ms % 60_000)
	}
	if (ms >= 1000) {
		ms = Math.floor(ms % 1000)
	}

	ms = Math.floor(ms / 10)
	return ms.toString().padStart(2, '0')
}

function msText(ms: number): string {
	let hour = 0
	let minute = 0
	let second = 0
	if (ms >= 3_600_000) {
		hour = Math.floor(ms / 3_600_000)
		ms = Math.floor(ms % 3_600_000)
	}
	if (ms >= 60_000) {
		minute = Math.floor(ms / 60_000)
		ms = Math.floor(ms % 60_000)
	}
	if (ms >= 1000) {
		second = Math.floor(ms / 1000)
		ms = Math.floor(ms % 1000)
	}

	ms = Math.floor(ms / 10)
	return (
		hour.toString()
		+ ':'
		+ [minute, second].map(v => v.toString().padStart(2, '0')).join(':')
		+ ','
		+ ms.toString().padStart(2, '0')
	)
}
---

<br-if
	br:query={`page=${Pages.Stopwatch}`}
	br:animation-for={Ids.PageStopwatch}
	br:animation-start-duration="500"
	br:animation-start-keyframes={JSON.stringify({
		opacity: [0, 1],
		scale: [.9, 1]
	})}>
	<div id={Ids.PageStopwatch} class={Styles.PageStopwatch}>
		<h2>
			<span
				id={Ids.PageStopwatchHHMMSS}>{textHHMMSS(Constant.DEFAULT_STOPWATCH_MS)}</span
			>,<small id={Ids.PageStopwatchMS}>{textMS(Constant.DEFAULT_STOPWATCH_MS)}</small>
		</h2>
		<div data-css="actions">
			<br-focusgroup br:direction="horizontal">
				<button
					style="width:6rem"
					id={Ids.PageStopwatchPlayPause}
					br:variant="filled">
					<br-icon set:html={Constant.DEFAULT_STOPWATCH_RUNNING? Icons.PauseFilled : Icons.PlayFilled}/>
					<span>{Constant.DEFAULT_STOPWATCH_RUNNING? 'Pause' : 'Start'}</span>
				</button>
				<button
					style={Constant.DEFAULT_STOPWATCH_MS > 0? undefined : "display:none"}
					id={Ids.PageStopwatchResetLap}
					br:variant="tonal icon"
					br:tooltip={Constant.DEFAULT_STOPWATCH_RUNNING? 'Lap' : 'Reset'}
					aria-label={Constant.DEFAULT_STOPWATCH_RUNNING? 'Lap' : 'Reset'}>
					<br-icon set:html={Constant.DEFAULT_STOPWATCH_RUNNING? Icons.Flag : Icons.ArrowReset}/>
				</button>
				<button
					style={Constant.DEFAULT_STOPWATCH_LAPS.length > 0? undefined : "display:none"}
					id={Ids.PageStopwatchMoreBtn}
					br:command-for={Ids.PageStopwatchMorePopover}
					br:variant="tonal icon"
					br:tooltip="More actions"
					aria-label="More actions">
					<br-icon set:html={Icons.MoreVertical}/>
				</button>
			</br-focusgroup>
		</div>
		<div
			data-css="laps"
			style={Constant.DEFAULT_STOPWATCH_LAPS.length > 0? 'display:flex' : undefined}
			id={Ids.PageStopwatchLaps}>
			<table>
				<thead>
					<tr>
						<th>Laps</th>
						<th>Time</th>
						<th>Total</th>
					</tr>
				</thead>
				<tbody id={Ids.PageStopwatchLapsContent}>
					{Constant.DEFAULT_STOPWATCH_LAPS.map((v, i) =>
						<tr tabindex="0">
							<td>{Constant.DEFAULT_STOPWATCH_LAPS.length - i}</td>
							<td>{i < Constant.DEFAULT_STOPWATCH_LAPS.length-1
								? msText(v - Constant.DEFAULT_STOPWATCH_LAPS[i + 1])
								: msText(v)
							}</td>
							<td>{msText(v)}</td>
						</tr>
					)}
				</tbody>
			</table>
		</div>
	</div>
	<br-popover id={Ids.PageStopwatchMorePopover}>
		<br-focusgroup br:direction="vertical">
			<menu>
				<li><button
					data-command={Commands.PageStopwatchCopyLapAll}>
					<br-icon set:html={Icons.Copy}/>
					Copy all
				</button></li>
				<li><button
					data-command={Commands.PageStopwatchCopyLapTime}>
					<br-icon set:html={Icons.Copy}/>
					Copy time
				</button></li>
				<li><button
					data-command={Commands.PageStopwatchCopyLapTotal}>
					<br-icon set:html={Icons.Copy}/>
					Copy total
				</button></li>
				<li><hr/></li>
				<li><button
					data-command={Commands.PageStopwatchCopyLapAllMS}>
					<br-icon set:html={Icons.Copy}/>
					Copy all (ms)
				</button></li>
				<li><button
					data-command={Commands.PageStopwatchCopyLapTimeMS}>
					<br-icon set:html={Icons.Copy}/>
					Copy time (ms)
				</button></li>
				<li><button
					data-command={Commands.PageStopwatchCopyLapTotalMS}>
					<br-icon set:html={Icons.Copy}/>
					Copy total (ms)
				</button></li>
			</menu>
		</br-focusgroup>
	</br-popover>
</br-if>