---
import * as Icons from '@/enums/icons.enum.js'
import * as BrNavigation from '@/web-components/components/br-navigation.server.js'
import * as Ids from '../_scripts/shared/ids.enum.js'
import * as ExternalLinks from '@/enums/external-links.enum.js'
import * as Routes from '@/enums/routes.enum.js'
import * as Constant from '../_scripts/shared/constant.enum.js'
import * as InputNames from '../_scripts/shared/input-names.enum.js'
import * as BrTheme from '@/web-components/components/br-theme.server.js'
import logoRedmerah from '@/assets/images/logos/redmerah-logo.svg'

const THEMES: [text: string, value: string, icon: string][] = [
	['System', BrTheme.ThemeMode.Auto , Icons.LaptopSettings],
	['Light' , BrTheme.ThemeMode.Light, Icons.WeatherSunny  ],
	['Dark'  , BrTheme.ThemeMode.Dark , Icons.WeatherMoon   ],
]
const ANIMATION: [text: string, value: string, icon: string][] = [
	['System', BrTheme.Animation.Auto, Icons.VideoClipOptimize],
	['On'    , BrTheme.Animation.On  , Icons.VideoClip        ],
	['Off'   , BrTheme.Animation.Off , Icons.VideoClipOff     ],
]

const LANGUAGES: [text: string, code: string][] = [
	["Afrikaans", "af"],
	["Akan", "ak"],
	["Amharic", "am"],
	["Arabic", "ar"],
	["Azerbaijani", "az"],
	["Bengali", "bn"],
	["Bosnian", "bs"],
	["Bulgarian", "bg"],
	["Castilian", "es"],
	["Catalan", "ca"],
	["Chinese", "zh"],
	["Croatian", "hr"],
	["Czech", "cs"],
	["Danish", "da"],
	["Dutch", "nl"],
	["Flemish", "nl"],
	["English", "en"],
	["Estonian", "et"],
	["Finnish", "fi"],
	["French", "fr"],
	["German", "de"],
	["Greek", "el"],
	["Gujarati", "gu"],
	["Hebrew", "he"],
	["Hindi", "hi"],
	["Hungarian", "hu"],
	["Indonesian", "id"],
	["Italian", "it"],
	["Japanese", "ja"],
	["Kannada", "kn"],
	["Korean", "ko"],
	["Latvian", "lv"],
	["Lithuanian", "lt"],
	["Malay", "ms"],
	["Malayalam", "ml"],
	["Marathi", "mr"],
	["Moldavian", "ro"],
	["Norwegian", "no"],
	["Persian", "fa"],
	["Polish", "pl"],
	["Portuguese", "pt"],
	["Panjabi", "pa"],
	["Punjabi", "pa"],
	["Romanian", "ro"],
	["Russian", "ru"],
	["Serbian", "sr"],
	["Sindhi", "sd"],
	["Slovak", "sk"],
	["Slovenian", "sl"],
	["Spanish", "es"],
	["Swahili", "sw"],
	["Swedish", "sv"],
	["Tagalog", "tl"],
	["Tamil", "ta"],
	["Telugu", "te"],
	["Thai", "th"],
	["Turkish", "tr"],
	["Ukranian", "uk"],
	["Urdu", "ur"],
	["Uzbek", "uz"],
	["Valencian", "ca"],
	["Vietnamese", "vi"],
]
---
<br-appbar slot="appbar">
	<br-if
		br:media={`(width < ${BrNavigation.SCREEN_SIZE_MEDIUM_MIN_IN_REM}rem)`}
		slot="leading">
		<button
			aria-label="Toggle navigation"
			br:tooltip="Toggle navigation"
			style="margin: 0 .5rem 0 0"
			br:command-for={Ids.Navigation}>
			<br-icon set:html={Icons.LineHorizontal3}/>
		</button>
	</br-if>
	<img
		slot="headline"
		src={Constant.APP.logoUrl}
		alt={Constant.APP.name + ' logo'}
		style="width: 1.5rem;margin-right: .5rem;"
	/>
	<span slot="headline">{Constant.APP.name}</span>
	<br-focusgroup br:direction="horizontal" slot="trailing">
		<button
			aria-label="Info"
			br:tooltip="Info"
			br:variant="icon"
			style="margin: 0 0 0 .5rem"
			br:command-for={Ids.PopoverAppBarInfo}>
			<br-icon set:html={Icons.Info}/>
		</button>
		<br-popover id={Ids.PopoverAppBarInfo}>
			<br-focusgroup br:direction="vertical">
				<menu>
					<li style="margin-left:1rem;padding-top:.5rem;opacity:.75"><small>{Constant.APP.name}</small></li>
					<li><button id={Ids.PopoverAppBarInfoShare}>
						<br-icon set:html={Icons.ShareAndroid}/>
						Share
					</button></li>
					<li><a br:as="button" href={'mailto:' + ExternalLinks.ContactEmail + '?subject=' + encodeURI(Constant.APP.name)}>
						<br-icon set:html={Icons.Chat}/>
						Send feedback
					</a></li>
					<li><hr/></li>
					<li><a br:as="button" href={Routes.Home}>
						<img src={logoRedmerah.src} style="width:1.25rem"/>
						Redmerah
					</a></li>
					<li><a br:as="button" href={Routes.Apps}>
						<br-icon set:html={Icons.Apps}/>
						More apps
					</a></li>
					<li><a br:as="button" href={Routes.About}>
						<br-icon set:html={Icons.Info}/>
						About us
					</a></li>
					<li><a br:as="button" rel="noopener noreferrer" target="_blank" href={'https://github.com/msulais/redmerah/tree/main/src/pages' + Constant.APP.link}>
						<br-icon set:html={Icons.Code}/>
						Repository
					</a></li>
					<li><a br:as="button" rel="noopener noreferrer" target="_blank" href={ExternalLinks.Donate}>
						<br-icon set:html={Icons.Gift}/>
						Donate
					</a></li>
					<li style="margin-left:1rem;padding-bottom:.5rem;opacity:.75"><small>&copy; {new Date().getFullYear()} Redmerah</small></li>
				</menu>
			</br-focusgroup>
		</br-popover>

		<button
			aria-label="Settings"
			br:tooltip="Settings"
			br:variant="icon"
			br:command-for={Ids.PopoverAppBarSettings}
			style="margin: 0 0 0 .25rem">
			<br-icon set:html={Icons.Settings}/>
		</button>
		<br-popover id={Ids.PopoverAppBarSettings}>
			<br-focusgroup br:direction="vertical">
				<menu>
					<li>
						<button br:prevent-default br:command-for={Ids.PopoverAppBarSettingsAnimation}>
							<br-icon set:html={Icons.PlayCircleHint}/>
							Animation
							<div style="flex:1"/>
							<br-icon set:html={Icons.ChevronRight}/>
						</button>
						<br-popover br:submenu id={Ids.PopoverAppBarSettingsAnimation}>
							<menu>
								{ANIMATION.map(v => <li><label br:as="button">
									<input
										checked={v[1] === Constant.DEFAULT_ANIMATION}
										value={v[1]}
										type="radio"
										name={InputNames.Animation}
									/>
									<br-icon set:html={v[2]}/>
									{v[0]}
								</label></li>)}
							</menu>
						</br-popover>
					</li>
					<li>
						<button br:prevent-default br:command-for={Ids.PopoverAppBarSettingsTheme}>
							<br-icon set:html={Icons.WeatherSunny}/>
							Theme
							<div style="flex:1"/>
							<br-icon set:html={Icons.ChevronRight}/>
						</button>
						<br-popover br:submenu id={Ids.PopoverAppBarSettingsTheme}>
							<menu>
								{THEMES.map(v => <li><label br:as="button">
									<input
										checked={v[1] === Constant.DEFAULT_THEME}
										value={v[1]}
										type="radio"
										name={InputNames.Theme}
									/>
									<br-icon set:html={v[2]}/>
									{v[0]}
								</label></li>)}
							</menu>
						</br-popover>
					</li>
					<li>
						<button br:prevent-default br:command-for={Ids.PopoverAppBarSettingsDatetimeLanguage}>
							<br-icon set:html={Icons.Translate}/>
							Datetime language
							<div style="flex:1"/>
							<br-icon set:html={Icons.ChevronRight}/>
						</button>
						<br-popover br:submenu id={Ids.PopoverAppBarSettingsDatetimeLanguage}>
							<menu>
								{LANGUAGES.map(v => <li><label br:as="button">
									<input
										checked={v[1] === Constant.DEFAULT_LANGUAGE_CODE}
										value={v[1]}
										type="radio"
										name={InputNames.Language}
									/>
									{v[0]}
								</label></li>)}
							</menu>
						</br-popover>
					</li>
				</menu>
			</br-focusgroup>
		</br-popover>
	</br-focusgroup>
</br-appbar>