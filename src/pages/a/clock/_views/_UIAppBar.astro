---
import AppBar from '@/components/AppBar/index.astro'
import IconButton from '@/components/Button/IconButton.astro'
import Menu from '@/components/Menu/index.astro'
import SubMenu from '@/components/Menu/SubMenu.astro'
import SubMenuItem from '@/components/Menu/SubMenuItem.astro'
import RadioMenuItem from '@/components/Menu/RadioMenuItem.astro'
import CheckMenuItem from '@/components/Menu/CheckMenuItem.astro'
import MenuHeader from '@/components/Menu/MenuHeader.astro'
import MenuItem from '@/components/Menu/MenuItem.astro'
import MenuIndent from '@/components/Menu/MenuIndent.astro'
import Icon from '@/components/Icon/index.astro'
import LinkMenuItem from '@/components/Menu/LinkMenuItem.astro'
import Divider from '@/components/Divider/index.astro'
import { PlatformAnimationMode, PlatformThemeMode } from '@/enums/platforms'
import logoRedmerah from '@/assets/images/logos/redmerah-logo.svg'
import { RoutesLinks, ExternalLinks } from '@/enums/links'
import { IconCodes } from '@/enums/icons'
import { ElementIds } from '../_scripts/shared/ids'
import { RadioNames } from '../_scripts/shared/input-names'
import { DEFAULT_ANIMATION, DEFAULT_KEEP_AWAKE, DEFAULT_THEME, APP, DEFAULT_LANGUAGE_CODE } from '../_scripts/shared/constant'
import { pxToRem } from '@/utils/css'
import { CSSClasses } from '../_styles/classes'

const languages = [
	["Afrikaans", "af"],
	["Akan", "ak"],
	["Amharic", "am"],
	["Arabic", "ar"],
	["Azerbaijani", "az"],
	["Bengali", "bn"],
	["Bosnian", "bs"],
	["Bulgarian", "bg"],
	["Castilian", "es"],
	["Catalan", "ca"],
	["Chinese", "zh"],
	["Croatian", "hr"],
	["Czech", "cs"],
	["Danish", "da"],
	["Dutch", "nl"],
	["Flemish", "nl"],
	["English", "en"],
	["Estonian", "et"],
	["Finnish", "fi"],
	["French", "fr"],
	["German", "de"],
	["Greek", "el"],
	["Gujarati", "gu"],
	["Hebrew", "he"],
	["Hindi", "hi"],
	["Hungarian", "hu"],
	["Indonesian", "id"],
	["Italian", "it"],
	["Japanese", "ja"],
	["Kannada", "kn"],
	["Korean", "ko"],
	["Latvian", "lv"],
	["Lithuanian", "lt"],
	["Malay", "ms"],
	["Malayalam", "ml"],
	["Marathi", "mr"],
	["Moldavian", "ro"],
	["Norwegian", "no"],
	["Persian", "fa"],
	["Polish", "pl"],
	["Portuguese", "pt"],
	["Panjabi", "pa"],
	["Punjabi", "pa"],
	["Romanian", "ro"],
	["Russian", "ru"],
	["Serbian", "sr"],
	["Sindhi", "sd"],
	["Slovak", "sk"],
	["Slovenian", "sl"],
	["Spanish", "es"],
	["Swahili", "sw"],
	["Swedish", "sv"],
	["Tagalog", "tl"],
	["Tamil", "ta"],
	["Telugu", "te"],
	["Thai", "th"],
	["Turkish", "tr"],
	["Ukranian", "uk"],
	["Urdu", "ur"],
	["Uzbek", "uz"],
	["Valencian", "ca"],
	["Vietnamese", "vi"],
]

const animations: {
	value: PlatformAnimationMode
	text: string
	icon: number
}[] = [
	{
		value: PlatformAnimationMode.Auto,
		text: 'Automatic',
		icon: IconCodes.VideoClipOptimize
	},
	{
		value: PlatformAnimationMode.On,
		text: 'On',
		icon: IconCodes.VideoClip
	},
	{
		value: PlatformAnimationMode.Off,
		text: 'Off',
		icon: IconCodes.VideoClipOff
	},
]
const themes: {
	value: PlatformThemeMode
	text: string
	icon: number
}[] = [
	{
		value: PlatformThemeMode.Auto,
		text: 'Automatic',
		icon: IconCodes.LaptopSettings
	},
	{
		value: PlatformThemeMode.Light,
		text: 'Light',
		icon: IconCodes.WeatherSunny
	},
	{
		value: PlatformThemeMode.Dark,
		text: 'Dark',
		icon: IconCodes.WeatherMoon
	},
]
---

<AppBar
	id={ElementIds.appbar}
	AppBarLeadingAttr={{class: CSSClasses.smallScreenOnly}}>
	<Fragment slot="leading">
		<IconButton
			class={CSSClasses.smallScreenOnly}
			id={ElementIds.ap_openDrawerBtn}
			IconButtonCode={IconCodes.LineHorizontal3}
		/>
	</Fragment>
	<Fragment slot="headline">
		<img
			src={APP.logoUrl}
			alt={APP.name + ' logo'}
			style={{
				width: pxToRem(24) + 'rem',
				marginLeft: pxToRem(4) + 'rem'
			}}
		/>
		{APP.name}
	</Fragment>
	<Fragment slot="trailing">
		<IconButton
			id={ElementIds.apInf_btn}
			data-tooltip="Info"
			aria-label="Info"
			IconButtonCode={IconCodes.Info}
			popovertarget={ElementIds.apInf_menu}
		/>
		<Menu id={ElementIds.apInf_menu} PopoverAnchorBy={ElementIds.apInf_btn}>
			<MenuHeader>{APP.name}</MenuHeader>
			<MenuItem id={ElementIds.apInf_shareBtn}>
				<Icon IconCode={IconCodes.ShareAndroid}/>
				Share
			</MenuItem>
			<LinkMenuItem href={'mailto:' + ExternalLinks.ContactEmail + '?subject=' + encodeURI(APP.name)}>
				<Icon IconCode={IconCodes.Chat}/>
				Send feedback
			</LinkMenuItem>
			<Divider />
			<LinkMenuItem href="/">
				<img src={logoRedmerah.src} style={{width: pxToRem(20) + 'rem'}}/>
				Redmerah
			</LinkMenuItem>
			<LinkMenuItem href={RoutesLinks.Apps}>
				<Icon IconCode={IconCodes.Apps}/>
				More apps
			</LinkMenuItem>
			<LinkMenuItem href={RoutesLinks.About}>
				<Icon IconCode={IconCodes.Info}/>
				About us
			</LinkMenuItem>
			<LinkMenuItem href={RoutesLinks.Privacy}>
				<Icon IconCode={IconCodes.ShieldCheckmark}/>
				Privacy policy
			</LinkMenuItem>
			<LinkMenuItem href={RoutesLinks.Terms}>
				<Icon IconCode={IconCodes.Receipt}/>
				Terms & conditions
				<MenuIndent />
			</LinkMenuItem>
			<LinkMenuItem href={ExternalLinks.Donate} LinkButtonNewTab>
				<Icon IconCode={IconCodes.Gift}/>
				Donate
			</LinkMenuItem>
			<MenuHeader>&copy; {new Date().getFullYear()} Redmerah</MenuHeader>
		</Menu>

		<IconButton
			id={ElementIds.apSett_btn}
			data-tooltip="Settings"
			IconButtonCode={IconCodes.Settings}
			aria-label="Settings"
			popovertarget={ElementIds.apSett_menu}
		/>
		<Menu id={ElementIds.apSett_menu} PopoverAnchorBy={ElementIds.apSett_btn}>
			<SubMenuItem
				popovertarget={ElementIds.apSett_animationMenu}>
				<Icon IconCode={IconCodes.PlayCircleHint}/>
				Animation
				<div style="flex:1"/>
				<Icon IconCode={IconCodes.ChevronRight}/>
			</SubMenuItem>
			<SubMenu
				style={{
					width: pxToRem(150) + 'rem'
				}}
				id={ElementIds.apSett_animationMenu}>
				{animations.map(v =>
					<RadioMenuItem
						RadioMenuItemName={RadioNames.Animation}
						RadioMenuItemChecked={DEFAULT_ANIMATION === v.value}
						RadioMenuItemValue={v.value}>
						<Icon IconCode={v.icon}/>
						{v.text}
					</RadioMenuItem>
				)}
			</SubMenu>

			<SubMenuItem
				popovertarget={ElementIds.apSett_themeMenu}>
				<Icon IconCode={IconCodes.WeatherSunny}/>
				Theme
				<div style="flex:1"/>
				<Icon IconCode={IconCodes.ChevronRight}/>
			</SubMenuItem>
			<SubMenu
				style={{
					width: pxToRem(150) + 'rem'
				}}
				id={ElementIds.apSett_themeMenu}>
				{themes.map(v =>
					<RadioMenuItem
						RadioMenuItemName={RadioNames.Theme}
						RadioMenuItemChecked={DEFAULT_THEME === v.value}
						RadioMenuItemValue={v.value}>
						<Icon IconCode={v.icon}/>
						{v.text}
					</RadioMenuItem>
				)}
			</SubMenu>

			<SubMenuItem
				popovertarget={ElementIds.apSett_languageMenu}>
				<Icon IconCode={IconCodes.Translate}/>
				Datetime language
				<div style="flex:1"/>
				<Icon IconCode={IconCodes.ChevronRight}/>
			</SubMenuItem>
			<SubMenu
				style={{
					width: pxToRem(192) + 'rem',
				}}
				id={ElementIds.apSett_languageMenu}>
				{languages.map(v =>
					<RadioMenuItem
						RadioMenuItemName={RadioNames.Language}
						RadioMenuItemChecked={DEFAULT_LANGUAGE_CODE === v[1]}
						RadioMenuItemValue={v[1]}>
						{v[0]}
					</RadioMenuItem>
				)}
			</SubMenu>

			<Divider />
			<CheckMenuItem
				CheckMenuItemInputAttr={{id: ElementIds.apSett_keepAwake}}
				CheckMenuItemChecked={DEFAULT_KEEP_AWAKE}>
				Keep awake
				<div style="flex:1"/>
				<MenuIndent />
			</CheckMenuItem>
		</Menu>
	</Fragment>
</AppBar>