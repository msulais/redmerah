---
import * as Ids from '../_scripts/shared/ids.enum.js'
import * as Pages from '../_scripts/shared/pages.enum.js'
import * as Constant from '../_scripts/shared/constant.enum.js'
import * as Icons from '@/enums/icons.enum.js'
import * as Styles from '../_styles/styles.enum.js'
import ringtone from '@/assets/audio/simple-ringtone-84595.mp3'

const HOURS = Math.floor(Constant.DEFAULT_TIMER_SECONDS / 3600)
const MINUTES = Math.floor(Math.floor(Constant.DEFAULT_TIMER_SECONDS % 3600) / 60)
const SECONDS = Math.floor(Math.floor(Constant.DEFAULT_TIMER_SECONDS % 3600) % 60)
---

<br-view
	br:query={`page=${Pages.Timer}`}
	br:animation-for={Ids.PageTimer}
	br:animation-start-duration="500"
	br:animation-start-keyframes={JSON.stringify({
		opacity: [0, 1],
		scale: [.9, 1]
	})}>
	<div id={Ids.PageTimer} class={Styles.PageTimer}>
		<h2 id={Ids.PageTimerTime}>{
			[HOURS, MINUTES, SECONDS].map(v => v.toString().padStart(2, '0')).join(':')
		}</h2>
		<audio id={Ids.PageTimerAudio} loop src={ringtone}></audio>
		<div>
			<button style="width:5.75rem" br:variant="filled" id={Ids.PageTimerPlayPause}>
				<br-icon set:html={Constant.DEFAULT_TIMER_RUNNING? Icons.PauseFilled : Icons.PlayFilled}/>
				<span>{Constant.DEFAULT_TIMER_RUNNING? 'Pause' : 'Start'}</span>
			</button>
			<button
				style={Constant.DEFAULT_TIMER_RUNNING? 'display:none' : undefined}
				id={Ids.PageTimerEditReset}
				br:variant="tonal icon"
				br:tooltip="Edit timer"
				aria-label="Edit timer">
				<br-icon set:html={Icons.Edit}/>
			</button>
		</div>
	</div>
	<br-dialog
		id={Ids.PageTimerEditDialog}
		style="width:22.5rem">
		<span slot="title">Edit Timer</span>
		<div style={{
			display: 'grid',
			gridTemplateColumns: 'repeat(3,1fr)',
			gap: '.5rem',
			marginBottom: '.25rem'
		}}>
			<label for={Ids.PageTimerHours}>Hours:</label>
			<label for={Ids.PageTimerMinutes}>Minutes:</label>
			<label for={Ids.PageTimerSeconds}>Seconds:</label>
		</div>
		<div style={{
			display: 'grid',
			gridTemplateColumns: 'repeat(3,1fr)',
			gap: '.5rem',
		}}>
			<input br:as="textfield" type="number" min="0" max="99" value={HOURS} id={Ids.PageTimerHours}/>
			<input br:as="textfield" type="number" min="0" max="99" value={MINUTES} id={Ids.PageTimerMinutes}/>
			<input br:as="textfield" type="number" min="0" max="99" value={SECONDS} id={Ids.PageTimerSeconds}/>
		</div>
		<button
			slot="footer"
			br:variant="tonal"
			br:command-for={Ids.PageTimerEditDialog}>
			Cancel
		</button>
		<button
			slot="footer"
			id={Ids.PageTimerSave}
			br:variant="filled"
			br:command-for={Ids.PageTimerEditDialog}>
			Save
		</button>
	</br-dialog>
	<br-dialog
		id={Ids.PageTimerDoneDialog}
		style="width:22.5rem">
		<span slot="title">Timer Done</span>
		<p id={Ids.PageTimerDoneTime}></p>
		<p id={Ids.PageTimerDoneDate}></p>
		<button
			slot="footer"
			br:variant="filled"
			br:command-for={Ids.PageTimerDoneDialog}>
			Dismiss
		</button>
	</br-dialog>
</br-view>