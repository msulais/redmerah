---
import { DEFAULT_PAGE } from '../../_scripts/shared/constant'
import { Pages } from '../../_scripts/shared/enums'
import { ElementIds } from '../../_scripts/shared/ids'
import { CSSClasses } from '../../_styles/classes'
---

<div
	id={ElementIds.pg_clock}
	class={[CSSClasses.bodyPage, CSSClasses.bodyPageClock].join(' ')}
	role="tabpanel"
	hidden={DEFAULT_PAGE !== Pages.Clock}>
	<h2 id={ElementIds.pgClk_time}>{new Date().toLocaleTimeString('en', {hour: 'numeric', minute: 'numeric', second: 'numeric', hour12: false})}</h2>
	<p id={ElementIds.pgClk_date}>{new Date().toLocaleDateString('en', {year: 'numeric', month: 'long', day: 'numeric', weekday: 'long'})}</p>
</div>