---
import * as Constant from './_scripts/shared/constant'
import Html2 from '@/layouts/Html2/index.astro'
import AppBar from './_views/_AppBar.astro'
import Navigation from './_views/_Navigation.astro'
---

<Html2
	title={Constant.APP.name + ' • Redmerah'}
	accentColor={Constant.APP.color}
	description={Constant.APP.description}>
	<Fragment slot="favicon">
		<link rel="shortcut icon" type="image/ico" href={`/favicon${Constant.APP.link}/favicon.ico`} />
		<link rel="apple-touch-icon" sizes="180x180" href={`/favicon${Constant.APP.link}/apple-touch-icon.png`}>
		<link rel="icon" type="image/png" sizes="32x32" href={`/favicon${Constant.APP.link}/favicon-32x32.png`}>
		<link rel="icon" type="image/png" sizes="16x16" href={`/favicon${Constant.APP.link}/favicon-16x16.png`}>
		<link rel="manifest" href={`/favicon${Constant.APP.link}/site.webmanifest`}>
	</Fragment>
	<br-scaffold>
		<AppBar />
		<Navigation/>
	</br-scaffold>
	<script src="@/web-components/components/br-scaffold.ts"/>
	<script src="@/web-components/components/br-view.ts"/>
	<script src="@/web-components/components/br-icon.ts"/>
	<script src="@/web-components/components/br-appbar.ts"/>
	<script src="@/web-components/components/br-popover.ts"/>
	<script src="@/web-components/components/br-navigation.ts"/>
	<script src="@/web-components/components/menu.ts"/>
	<script src="@/web-components/components/navigationitem.ts"/>
	<script src="@/web-components/components/button.ts"/>
	<script src="./_scripts/index.ts"/>
</Html2>