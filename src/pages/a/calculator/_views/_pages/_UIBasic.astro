---
import Button from '@/components/Button/index.astro'
import Icon from '@/components/Icon/index.astro'
import { CButton } from '@/components/Button'
import { AppCSSColors } from '@/enums/app-data'
import { IconCodes } from '@/enums/icons'
import { ElementIds } from '../../_scripts/_shared/_ids'
import { Commands } from '../../_scripts/_shared/_commands'
import { CSSClasses } from "../../_styles/_css"
import { Pages } from '../../_scripts/_shared/_enums'
import { DEFAULT_BASIC_INPUT, DEFAULT_BASIC_OUTPUT, DEFAULT_PAGE } from '../../_scripts/_shared/_constant'
---
<div
	class={CSSClasses.bd_page}
	role="tabpanel"
	id={ElementIds.pg_basic}
	hidden={DEFAULT_PAGE !== Pages.basic}>
	<div class={CSSClasses.bdPage_input}>
		<input
			id={ElementIds.pgBas_input}
			readonly
			placeholder="0"
			value={DEFAULT_BASIC_INPUT}
			class={CSSClasses.bd_inField}
		/>
		<input
			id={ElementIds.pgBas_output}
			readonly
			value={DEFAULT_BASIC_OUTPUT ?? '0'}
			class={CSSClasses.bd_outField}
		/>
	</div>
	<div class={CSSClasses.bdPage_options}>
		<div class={CSSClasses.bdPage_optionGroup}>
			<Button data-command={Commands.memo_clear} data-tooltip="Memory clear (Ctrl+Shift+C)">MC</Button>
			<Button data-command={Commands.memo_add} data-tooltip="Memory add (Ctrl+Shift+&quot;+&quot;)">M+</Button>
			<Button data-command={Commands.memo_sub} data-tooltip="Memory subtract (Ctrl+Shift+&quot;-&quot;)">M-</Button>
			<Button class={CSSClasses.bdPage_memoPreview} data-command={Commands.memo_recall} data-tooltip="Memory recall (Ctrl+Shift+R)">MR: 0</Button>
		</div>
	</div>
	<div class={CSSClasses.bdPage_buttons} style="grid-template-columns: repeat(4, 1fr);">
		<Button data-command={Commands.key_char} data-char="%" ButtonVariant={CButton.Variant.tonal}>%</Button>
		<Button data-command={Commands.key_char} data-char="√" ButtonVariant={CButton.Variant.tonal}>√</Button>
		<Button data-command={Commands.key_clear} ButtonVariant={CButton.Variant.tonal} style={`color:rgb(${AppCSSColors.accent})`}>C</Button>
		<Button data-command={Commands.key_backspace} ButtonVariant={CButton.Variant.tonal} style={`color:rgb(${AppCSSColors.accent})`}><Icon IconCode={IconCodes.backspace}/></Button>

		<Button data-command={Commands.key_char} data-char="7" data-type="number" ButtonVariant={CButton.Variant.tonal}>7</Button>
		<Button data-command={Commands.key_char} data-char="8" data-type="number" ButtonVariant={CButton.Variant.tonal}>8</Button>
		<Button data-command={Commands.key_char} data-char="9" data-type="number" ButtonVariant={CButton.Variant.tonal}>9</Button>
		<Button data-command={Commands.key_char} data-char="÷" ButtonVariant={CButton.Variant.tonal}><Icon IconCode={IconCodes.slashForward}/></Button>

		<Button data-command={Commands.key_char} data-char="4" data-type="number" ButtonVariant={CButton.Variant.tonal}>4</Button>
		<Button data-command={Commands.key_char} data-char="5" data-type="number" ButtonVariant={CButton.Variant.tonal}>5</Button>
		<Button data-command={Commands.key_char} data-char="6" data-type="number" ButtonVariant={CButton.Variant.tonal}>6</Button>
		<Button data-command={Commands.key_char} data-char="×" ButtonVariant={CButton.Variant.tonal}><Icon IconCode={IconCodes.dismiss}/></Button>

		<Button data-command={Commands.key_char} data-char="1" data-type="number" ButtonVariant={CButton.Variant.tonal}>1</Button>
		<Button data-command={Commands.key_char} data-char="2" data-type="number" ButtonVariant={CButton.Variant.tonal}>2</Button>
		<Button data-command={Commands.key_char} data-char="3" data-type="number" ButtonVariant={CButton.Variant.tonal}>3</Button>
		<Button data-command={Commands.key_char} data-char="-" ButtonVariant={CButton.Variant.tonal}><Icon IconCode={IconCodes.lineHorizontal1}/></Button>

		<Button data-command={Commands.key_char} data-char="0" data-type="number" ButtonVariant={CButton.Variant.tonal}>0</Button>
		<Button data-command={Commands.key_dec} ButtonVariant={CButton.Variant.tonal}>.</Button>
		<Button data-command={Commands.key_equal} ButtonVariant={CButton.Variant.filled} style="font-weight:bold">=</Button>
		<Button data-command={Commands.key_char} data-char="+" ButtonVariant={CButton.Variant.tonal}><Icon IconCode={IconCodes.add}/></Button>
	</div>
</div>