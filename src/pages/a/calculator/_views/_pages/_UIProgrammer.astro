---
import Button from '@/components/Button/index.astro'
import Icon from '@/components/Icon/index.astro'
import { CSSClasses } from "../../_styles/classes"
import { AppCSSColors } from '@/enums/app-data'
import { CButton } from '@/components/Button'
import { IconCodes } from '@/enums/icons'
import { ElementIds } from '../../_scripts/shared/ids'
import { Commands } from '../../_scripts/shared/commands'
import { NumberType, Pages } from '../../_scripts/shared/enums'
import { DEFAULT_PAGE, DEFAULT_PROGRAMMER_INPUT, DEFAULT_PROGRAMMER_NUMBER_TYPE, DEFAULT_PROGRAMMER_OUTPUT } from '../../_scripts/shared/constant'
const btnVal = CSSClasses.bdPageProg_btnValue
const btnHex = CSSClasses.bdPageProg_btnHex
const btnDec = CSSClasses.bdPageProg_btnDec
const btnOct = CSSClasses.bdPageProg_btnOct
const btnBin = CSSClasses.bdPageProg_btnBin
const types: {id: string, type: NumberType, text: string, value: string | number}[] = [
	{
		id: ElementIds.pgPro_outHex,
		type: NumberType.Hexadecimal,
		text: 'HEX',
		value: DEFAULT_PROGRAMMER_OUTPUT?.toString(16).toUpperCase() ?? '0'
	},
	{
		id: ElementIds.pgPro_outDec,
		type: NumberType.Decimal,
		text: 'DEC',
		value: DEFAULT_PROGRAMMER_OUTPUT ?? '0'
	},
	{
		id: ElementIds.pgPro_outOct,
		type: NumberType.Octal,
		text: 'OCT',
		value: DEFAULT_PROGRAMMER_OUTPUT?.toString(8) ?? '0'
	},
	{
		id: ElementIds.pgPro_outBin,
		type: NumberType.Binary,
		text: 'BIN',
		value: DEFAULT_PROGRAMMER_OUTPUT?.toString(2) ?? '0'
	},
]
---
<div
	class={CSSClasses.bd_page}
	role="tabpanel"
	id={ElementIds.pg_programmer}
	hidden={DEFAULT_PAGE !== Pages.Orogrammer}>
	<div class={CSSClasses.bdPage_input}>
		<input
			type="text"
			readonly
			placeholder="0"
			id={ElementIds.pgPro_input}
			class={CSSClasses.bd_inField}
			value={DEFAULT_PROGRAMMER_INPUT}
		/>
		<div
			style="display:contents"
			role="listbox"
			aria-activedescendant={
				DEFAULT_PROGRAMMER_NUMBER_TYPE === NumberType.Hexadecimal
					? ElementIds.pgPro_outHex
				: DEFAULT_PROGRAMMER_NUMBER_TYPE === NumberType.Decimal
					? ElementIds.pgPro_outDec
				: DEFAULT_PROGRAMMER_NUMBER_TYPE === NumberType.Octal
					? ElementIds.pgPro_outOct
				: DEFAULT_PROGRAMMER_NUMBER_TYPE === NumberType.Binary
					? ElementIds.pgPro_outBin
				: ''}
			id={ElementIds.pgPro_output}>
			{types.map(v =>
				<div
					id={v.id}
					class={CSSClasses.bdPageProg_outputGroup}
					role="option"
					aria-selected={DEFAULT_PROGRAMMER_NUMBER_TYPE === v.type}>
					<input
						type="text"
						value={v.value}
						readonly
					/>
					<Button ButtonVariant={DEFAULT_PROGRAMMER_NUMBER_TYPE === v.type? CButton.Variant.Filled : undefined}>{v.text}</Button>
				</div>
			)}
		</div>
	</div>
	<div class={CSSClasses.bdPage_options}>
		<div class={CSSClasses.bdPage_optionGroup}>
			<Button data-command={Commands.MemoClear} data-tooltip="Memory clear (Ctrl+Shift+C)">MC</Button>
			<Button data-command={Commands.MemoAdd} data-tooltip="Memory add (Ctrl+Shift+&quot;+&quot;)">M+</Button>
			<Button data-command={Commands.MemoSub} data-tooltip="Memory subtract (Ctrl+Shift+&quot;-&quot;)">M-</Button>
			<Button class={CSSClasses.bdPage_memoPreview} data-command={Commands.MemoRecall} data-tooltip="Memory recall (Ctrl+Shift+R)">MR: 0</Button>
		</div>
	</div>
	<div class={CSSClasses.bdPage_buttons} style="grid-template-columns: repeat(5, 1fr);">
		<Button data-command={Commands.KeyPlusMin} ButtonVariant={CButton.Variant.Tonal}>±</Button>
		<Button data-command={Commands.KeyChar} data-char="(" ButtonVariant={CButton.Variant.Tonal}>(</Button>
		<Button data-command={Commands.KeyChar} data-char=")" ButtonVariant={CButton.Variant.Tonal}>)</Button>
		<Button data-command={Commands.KeyClear} ButtonVariant={CButton.Variant.Tonal} style={`color:rgb(${AppCSSColors.Accent})`}>C</Button>
		<Button data-command={Commands.KeyBackspace} ButtonVariant={CButton.Variant.Tonal} style={`color:rgb(${AppCSSColors.Accent})`}><Icon IconCode={IconCodes.Backspace}/></Button>

		<Button data-command={Commands.KeyChar} data-char="F" class={[btnVal, btnHex].join(' ')} data-type="number" disabled ButtonVariant={CButton.Variant.Tonal}>F</Button>
		<Button data-command={Commands.KeyChar} data-char="not(" ButtonVariant={CButton.Variant.Tonal}>not</Button>
		<Button data-command={Commands.KeyChar} data-char="mod" ButtonVariant={CButton.Variant.Tonal}>mod</Button>
		<Button data-command={Commands.KeyChar} data-char="lsh" ButtonVariant={CButton.Variant.Tonal}>lsh</Button>
		<Button data-command={Commands.KeyChar} data-char="rsh" ButtonVariant={CButton.Variant.Tonal}>rsh</Button>

		<Button data-command={Commands.KeyChar} class={[btnVal, btnHex].join(' ')} data-char="E" data-type="number" disabled ButtonVariant={CButton.Variant.Tonal}>E</Button>
		<Button data-command={Commands.KeyChar} data-char="or" ButtonVariant={CButton.Variant.Tonal}>or</Button>
		<Button data-command={Commands.KeyChar} data-char="and" ButtonVariant={CButton.Variant.Tonal}>and</Button>
		<Button data-command={Commands.KeyChar} data-char="xor" ButtonVariant={CButton.Variant.Tonal}>xor</Button>
		<Button data-command={Commands.KeyChar} data-char="^" ButtonVariant={CButton.Variant.Tonal}><Icon IconCode={IconCodes.ChevronUp}/></Button>

		<Button data-command={Commands.KeyChar} class={[btnVal, btnHex].join(' ')} data-char="D" data-type="number" disabled ButtonVariant={CButton.Variant.Tonal}>D</Button>
		<Button data-command={Commands.KeyChar} class={[btnVal, btnHex, btnDec, btnOct].join(' ')} data-char="7" data-type="number" ButtonVariant={CButton.Variant.Tonal}>7</Button>
		<Button data-command={Commands.KeyChar} class={[btnVal, btnHex, btnDec].join(' ')} data-char="8" data-type="number" ButtonVariant={CButton.Variant.Tonal}>8</Button>
		<Button data-command={Commands.KeyChar} class={[btnVal, btnHex, btnDec].join(' ')} data-char="9" data-type="number" ButtonVariant={CButton.Variant.Tonal}>9</Button>
		<Button data-command={Commands.KeyChar} data-char="÷" ButtonVariant={CButton.Variant.Tonal}><Icon IconCode={IconCodes.SlashForward}/></Button>

		<Button data-command={Commands.KeyChar} class={[btnVal, btnHex].join(' ')} data-char="C" data-type="number" disabled ButtonVariant={CButton.Variant.Tonal}>C</Button>
		<Button data-command={Commands.KeyChar} class={[btnVal, btnHex, btnDec, btnOct].join(' ')} data-char="4" data-type="number" ButtonVariant={CButton.Variant.Tonal}>4</Button>
		<Button data-command={Commands.KeyChar} class={[btnVal, btnHex, btnDec, btnOct].join(' ')} data-char="5" data-type="number" ButtonVariant={CButton.Variant.Tonal}>5</Button>
		<Button data-command={Commands.KeyChar} class={[btnVal, btnHex, btnDec, btnOct].join(' ')} data-char="6" data-type="number" ButtonVariant={CButton.Variant.Tonal}>6</Button>
		<Button data-command={Commands.KeyChar} data-char="×" ButtonVariant={CButton.Variant.Tonal}><Icon IconCode={IconCodes.Dismiss}/></Button>

		<Button data-command={Commands.KeyChar} class={[btnVal, btnHex].join(' ')} data-char="B" data-type="number" disabled ButtonVariant={CButton.Variant.Tonal}>B</Button>
		<Button data-command={Commands.KeyChar} class={[btnVal, btnHex, btnDec, btnOct, btnBin].join(' ')} data-char="1" data-type="number" ButtonVariant={CButton.Variant.Tonal}>1</Button>
		<Button data-command={Commands.KeyChar} class={[btnVal, btnHex, btnDec, btnOct].join(' ')} data-char="2" data-type="number" ButtonVariant={CButton.Variant.Tonal}>2</Button>
		<Button data-command={Commands.KeyChar} class={[btnVal, btnHex, btnDec, btnOct].join(' ')} data-char="3" data-type="number" ButtonVariant={CButton.Variant.Tonal}>3</Button>
		<Button data-command={Commands.KeyChar} data-char="-" ButtonVariant={CButton.Variant.Tonal}><Icon IconCode={IconCodes.LineHorizontal1}/></Button>

		<Button data-command={Commands.KeyChar} class={[btnVal, btnHex].join(' ')} data-char="A" data-type="number" disabled ButtonVariant={CButton.Variant.Tonal}>A</Button>
		<Button data-command={Commands.KeyChar} class={[btnVal, btnHex, btnDec, btnOct, btnBin].join(' ')} data-char="0" data-type="number" ButtonVariant={CButton.Variant.Tonal}>0</Button>
		<Button data-command={Commands.KeyDec} class={[btnVal, btnDec].join(' ')} ButtonVariant={CButton.Variant.Tonal}>.</Button>
		<Button data-command={Commands.KeyEqual} ButtonVariant={CButton.Variant.Filled} style="font-weight:bold">=</Button>
		<Button data-command={Commands.KeyChar} data-char="+" ButtonVariant={CButton.Variant.Tonal}><Icon IconCode={IconCodes.Add}/></Button>
	</div>
</div>