---
import Button from '@/components/Button/index.astro'
import Tooltip from '@/components/Tooltip/index.astro'
import Popover from '@/components/Popover/index.astro'
import Icon from '@/components/Icon/index.astro'
import ComboBox from '@/components/ComboBox/index.astro'
import CheckBox from '@/components/CheckBox/index.astro'
import Divider from '@/components/Divider/index.astro'
import ComboBoxOption from '@/components/ComboBox/ComboBoxOption.astro'
import { CSSClasses } from "../../_styles/_css"
import { AppCSSColors } from '@/enums/app-data'
import { CButton } from '@/components/Button'
import { IconCodes } from '@/enums/icons'
import { ElementIds } from '../../_scripts/_shared/_ids'
import { Commands } from '../../_scripts/_shared/_commands'
import { ScientificAngleType } from '../../_scripts/_shared/_enums'
import { Pages } from '../../_scripts/_shared/_enums'
import { DEFAULT_PAGE, DEFAULT_SCIENTIFIC_ANGLE, DEFAULT_SCIENTIFIC_INPUT, DEFAULT_SCIENTIFIC_OUTPUT } from '../../_scripts/_shared/_constant'
import { pxToRem } from '@/utils/css'
import { FlyoutPosition } from '@/enums/position'
---
<div
	class={CSSClasses.bd_page}
	role="tabpanel"
	id={ElementIds.pg_scientific}
	hidden={DEFAULT_PAGE !== Pages.scientific}>
	<div class={CSSClasses.bdPage_input}>
		<input
			id={ElementIds.pgSci_input}
			readonly
			placeholder="0"
			value={DEFAULT_SCIENTIFIC_INPUT}
			class={CSSClasses.bd_inField}
		/>
		<input
			id={ElementIds.pgSci_output}
			readonly
			value={DEFAULT_SCIENTIFIC_OUTPUT ?? '0'}
			class={CSSClasses.bd_outField}
		/>
	</div>
	<div class={CSSClasses.bdPage_options}>
		<div class={CSSClasses.bdPage_optionGroup}>
			<Tooltip>
				<Button data-command={Commands.memo_clear} data-tooltip="Memory clear (Ctrl+Shift+C)">MC</Button>
				<Button data-command={Commands.memo_add} data-tooltip="Memory add (Ctrl+Shift+&quot;+&quot;)">M+</Button>
				<Button data-command={Commands.memo_sub} data-tooltip="Memory subtract (Ctrl+Shift+&quot;-&quot;)">M-</Button>
				<Button class={CSSClasses.bdPage_memoPreview} data-command={Commands.memo_recall} data-tooltip="Memory recall (Ctrl+Shift+R)">MR: 0</Button>
			</Tooltip>
		</div>
		<div class={CSSClasses.bdPage_optionGroup}>
			<Button
				ButtonVariant={CButton.Variant.tonal}
				id={ElementIds.pgSci_fnBtn}
				aria-haspopup="true"
				aria-expanded="false"
				aria-controls={ElementIds.pgSci_fnMenu}
				popovertarget={ElementIds.pgSci_fnMenu}>
				<Icon IconCode={IconCodes.mathFormula}/>
				Functions
				<div style={{
					'min-width': pxToRem(4) + 'rem',
					'max-width': pxToRem(4) + 'rem',
				}}/>
				<Icon IconCode={IconCodes.chevronDown}/>
			</Button>
			<Popover
				popover="manual"
				PopoverDraggable
				PopoverGap={pxToRem(8)}
				PopoverPosition={FlyoutPosition.centerBottomToRight}
				PopoverPadding={pxToRem(16)}
				id={ElementIds.pgSci_fnMenu}
				PopoverAnchorBy={ElementIds.pgSci_fnBtn}>
				<div class={CSSClasses.bdPageSci_menuGrid}>
					<Button data-command={Commands.key_char} data-char="abs(" ButtonVariant={CButton.Variant.tonal}>abs(x)</Button>
					<Button data-command={Commands.key_char} data-char="log(" ButtonVariant={CButton.Variant.tonal}>log(x)</Button>
					<Button data-command={Commands.key_char} data-char="ln(" ButtonVariant={CButton.Variant.tonal}>ln(x)</Button>
					<Button data-command={Commands.key_char} data-char="ceil(" ButtonVariant={CButton.Variant.tonal}>ceil(x)</Button>
					<Button data-command={Commands.key_char} data-char="round(" ButtonVariant={CButton.Variant.tonal}>round(x)</Button>
					<Button data-command={Commands.key_char} data-char="floor(" ButtonVariant={CButton.Variant.tonal}>floor(x)</Button>
				</div>
				<Divider/>
				<div style={{
					padding: `${pxToRem(16)}rem ${pxToRem(16)}rem 0 ${pxToRem(18)}rem`,
					display: 'flex',
					gap: pxToRem(4) + 'rem'
				}}>
					<CheckBox CheckBoxInputAttr={{id: ElementIds.pgSci_fnInv}}>Invers</CheckBox>
					<CheckBox CheckBoxInputAttr={{id: ElementIds.pgSci_fnHyper}}>Hyperbolic</CheckBox>
				</div>
				<div
					style={{
						'padding-top': pxToRem(4) + 'rem'
					}}
					class={CSSClasses.bdPageSci_menuGrid}>
					<Button data-command={Commands.key_char} data-char="sin(" class={CSSClasses.bdPageSci_trigonometry} ButtonVariant={CButton.Variant.tonal}>sin(x)</Button>
					<Button data-command={Commands.key_char} data-char="cos(" class={CSSClasses.bdPageSci_trigonometry} ButtonVariant={CButton.Variant.tonal}>cos(x)</Button>
					<Button data-command={Commands.key_char} data-char="tan(" class={CSSClasses.bdPageSci_trigonometry} ButtonVariant={CButton.Variant.tonal}>tan(x)</Button>
					<Button data-command={Commands.key_char} data-char="csc(" class={CSSClasses.bdPageSci_trigonometry} ButtonVariant={CButton.Variant.tonal}>csc(x)</Button>
					<Button data-command={Commands.key_char} data-char="sec(" class={CSSClasses.bdPageSci_trigonometry} ButtonVariant={CButton.Variant.tonal}>sec(x)</Button>
					<Button data-command={Commands.key_char} data-char="cot(" class={CSSClasses.bdPageSci_trigonometry} ButtonVariant={CButton.Variant.tonal}>cot(x)</Button>
				</div>
			</Popover>
			<ComboBox id={ElementIds.pgSci_angle}>
				<ComboBoxOption
					selected={DEFAULT_SCIENTIFIC_ANGLE === ScientificAngleType.RAD}
					value={ScientificAngleType.RAD}>RAD</ComboBoxOption>
				<ComboBoxOption
					selected={DEFAULT_SCIENTIFIC_ANGLE === ScientificAngleType.DEG}
					value={ScientificAngleType.DEG}>DEG</ComboBoxOption>
				<ComboBoxOption
					selected={DEFAULT_SCIENTIFIC_ANGLE === ScientificAngleType.GRAD}
					value={ScientificAngleType.GRAD}>GRAD</ComboBoxOption>
			</ComboBox>
		</div>
	</div>
	<div class={CSSClasses.bdPage_buttons} style="grid-template-columns: repeat(5, 1fr);">
		<Button data-command={Commands.key_char} data-char="mod" ButtonVariant={CButton.Variant.tonal}>mod</Button>
		<Button data-command={Commands.key_char} data-char="(" ButtonVariant={CButton.Variant.tonal}>(</Button>
		<Button data-command={Commands.key_char} data-char=")" ButtonVariant={CButton.Variant.tonal}>)</Button>
		<Button data-command={Commands.key_clear} ButtonVariant={CButton.Variant.tonal} style={`color:rgb(${AppCSSColors.accent})`}>C</Button>
		<Button data-command={Commands.key_backspace} ButtonVariant={CButton.Variant.tonal} style={`color:rgb(${AppCSSColors.accent})`}><Icon IconCode={IconCodes.backspace}/></Button>

		<Button data-command={Commands.key_char} data-char="%" ButtonVariant={CButton.Variant.tonal}>%</Button>
		<Button data-command={Commands.key_char} data-char="10^" ButtonVariant={CButton.Variant.tonal}>10^</Button>
		<Button data-command={Commands.key_char} data-char="^2" ButtonVariant={CButton.Variant.tonal}>^2</Button>
		<Button data-command={Commands.key_char} data-char="e^" ButtonVariant={CButton.Variant.tonal}>e^</Button>
		<Button data-command={Commands.key_char} data-char="^" ButtonVariant={CButton.Variant.tonal}><Icon IconCode={IconCodes.chevronUp}/></Button>

		<Button data-command={Commands.key_char} data-char="!" ButtonVariant={CButton.Variant.tonal}>!</Button>
		<Button data-command={Commands.key_char} data-char="7" data-type="number" ButtonVariant={CButton.Variant.tonal}>7</Button>
		<Button data-command={Commands.key_char} data-char="8" data-type="number" ButtonVariant={CButton.Variant.tonal}>8</Button>
		<Button data-command={Commands.key_char} data-char="9" data-type="number" ButtonVariant={CButton.Variant.tonal}>9</Button>
		<Button data-command={Commands.key_char} data-char="÷" ButtonVariant={CButton.Variant.tonal}><Icon IconCode={IconCodes.slashForward}/></Button>

		<Button data-command={Commands.key_char} data-char="e" ButtonVariant={CButton.Variant.tonal}>e</Button>
		<Button data-command={Commands.key_char} data-char="4" data-type="number" ButtonVariant={CButton.Variant.tonal}>4</Button>
		<Button data-command={Commands.key_char} data-char="5" data-type="number" ButtonVariant={CButton.Variant.tonal}>5</Button>
		<Button data-command={Commands.key_char} data-char="6" data-type="number" ButtonVariant={CButton.Variant.tonal}>6</Button>
		<Button data-command={Commands.key_char} data-char="×" ButtonVariant={CButton.Variant.tonal}><Icon IconCode={IconCodes.dismiss}/></Button>

		<Button data-command={Commands.key_char} data-char="π" ButtonVariant={CButton.Variant.tonal}>π</Button>
		<Button data-command={Commands.key_char} data-char="1" data-type="number" ButtonVariant={CButton.Variant.tonal}>1</Button>
		<Button data-command={Commands.key_char} data-char="2" data-type="number" ButtonVariant={CButton.Variant.tonal}>2</Button>
		<Button data-command={Commands.key_char} data-char="3" data-type="number" ButtonVariant={CButton.Variant.tonal}>3</Button>
		<Button data-command={Commands.key_char} data-char="-" ButtonVariant={CButton.Variant.tonal}><Icon IconCode={IconCodes.lineHorizontal1}/></Button>

		<Button data-command={Commands.key_char} data-char="√" ButtonVariant={CButton.Variant.tonal}>√</Button>
		<Button data-command={Commands.key_char} data-char="0" data-type="number" ButtonVariant={CButton.Variant.tonal}>0</Button>
		<Button data-command={Commands.key_dec} ButtonVariant={CButton.Variant.tonal}>.</Button>
		<Button data-command={Commands.key_equal} ButtonVariant={CButton.Variant.filled} style="font-weight:bold">=</Button>
		<Button data-command={Commands.key_char} data-char="+" ButtonVariant={CButton.Variant.tonal}><Icon IconCode={IconCodes.add}/></Button>
	</div>
</div>