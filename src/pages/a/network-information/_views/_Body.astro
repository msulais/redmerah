---
import * as Ids from '../_scripts/shared/ids.enum.js'
import * as Icons from '@/enums/icons.enum.js'
import * as Styles from '../_styles/styles.enum.js'
---

<ul class={Styles.List}>
	<li>
		<p>
			<br-icon set:html={Icons.ArrowCircleDown}/>
			Downlink
		</p>
		<span id={Ids.Downlink}>N/A</span>
	</li>
	<li>
		<p>
			<br-icon set:html={Icons.ArrowCircleDownDouble}/>
			Downlink Max
		</p>
		<span id={Ids.DownlinkMax}>N/A</span>
	</li>
	<li>
		<p>
			<br-icon set:html={Icons.NetworkCheck}/>
			Effective Type
		</p>
		<span id={Ids.EffectiveType}>N/A</span>
	</li>
	<li>
		<p>
			<br-icon set:html={Icons.ArrowCircleDownUp}/>
			Round Trip Time
		</p>
		<span id={Ids.RoundTripTime}>N/A</span>
	</li>
	<li>
		<p>
			<br-icon set:html={Icons.Wifi1}/>
			Type
		</p>
		<span id={Ids.Type}>N/A</span>
	</li>
	<li>
		<p>
			<br-icon set:html={Icons.LeafTwo}/>
			Data Saver
		</p>
		<span id={Ids.DataSaver}>N/A</span>
	</li>
</ul>