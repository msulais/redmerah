---
import AppBar from '@/components/AppBar/index.astro'
import IconButton from '@/components/Button/IconButton.astro'
import Tooltip from '@/components/Tooltip/index.astro'
import { APP_MARKDOWN_CONVERTER as APP } from '@/constants/apps'
import Menu from '@/components/Menu/index.astro'
import SubMenu from '@/components/Menu/SubMenu.astro'
import CheckMenuItem from '@/components/Menu/CheckMenuItem.astro'
import SubMenuItem from '@/components/Menu/SubMenuItem.astro'
import RadioMenuItem from '@/components/Menu/RadioMenuItem.astro'
import MenuHeader from '@/components/Menu/MenuHeader.astro'
import MenuItem from '@/components/Menu/MenuItem.astro'
import MenuIndent from '@/components/Menu/MenuIndent.astro'
import Icon from '@/components/Icon/index.astro'
import LinkMenuItem from '@/components/Menu/LinkMenuItem.astro'
import Divider from '@/components/Divider/index.astro'
import { PlatformAnimationMode, PlatformThemeMode } from '@/enums/platforms'
import logoRedmerah from '@/assets/images/logos/redmerah-logo.svg'
import logoCSS from '@/assets/images/logos/css-logo.svg'
import logoHTML from '@/assets/images/logos/html-logo.svg'
import { RoutesLinks, ExternalLinks } from '@/enums/links'
import { IconCodes } from '@/enums/icons'
import { ElementIds } from '../_scripts/_shared/_ids'
import { RadioNames } from '../_scripts/_shared/_input-names'
import { DEFAULT_ANIMATION, DEFAULT_TEXT_WRAP, DEFAULT_THEME } from '../_scripts/_shared/_constant'

const animations: {
	value: PlatformAnimationMode
	text: string
	icon: number
}[] = [
	{
		value: PlatformAnimationMode.auto,
		text: 'Automatic',
		icon: IconCodes.videoClipOptimize
	},
	{
		value: PlatformAnimationMode.on,
		text: 'On',
		icon: IconCodes.videoClip
	},
	{
		value: PlatformAnimationMode.off,
		text: 'Off',
		icon: IconCodes.videoClipOff
	},
]
const themes: {
	value: PlatformThemeMode
	text: string
	icon: number
}[] = [
	{
		value: PlatformThemeMode.auto,
		text: 'Automatic',
		icon: IconCodes.laptopSettings
	},
	{
		value: PlatformThemeMode.light,
		text: 'Light',
		icon: IconCodes.weatherSunny
	},
	{
		value: PlatformThemeMode.dark,
		text: 'Dark',
		icon: IconCodes.weatherMoon
	},
]
---

<AppBar id={ElementIds.appbar}>
	<Fragment slot="leading">
		<img
			src={APP.logoUrl}
			alt={APP.name + ' logo'}
			width={32}
			style="margin:0 8px 0 12px"
		/>
	</Fragment>
	<Fragment slot="headline">{APP.name}</Fragment>
	<Tooltip slot="trailing">
		<IconButton
			id={ElementIds.apInf_btn}
			data-tooltip="Info"
			aria-label="Info"
			IconButtonCode={IconCodes.info}
			popovertarget={ElementIds.apInf_menu}
		/>
		<Menu id={ElementIds.apInf_menu} PopoverAnchorBy={ElementIds.apInf_btn}>
			<LinkMenuItem href="/">
				<img src={logoRedmerah.src} width="20"/>
				Redmerah
				<MenuIndent />
			</LinkMenuItem>
			<LinkMenuItem href={RoutesLinks.apps}>
				<Icon IconCode={IconCodes.apps}/>
				More apps
				<MenuIndent />
			</LinkMenuItem>
			<LinkMenuItem href={RoutesLinks.about}>
				<Icon IconCode={IconCodes.info}/>
				About us
				<MenuIndent />
			</LinkMenuItem>
			<Divider />
			<LinkMenuItem href={RoutesLinks.privacy}>
				<Icon IconCode={IconCodes.shieldCheckmark}/>
				Privacy policy
				<MenuIndent />
			</LinkMenuItem>
			<LinkMenuItem href={RoutesLinks.terms}>
				<Icon IconCode={IconCodes.receipt}/>
				Terms & conditions
				<MenuIndent />
			</LinkMenuItem>
			<Divider />
			<MenuItem id={ElementIds.apInf_shareBtn}>
				<Icon IconCode={IconCodes.shareAndroid}/>
				Share
				<MenuIndent />
			</MenuItem>
			<LinkMenuItem href={'mailto:' + ExternalLinks.contactEmail + '?subject=' + encodeURI(APP.name)}>
				<Icon IconCode={IconCodes.chat}/>
				Send feedback
				<MenuIndent />
			</LinkMenuItem>
			<LinkMenuItem href={ExternalLinks.donate} LinkButtonNewTab>
				<Icon IconCode={IconCodes.gift}/>
				Donate
				<MenuIndent />
			</LinkMenuItem>
			<MenuHeader>&copy; {new Date().getFullYear()} Redmerah</MenuHeader>
		</Menu>

		<IconButton
			id={ElementIds.apSett_btn}
			data-tooltip="Settings"
			IconButtonCode={IconCodes.settings}
			aria-label="Settings"
			popovertarget={ElementIds.apSett_menu}
		/>
		<Menu id={ElementIds.apSett_menu} PopoverAnchorBy={ElementIds.apSett_btn}>
			<SubMenuItem
				popovertarget={ElementIds.apSett_animationMenu}>
				<Icon IconCode={IconCodes.playCircleHint}/>
				Animation
				<div style="flex:1"/>
				<Icon IconCode={IconCodes.chevronRight}/>
			</SubMenuItem>
			<SubMenu style="width:150px" id={ElementIds.apSett_animationMenu}>
				{animations.map(v =>
					<RadioMenuItem
						RadioMenuItemName={RadioNames.animation}
						RadioMenuItemChecked={DEFAULT_ANIMATION === v.value}
						RadioMenuItemValue={v.value}>
						<Icon IconCode={v.icon}/>
						{v.text}
					</RadioMenuItem>
				)}
			</SubMenu>

			<SubMenuItem
				popovertarget={ElementIds.apSett_themeMenu}>
				<Icon IconCode={IconCodes.weatherSunny}/>
				Theme
				<div style="flex:1"/>
				<Icon IconCode={IconCodes.chevronRight}/>
			</SubMenuItem>
			<SubMenu style="width:150px" id={ElementIds.apSett_themeMenu}>
				{themes.map(v =>
					<RadioMenuItem
						RadioMenuItemName={RadioNames.theme}
						RadioMenuItemChecked={DEFAULT_THEME === v.value}
						RadioMenuItemValue={v.value}>
						<Icon IconCode={v.icon}/>
						{v.text}
					</RadioMenuItem>
				)}
			</SubMenu>

			<Divider/>
			<CheckMenuItem
				CheckMenuItemInputAttr={{id: ElementIds.apSett_textWrap}}
				CheckMenuItemChecked={DEFAULT_TEXT_WRAP}>
				Text wrap
				<MenuIndent />
			</CheckMenuItem>
		</Menu>

		<IconButton
			id={ElementIds.apMore_btn}
			data-tooltip="More actions"
			IconButtonCode={IconCodes.moreVertical}
			aria-label="More actions"
			popovertarget={ElementIds.apMore_menu}
		/>
		<Menu id={ElementIds.apMore_menu} PopoverAnchorBy={ElementIds.apMore_btn}>
			<MenuItem id={ElementIds.apMore_print}>
				<Icon IconCode={IconCodes.print}/>
				Print
				<MenuIndent />
			</MenuItem>
			<MenuItem id={ElementIds.apMore_open}>
				<Icon IconCode={IconCodes.documentArrowRight}/>
				Open file
				<MenuIndent />
			</MenuItem>

			<SubMenuItem
				popovertarget={ElementIds.apMore_copyMenu}>
				<Icon IconCode={IconCodes.copy}/>
				Copy
				<div style="flex:1"/>
				<Icon IconCode={IconCodes.chevronRight}/>
			</SubMenuItem>
			<SubMenu style="width:150px" id={ElementIds.apMore_copyMenu}>
				<MenuItem id={ElementIds.apMore_copyMarkdown}>
					<svg width={20} viewBox="0 0 2560 2560" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M2375.4 2067.68H184.6C82.8 2067.68 0 1984.88 0 1883.08V676.92C0 575.12 82.8 492.32 184.6 492.32H2375.36C2477.16 492.32 2559.96 575.12 2559.96 676.92V1883.08C2560 1984.88 2477.2 2067.68 2375.4 2067.68ZM615.4 1698.48V1218.48L861.56 1526.16L1107.72 1218.48V1698.48H1353.88V861.52H1107.72L861.56 1169.2L615.4 861.52H369.24V1698.44H615.4V1698.48ZM2264.6 1280H2018.44V861.52H1772.28V1280H1526.12L1895.36 1710.76L2264.6 1280Z" fill="rgb(var(--g-color-on-surface))"/>
					</svg>
					Markdown
				</MenuItem>
				<MenuItem id={ElementIds.apMore_copyCSS}>
					<img width={20} src={logoCSS.src} alt="CSS logo"/>
					CSS
				</MenuItem>
				<MenuItem id={ElementIds.apMore_copyHTML}>
					<img width={20} src={logoHTML.src} alt="HTML logo"/>
					HTML
				</MenuItem>
			</SubMenu>

			<SubMenuItem
				popovertarget={ElementIds.apMore_downloadMenu}>
				<Icon IconCode={IconCodes.arrowDownload}/>
				Download
				<div style="flex:1"/>
				<Icon IconCode={IconCodes.chevronRight}/>
			</SubMenuItem>
			<SubMenu style="width:150px" id={ElementIds.apMore_downloadMenu}>
				<MenuItem id={ElementIds.apMore_downloadMarkdown}>
					<svg width={20} viewBox="0 0 2560 2560" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M2375.4 2067.68H184.6C82.8 2067.68 0 1984.88 0 1883.08V676.92C0 575.12 82.8 492.32 184.6 492.32H2375.36C2477.16 492.32 2559.96 575.12 2559.96 676.92V1883.08C2560 1984.88 2477.2 2067.68 2375.4 2067.68ZM615.4 1698.48V1218.48L861.56 1526.16L1107.72 1218.48V1698.48H1353.88V861.52H1107.72L861.56 1169.2L615.4 861.52H369.24V1698.44H615.4V1698.48ZM2264.6 1280H2018.44V861.52H1772.28V1280H1526.12L1895.36 1710.76L2264.6 1280Z" fill="rgb(var(--g-color-on-surface))"/>
					</svg>
					Markdown
				</MenuItem>
				<MenuItem id={ElementIds.apMore_downloadCSS}>
					<img width={20} src={logoCSS.src} alt="CSS logo"/>
					CSS
				</MenuItem>
				<MenuItem id={ElementIds.apMore_downloadHTML}>
					<img width={20} src={logoHTML.src} alt="HTML logo"/>
					HTML
				</MenuItem>
			</SubMenu>

			<Divider/>
			<MenuItem id={ElementIds.apMore_resetMarkdown}>
				<svg width={20} viewBox="0 0 2560 2560" fill="none" xmlns="http://www.w3.org/2000/svg">
					<path d="M2375.4 2067.68H184.6C82.8 2067.68 0 1984.88 0 1883.08V676.92C0 575.12 82.8 492.32 184.6 492.32H2375.36C2477.16 492.32 2559.96 575.12 2559.96 676.92V1883.08C2560 1984.88 2477.2 2067.68 2375.4 2067.68ZM615.4 1698.48V1218.48L861.56 1526.16L1107.72 1218.48V1698.48H1353.88V861.52H1107.72L861.56 1169.2L615.4 861.52H369.24V1698.44H615.4V1698.48ZM2264.6 1280H2018.44V861.52H1772.28V1280H1526.12L1895.36 1710.76L2264.6 1280Z" fill="rgb(var(--g-color-on-surface))"/>
				</svg>
				Reset markdown
				<MenuIndent />
			</MenuItem>
			<MenuItem id={ElementIds.apMore_resetCSS}>
				<img width={20} src={logoCSS.src} alt="CSS logo"/>
				Reset CSS
				<MenuIndent />
			</MenuItem>
		</Menu>
	</Tooltip>
</AppBar>