	<AppBar/>
	<div style={{
		width: '100%',
		maxWidth: '100%',
		display: 'flex',
		flexDirection: 'column',
		alignItems: 'center',
		minHeight: '100dvh',
		backgroundColor: `rgb(var(${BrTheme.CSSVars.ColorBackground}))`,
		justifyContent: 'center'
	}}>
		<h1 style={{
			padding: '4rem 1rem 1rem 1rem',
			fontSize: 'max(min(16vmin, 10.25rem), 4rem)'
		}}><code>PAGE<br/>NOT<br/>FOUND</code></h1>
		<a br:as="button" href={Routes.Home} br:variant="filled">
			<br-icon set:html={Icons.HomeFilled}/>
