---
import type { HEXColor } from '@/types/color'
import { RoutesLinks } from '@/enums/links'
import { APPS } from '@/constants/apps'
import { hexToHsl, hexToRgb, generateColorPalette } from '@/utils/color'
import Splash from '@/layouts/Splash/index.astro'
import Html from '@/layouts/Html/index.astro'
import Icon from '@/components/Icon/index.astro'
import LinkButton from '@/components/Button/LinkButton.astro'
import { CButton } from '@/components/Button'
import Appbar from '@/layouts/Appbar/index.astro'
import BottomBar from '@/layouts/BottomBar/index.astro'
import CSS from './_index.module.scss'
import { IconCodes } from '@/enums/icons'
import feature_uiUx from '@/assets/images/feature_ui_ux.svg'
import feature_offlineWork from '@/assets/images/feature_offline_work.svg'
import feature_localDB from '@/assets/images/feature_local_db.svg'
import { shuffleArray } from '@/utils/array'

const features = [
	{
		title: 'Prioritize UI/UX & Functionality',
		description: 'Experience the perfect blend of aesthetics and usability. Our apps offer a visually stunning interface that is easy to navigate and packed with features.',
		icon: feature_uiUx
	},
	{
		title: 'Store Data Locally on Your Device',
		description: 'We respect your privacy. All your settings, preferences, and history are stored securely in your browser, not on our server. Your data, your control.',
		icon: feature_localDB
	},
	{
		title: 'Continue Working Offline',
		description: 'No internet connection? No problem! Our apps work seamlessly offline, ensuring you can stay productive wherever you are.',
		icon: feature_offlineWork
	},
]

function appColorCustom(color: HEXColor): string {
	const hsl = hexToHsl(color)
	const palette = generateColorPalette(color)
	const css = (d: HEXColor) => {
		const rgb = hexToRgb(d)
		return [Math.round(rgb.r * 0xff), Math.round(rgb.g * 0xff), Math.round(rgb.b * 0xff)].join(', ')
	}
	return [
		`--hue:${hsl.h * 360}`,
		`--color-accent-light: ${css(palette.color)}`,
		`--color-on-accent-light: ${css(palette.onColor)}`,
		`--color-accent-dark: ${css(palette.colorDark)}`,
		`--color-on-accent-dark: ${css(palette.onColorDark)}`,
	].join(';')
}
---

<Html>
	<Splash>
		<svg width="512" height="512" viewBox="0 0 512 512" fill="none" xmlns="http://www.w3.org/2000/svg">
			<g clip-path="url(#clip0_864_188)">
				<path d="M256 320V240C256 222.327 241.673 208 224 208C206.327 208 192 222.327 192 240V464C192 478.91 192 486.365 189.564 492.246C186.316 500.087 180.087 506.316 172.246 509.564C166.365 512 158.91 512 144 512V512C129.09 512 121.635 512 115.754 509.564C107.913 506.316 101.684 500.087 98.4359 492.246C96 486.365 96 478.91 96 464V240C96 169.308 153.308 112 224 112C294.692 112 352 169.308 352 240V320C352 343.016 352.037 357.876 352.812 369.25C353.559 380.194 354.829 384.378 355.656 386.375C360.528 398.131 369.869 407.472 381.625 412.344C383.622 413.171 387.806 414.441 398.75 415.188C399.166 415.216 399.586 415.243 400.011 415.27C416.056 416.266 424.079 416.764 429.607 419.361C437.289 422.97 442.625 428.648 445.75 436.538C448 442.216 448 449.478 448 464V464C448 479.086 448 486.63 445.427 492.653C442.092 500.457 435.2 507.05 427.256 510.035C421.125 512.339 414.085 512.026 400.006 511.402C397.324 511.283 394.728 511.14 392.219 510.969C376.39 509.889 360.548 507.509 344.906 501.031C309.622 486.416 281.584 458.378 266.969 423.094C260.491 407.452 258.111 391.61 257.031 375.781C255.981 360.383 256 341.703 256 320Z" fill="url(#paint0_linear_864_188)"/>
				<rect x="32" y="32" width="448" height="288" rx="64" fill="#7A0000" stroke="#FF1414" stroke-width="64"/>
			</g>
			<defs>
				<linearGradient id="paint0_linear_864_188" x1="288" y1="288" x2="288" y2="512" gradientUnits="userSpaceOnUse">
					<stop stop-color="#A30000"/>
					<stop offset="1" stop-color="#FF1414"/>
				</linearGradient>
				<clipPath id="clip0_864_188">
					<rect width="512" height="512" fill="white"/>
				</clipPath>
			</defs>
		</svg>
	</Splash>
	<Appbar route={RoutesLinks.home}/>
	<div class={CSS.body}>
		<section class={CSS.header}>
			<div>
				<h1 class={CSS.fadeOnView}><span>Apps</span><br/><span>Tasks</span><br/><span>Productivity</span></h1>
				<div class={CSS.fadeOnView}>
					<ul>
						{shuffleArray([...APPS]).map((v, i) => <>{i < 5 && <li>
							<img tabindex="0" data-tooltip={v.name} src={v.logoUrl} alt={v.name}/>
						</li>}</>)}
						{APPS.length > 5 && <li
							data-css-more>
							{APPS.length - 5}+ more apps
						</li>}
					</ul>
					<p>Discover a suite of powerful apps designed to simplify your tasks and enhance your productivity</p>
					<LinkButton
						LinkButtonVariant={CButton.Variant.filled}
						href={RoutesLinks.apps}
						style={{width: 'fit-content'}}>
						Browse apps
						<Icon IconFilled IconCode={IconCodes.arrowRight}/>
					</LinkButton>
				</div>
			</div>
		</section>
		<section class={CSS.apps}>
			<h2 class={CSS.heading}><div><span>Apps</span></div></h2>
			<div>
				<ul>
					{APPS.map((v, i) => <>{i < 3 && <li
						class={CSS.fadeOnView}
						style={appColorCustom(v.color)}>
						<img src={v.logoUrl} alt={v.name} />
						<h3>{v.name}</h3>
						<p style="flex:1">{v.description}</p>
						<LinkButton
							LinkButtonVariant={CButton.Variant.filled}
							href={v.link}><Icon IconCode={IconCodes.openFolder}/> Open</LinkButton>
					</li>}</>)}
				</ul>
				<LinkButton
					class={CSS.fadeOnView}
					LinkButtonVariant={CButton.Variant.filled}
					href={RoutesLinks.apps}>
					See {APPS.length-3} more apps
					<Icon IconFilled IconCode={IconCodes.arrowRight}/>
				</LinkButton>
			</div>
		</section>
		<section class={CSS.features}>
			<h2 class={CSS.heading}><div><span>Features</span></div></h2>
			<div>
				<ul>
					{features.map(v => <li class={CSS.fadeOnView}>
						<img src={v.icon.src} alt={v.title}/>
						<h3>{v.title}</h3>
						<p>{v.description}</p>
					</li>)}
				</ul>
			</div>
		</section>
	</div>
	<BottomBar>
		<p id="quote" class={[CSS.quote, CSS.fadeOnView].join(' ')}><q>
			{ 'We are also users. What’s good for you, good for us too.'.split(' ').map(v => <><span>{v}</span> </>) }
		</q></p>
	</BottomBar>
</Html>

<script>
	import { isAnimationAllowed } from "@/utils/animation"
	import CSS from './_index.module.scss'
	import { pxToRem } from "@/utils/css"
	import { AnimationEasing } from "@/enums/animation"

	const quote = document.getElementById('quote') as HTMLParagraphElement
	const spans = document.querySelectorAll<HTMLSpanElement>('#quote span')
	const refs = document.querySelectorAll(`.${CSS.fadeOnView}`)
	const observer1 = new IntersectionObserver((entries) => {
		if (!isAnimationAllowed()) return

		for (const entry of entries) {
			if (!entry.isIntersecting) continue;
			for (let i = 0; i < (spans as unknown as any[]).length; i++) {
				spans[i].animate([{
					transform: 'translateY(-0.4em)',
					offset: 0.5
				}], {
					duration: 1000,
					delay: i * 200,
					easing: 'cubic-bezier(.15, 0, 0, 1)',
					iterations: 1,
				})
			}
		}
	}, {
		root: null,
		threshold: 1.0
	})
	const targets = new Set<HTMLElement>()
	const observer2 = new IntersectionObserver((entries) => {
		for (const entry of entries) {
			if (entry.isIntersecting) {
				const ref_target = entry.target as HTMLElement
				if (targets.has(ref_target)) {
					continue
				}

				ref_target.style.setProperty('opacity', '1')
				if (isAnimationAllowed()){
					ref_target.animate({
						opacity: [0, 1],
						translate: [`0 ${pxToRem(64)}rem`, '0 0']
					}, {
						duration: 1000,
						easing: AnimationEasing.spring
					})
				}
				targets.add(ref_target)
			}
		}
	}, {
		root: null,
		threshold: 0
	})

	for (const ref of refs) {
		observer2.observe(ref)
	}

	observer1.observe(quote)
</script>